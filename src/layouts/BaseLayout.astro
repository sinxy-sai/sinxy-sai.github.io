---
import { Archive, Home, Moon, Rss, Search, Sun, Tags, User } from "lucide-astro";
import AmbientFlow from "../components/AmbientFlow.astro";
import "katex/dist/katex.min.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  tags?: string[];
}

const siteTitle = "Sinxy Sai's Blog";
const {
  title = "首页",
  description = "Personal notes on computer science, algorithms, and building things.",
  image = "/avatar.jpg",
  type = "website",
  publishedTime,
  tags = [],
} = Astro.props;

const pageTitle = `${title} | ${siteTitle}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const imageUrl = new URL(image, Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Sinxy Sai" />
    <meta name="robots" content="index, follow" />
    <meta id="theme-color-meta" name="theme-color" content="#f6fbf5" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="Sinxy Sai's Blog" />
    {
      type === "article" && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        try {
          const storedTheme = localStorage.getItem("sinxy-theme");
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const theme = storedTheme === "light" || storedTheme === "dark"
            ? storedTheme
            : prefersDark
              ? "dark"
              : "light";

          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme;
        } catch {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
  </head>
  <body>
    <AmbientFlow />

    <header class="site-header">
      <a class="brand" href="/" aria-label="返回首页">
        <span class="brand-mark" aria-hidden="true">
          <img src="/favicon.png" alt="" width="52" height="52" />
        </span>
        <span>
          <strong>{siteTitle}</strong>
          <small>notes, code, and tiny discoveries</small>
        </span>
      </a>
      <form class="header-search" role="search" data-pagefind-ignore>
        <label class="header-search-label" for="site-search-input">搜索文章</label>
        <div class="header-search-field">
          <Search size={18} aria-hidden="true" />
          <input
            id="site-search-input"
            class="header-search-input"
            type="search"
            placeholder="搜索 DCP、维纳滤波..."
            autocomplete="off"
          />
        </div>
        <div id="site-search-panel" class="header-search-panel" hidden>
          <p id="site-search-status" class="header-search-status">输入关键词开始搜索。</p>
          <div id="site-search-results" class="header-search-results" aria-live="polite"></div>
        </div>
      </form>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/">
          <Home size={16} aria-hidden="true" />
          <span>首页</span>
        </a>
        <a href="/archive/">
          <Archive size={16} aria-hidden="true" />
          <span>归档</span>
        </a>
        <a href="/tags/">
          <Tags size={16} aria-hidden="true" />
          <span>标签</span>
        </a>
        <a href="/about/">
          <User size={16} aria-hidden="true" />
          <span>关于</span>
        </a>
        <button
          class="theme-toggle"
          type="button"
          data-theme-toggle
          aria-label="切换到夜间模式"
          aria-pressed="false"
        >
          <Sun class="theme-icon theme-icon-sun" size={16} aria-hidden="true" />
          <Moon class="theme-icon theme-icon-moon" size={16} aria-hidden="true" />
          <span data-theme-toggle-text>夜间</span>
        </button>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span>© {new Date().getFullYear()} Sinxy Sai. Content rights reserved.</span>
      <span class="footer-links">
        <a class="footer-rss" href="/rss.xml" aria-label="RSS 订阅">
          <Rss size={16} aria-hidden="true" />
          <span>RSS</span>
        </a>
        <span aria-hidden="true">·</span>
        <a href="https://astro.build/" target="_blank" rel="noreferrer">Built with Astro</a>
      </span>
    </footer>
    <script is:inline>
      const themeToggle = document.querySelector("[data-theme-toggle]");
      const themeToggleText = document.querySelector("[data-theme-toggle-text]");
      const themeColorMeta = document.querySelector("#theme-color-meta");

      function setSiteTheme(theme, shouldStore = true) {
        const isDark = theme === "dark";

        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
        if (themeColorMeta) {
          themeColorMeta.setAttribute("content", isDark ? "#101815" : "#f6fbf5");
        }

        if (themeToggle) {
          themeToggle.setAttribute("aria-pressed", String(isDark));
          themeToggle.setAttribute("aria-label", isDark ? "切换到白天模式" : "切换到夜间模式");
        }

        if (themeToggleText) {
          themeToggleText.textContent = isDark ? "白天" : "夜间";
        }

        if (shouldStore) {
          localStorage.setItem("sinxy-theme", theme);
        }
      }

      const initialTheme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
      setSiteTheme(initialTheme, false);

      themeToggle?.addEventListener("click", () => {
        const currentTheme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
        setSiteTheme(currentTheme === "dark" ? "light" : "dark");
      });

      const siteSearchForm = document.querySelector(".header-search");
      const siteSearchInput = document.querySelector("#site-search-input");
      const siteSearchPanel = document.querySelector("#site-search-panel");
      const siteSearchStatus = document.querySelector("#site-search-status");
      const siteSearchResults = document.querySelector("#site-search-results");

      const escapeSearchHtml = (value) =>
        value.replace(/[&<>"']/g, (char) => ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[char]);

      let sitePagefind;
      let siteSearchRequestId = 0;

      async function loadSitePagefind() {
        if (sitePagefind) return sitePagefind;
        const importPagefind = new Function("path", "return import(path)");
        const loadedPagefind = await importPagefind("/pagefind/pagefind.js");
        sitePagefind = loadedPagefind.createInstance({
          basePath: "/pagefind/",
          noWorker: true,
        });
        await sitePagefind.init();
        return sitePagefind;
      }

      function closeSiteSearch() {
        if (siteSearchPanel) siteSearchPanel.hidden = true;
      }

      async function runSiteSearch(query) {
        const currentRequest = ++siteSearchRequestId;
        const trimmed = query.trim();

        if (!trimmed) {
          closeSiteSearch();
          if (siteSearchResults) siteSearchResults.innerHTML = "";
          return;
        }

        if (siteSearchPanel) siteSearchPanel.hidden = false;
        if (siteSearchStatus) siteSearchStatus.textContent = "正在搜索...";

        try {
          const search = await (await loadSitePagefind()).search(trimmed);
          if (currentRequest !== siteSearchRequestId) return;

          const resultData = await Promise.all(
            search.results.slice(0, 6).map((result) => result.data()),
          );

          if (siteSearchStatus) {
            siteSearchStatus.textContent = resultData.length
              ? `找到 ${search.results.length} 条结果`
              : "没有找到匹配的文章";
          }

          if (siteSearchResults) {
            siteSearchResults.innerHTML = resultData
              .map((item) => `
                <a class="header-search-result" href="${item.url}">
                  <strong>${escapeSearchHtml(item.meta.title || "Untitled")}</strong>
                  <span>${item.excerpt || ""}</span>
                </a>
              `)
              .join("");
          }
        } catch (error) {
          console.error("Pagefind search failed:", error);
          if (siteSearchStatus) siteSearchStatus.textContent = "搜索暂时不可用，请先运行构建。";
          if (siteSearchResults) siteSearchResults.innerHTML = "";
        }
      }

      siteSearchInput?.addEventListener("input", (event) => {
        runSiteSearch(event.target.value);
      });

      siteSearchForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        const firstResult = siteSearchResults?.querySelector("a");
        if (firstResult instanceof HTMLAnchorElement) {
          window.location.href = firstResult.href;
        }
      });

      document.addEventListener("click", (event) => {
        if (!siteSearchForm?.contains(event.target)) {
          closeSiteSearch();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeSiteSearch();
          siteSearchInput?.blur();
        }
      });

      const siteHeader = document.querySelector(".site-header");
      let lastScrollY = window.scrollY;
      let ticking = false;

      function updateHeaderVisibility() {
        const currentScrollY = window.scrollY;
        const scrollingDown = currentScrollY > lastScrollY;
        const searchIsActive =
          siteSearchInput === document.activeElement ||
          (siteSearchPanel && !siteSearchPanel.hidden);

        if (!siteHeader) {
          ticking = false;
          return;
        }

        siteHeader.classList.toggle("is-floating", currentScrollY > 24 || searchIsActive);

        if (currentScrollY < 80 || searchIsActive || currentScrollY < lastScrollY) {
          siteHeader.classList.remove("is-hidden");
        } else if (scrollingDown) {
          siteHeader.classList.add("is-hidden");
        }

        lastScrollY = Math.max(currentScrollY, 0);
        ticking = false;
      }

      window.addEventListener(
        "scroll",
        () => {
          if (!ticking) {
            window.requestAnimationFrame(updateHeaderVisibility);
            ticking = true;
          }
        },
        { passive: true },
      );

      const tocLinks = Array.from(document.querySelectorAll(".article-toc a[href^='#']"));
      const tocHeadings = tocLinks
        .map((link) => {
          const id = link.getAttribute("href")?.slice(1);
          return id ? document.getElementById(id) : null;
        })
        .filter(Boolean);
      let activeTocId = "";
      let tocTicking = false;

      function setActiveToc(id) {
        if (!id || id === activeTocId) return;
        activeTocId = id;

        tocLinks.forEach((link) => {
          const isActive = link.getAttribute("href") === `#${id}`;
          link.classList.toggle("is-active", isActive);
          if (isActive) {
            link.setAttribute("aria-current", "true");
            link.scrollIntoView({ block: "nearest", inline: "nearest" });
          } else {
            link.removeAttribute("aria-current");
          }
        });
      }

      function updateActiveToc() {
        if (!tocHeadings.length) {
          tocTicking = false;
          return;
        }

        const readingLine = window.innerHeight * 0.32;
        let currentHeading = tocHeadings[0];

        tocHeadings.forEach((heading) => {
          if (heading.getBoundingClientRect().top <= readingLine) {
            currentHeading = heading;
          }
        });

        setActiveToc(currentHeading.id);
        tocTicking = false;
      }

      if (tocHeadings.length) {
        updateActiveToc();
        window.addEventListener(
          "scroll",
          () => {
            if (!tocTicking) {
              window.requestAnimationFrame(updateActiveToc);
              tocTicking = true;
            }
          },
          { passive: true },
        );
        window.addEventListener("resize", updateActiveToc);
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f6fbf5;
    --bg-soft: #eef8ee;
    --surface: rgba(255, 255, 250, 0.82);
    --surface-strong: #fffef8;
    --surface-floating: rgba(255, 255, 250, 0.96);
    --surface-control: rgba(255, 255, 250, 0.72);
    --text: #22342f;
    --muted: #66756f;
    --line: rgba(113, 148, 137, 0.24);
    --accent: #75c9a5;
    --accent-strong: #2f8f70;
    --accent-soft: #dff4e9;
    --sun: #ffd98a;
    --rose: #f6b6c8;
    --code-bg: #24352f;
    --shadow: 0 22px 70px rgba(74, 116, 98, 0.16);
    --body-bg:
      radial-gradient(circle at 12% 8%, rgba(255, 217, 138, 0.48), transparent 22rem),
      radial-gradient(circle at 88% 12%, rgba(117, 201, 165, 0.35), transparent 24rem),
      linear-gradient(180deg, #fbfff9 0%, var(--bg) 46%, #f8fbf4 100%);
    --grid-line: rgba(117, 201, 165, 0.08);
    --scroll-track: rgba(223, 244, 233, 0.58);
    --scroll-thumb: rgba(47, 143, 112, 0.46);
    --scroll-thumb-hover: rgba(47, 143, 112, 0.68);
    --radius: 18px;
    font-family:
      ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Noto Sans SC", "Microsoft YaHei", sans-serif;
  }

  html[data-theme="dark"] {
    color-scheme: dark;
    --bg: #101815;
    --bg-soft: #18231f;
    --surface: rgba(24, 35, 31, 0.82);
    --surface-strong: #17211d;
    --surface-floating: rgba(20, 31, 27, 0.96);
    --surface-control: rgba(24, 35, 31, 0.76);
    --text: #e8f1ea;
    --muted: #a8b8b0;
    --line: rgba(166, 207, 189, 0.18);
    --accent: #88d8b8;
    --accent-strong: #9de4c6;
    --accent-soft: rgba(80, 145, 116, 0.22);
    --sun: #f4c970;
    --rose: #f3a8bc;
    --code-bg: #0b1210;
    --shadow: 0 22px 70px rgba(0, 0, 0, 0.34);
    --body-bg:
      radial-gradient(circle at 12% 8%, rgba(244, 201, 112, 0.18), transparent 22rem),
      radial-gradient(circle at 88% 12%, rgba(136, 216, 184, 0.16), transparent 24rem),
      linear-gradient(180deg, #101815 0%, #111c18 48%, #141c19 100%);
    --grid-line: rgba(136, 216, 184, 0.06);
    --scroll-track: rgba(24, 35, 31, 0.82);
    --scroll-thumb: rgba(136, 216, 184, 0.38);
    --scroll-thumb-hover: rgba(136, 216, 184, 0.58);
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    scrollbar-color: var(--scroll-thumb) var(--scroll-track);
    scrollbar-width: thin;
    scroll-behavior: smooth;
  }

  *::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }

  *::-webkit-scrollbar-track {
    background: var(--scroll-track);
  }

  *::-webkit-scrollbar-thumb {
    border: 2px solid var(--bg);
    border-radius: 999px;
    background: var(--scroll-thumb);
  }

  *::-webkit-scrollbar-thumb:hover {
    background: var(--scroll-thumb-hover);
  }

  body {
    margin: 0;
    min-height: 100vh;
    overflow-x: hidden;
    color: var(--text);
    background: var(--body-bg);
    letter-spacing: 0;
    transition:
      background 220ms ease,
      color 220ms ease;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -2;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 34px 34px;
    mask-image: linear-gradient(to bottom, black, transparent 78%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a,
  button {
    -webkit-tap-highlight-color: transparent;
  }

  a:focus-visible,
  button:focus-visible {
    outline: 3px solid rgba(47, 143, 112, 0.45);
    outline-offset: 4px;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .site-header,
  .site-footer,
  main {
    position: relative;
    z-index: 1;
    width: min(1120px, calc(100% - 32px));
    margin-inline: auto;
  }

  .site-header {
    display: grid;
    grid-template-columns: minmax(220px, 0.92fr) minmax(260px, 1fr) auto;
    align-items: center;
    gap: 18px;
    padding: 24px 0;
    position: sticky;
    top: 10px;
    z-index: 10;
    isolation: isolate;
    transition:
      transform 220ms ease,
      opacity 220ms ease;
    will-change: transform;
  }

  .site-header::before {
    content: "";
    position: absolute;
    inset: 10px -14px;
    z-index: -1;
    border: 1px solid var(--line);
    border-radius: 28px;
    background: var(--surface-floating);
    box-shadow: 0 18px 54px rgba(74, 116, 98, 0.16);
    opacity: 0;
    backdrop-filter: blur(18px);
    transition: opacity 180ms ease;
  }

  .site-header.is-floating::before {
    opacity: 1;
  }

  .site-header.is-hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(calc(-100% - 24px));
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .brand-mark {
    box-sizing: border-box;
    display: grid;
    width: 52px;
    height: 52px;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid rgba(117, 201, 165, 0.58);
    border-radius: 18px;
    background: linear-gradient(145deg, var(--surface-strong), var(--bg-soft));
    box-shadow: 0 12px 32px rgba(74, 116, 98, 0.16);
    overflow: hidden;
  }

  .brand-mark img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand strong {
    font-size: 1rem;
  }

  .brand small {
    margin-top: 3px;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .header-search {
    position: relative;
    min-width: 0;
  }

  .header-search-label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .header-search-field {
    position: relative;
    display: flex;
    align-items: center;
  }

  .header-search-field svg {
    position: absolute;
    left: 14px;
    z-index: 1;
    color: var(--accent-strong);
    opacity: 0.82;
    pointer-events: none;
    stroke-width: 2.2;
  }

  .header-search-input {
    position: relative;
    width: 100%;
    min-height: 44px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface-control);
    color: var(--text);
    font: inherit;
    font-size: 0.92rem;
    padding: 0 16px 0 46px;
    box-shadow: 0 14px 38px rgba(74, 116, 98, 0.1);
    backdrop-filter: blur(16px);
    transition:
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .header-search-input::placeholder {
    color: color-mix(in srgb, var(--muted) 78%, transparent);
  }

  .header-search-input:focus {
    border-color: rgba(117, 201, 165, 0.8);
    background: var(--surface-floating);
    outline: 3px solid rgba(117, 201, 165, 0.22);
    box-shadow: 0 16px 44px rgba(74, 116, 98, 0.14);
  }

  .header-search-panel {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    left: 0;
    z-index: 30;
    max-height: min(520px, calc(100vh - 120px));
    overflow: auto;
    border: 1px solid var(--line);
    border-radius: 22px;
    background: var(--surface-floating);
    padding: 12px;
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .header-search-status {
    margin: 0 0 8px;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .header-search-results {
    display: grid;
    gap: 8px;
  }

  .header-search-result {
    display: grid;
    gap: 5px;
    border: 1px solid transparent;
    border-radius: 16px;
    padding: 10px;
    transition:
      background 180ms ease,
      border-color 180ms ease;
  }

  .header-search-result:hover {
    border-color: rgba(117, 201, 165, 0.48);
    background: var(--accent-soft);
  }

  .header-search-result strong {
    font-size: 0.92rem;
    line-height: 1.35;
  }

  .header-search-result span {
    display: -webkit-box;
    overflow: hidden;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.55;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 5px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface-control);
    box-shadow: 0 14px 38px rgba(74, 116, 98, 0.1);
    backdrop-filter: blur(16px);
  }

  .site-nav a,
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 38px;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font: inherit;
    font-size: 0.92rem;
    padding: 9px 14px;
    transition:
      color 180ms ease,
      background 180ms ease,
      transform 180ms ease;
  }

  .site-nav a svg,
  .theme-toggle svg {
    flex: 0 0 auto;
  }

  .site-nav a:hover,
  .theme-toggle:hover {
    background: var(--accent-soft);
    color: var(--accent-strong);
    transform: translateY(-1px);
  }

  .theme-toggle {
    position: relative;
    min-width: 82px;
  }

  .theme-icon-moon,
  html[data-theme="dark"] .theme-icon-sun {
    display: none;
  }

  html[data-theme="dark"] .theme-icon-moon {
    display: block;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 80px;
    padding: 28px 0 36px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.9rem;
  }

  .footer-links {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .footer-links a {
    color: var(--accent-strong);
