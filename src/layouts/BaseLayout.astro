---
interface Props {
  title?: string;
  description?: string;
}

const siteTitle = "Sinxy Sai's Blog";
const {
  title = "首页",
  description = "Personal notes on computer science, algorithms, and building things.",
} = Astro.props;

const pageTitle = `${title} | ${siteTitle}`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="ambient ambient-one" aria-hidden="true"></div>
    <div class="ambient ambient-two" aria-hidden="true"></div>

    <header class="site-header">
      <a class="brand" href="/" aria-label="返回首页">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 32 32" role="img">
            <path d="M7 19.8c5.7-.7 10.7-4.3 14.9-10.6 2.7 7.8-1.2 14.8-8.3 15.5-2.4.2-4.6-.6-6.6-2.1Z" />
            <path d="M8 22.6c4.2-1.8 7.7-4.5 10.6-8.2" />
          </svg>
        </span>
        <span>
          <strong>{siteTitle}</strong>
          <small>notes, code, and tiny discoveries</small>
        </span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/">首页</a>
        <a href="/archive/">归档</a>
        <a href="/tags/">标签</a>
        <a href="/about/">关于</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span>© {new Date().getFullYear()} sinxy-sai</span>
      <span>Built with Astro</span>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f6fbf5;
    --bg-soft: #eef8ee;
    --surface: rgba(255, 255, 250, 0.82);
    --surface-strong: #fffef8;
    --text: #22342f;
    --muted: #66756f;
    --line: rgba(113, 148, 137, 0.24);
    --accent: #75c9a5;
    --accent-strong: #2f8f70;
    --accent-soft: #dff4e9;
    --sun: #ffd98a;
    --rose: #f6b6c8;
    --code-bg: #24352f;
    --shadow: 0 22px 70px rgba(74, 116, 98, 0.16);
    --radius: 18px;
    font-family:
      ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Noto Sans SC", "Microsoft YaHei", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    overflow-x: hidden;
    color: var(--text);
    background:
      radial-gradient(circle at 12% 8%, rgba(255, 217, 138, 0.48), transparent 22rem),
      radial-gradient(circle at 88% 12%, rgba(117, 201, 165, 0.35), transparent 24rem),
      linear-gradient(180deg, #fbfff9 0%, var(--bg) 46%, #f8fbf4 100%);
    letter-spacing: 0;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -2;
    background-image:
      linear-gradient(rgba(117, 201, 165, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(117, 201, 165, 0.08) 1px, transparent 1px);
    background-size: 34px 34px;
    mask-image: linear-gradient(to bottom, black, transparent 78%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a,
  button {
    -webkit-tap-highlight-color: transparent;
  }

  a:focus-visible,
  button:focus-visible {
    outline: 3px solid rgba(47, 143, 112, 0.45);
    outline-offset: 4px;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .ambient {
    position: fixed;
    z-index: -1;
    border-radius: 999px;
    filter: blur(4px);
    opacity: 0.72;
    pointer-events: none;
    animation: float-soft 9s ease-in-out infinite;
  }

  .ambient-one {
    width: 170px;
    height: 170px;
    right: 8vw;
    top: 160px;
    background: rgba(246, 182, 200, 0.2);
  }

  .ambient-two {
    width: 120px;
    height: 120px;
    left: 7vw;
    bottom: 120px;
    background: rgba(117, 201, 165, 0.18);
    animation-delay: -3s;
  }

  .site-header,
  .site-footer,
  main {
    width: min(1120px, calc(100% - 32px));
    margin-inline: auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 24px 0;
    position: relative;
    z-index: 1;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .brand-mark {
    display: grid;
    width: 46px;
    height: 46px;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid rgba(117, 201, 165, 0.38);
    border-radius: 16px;
    background: linear-gradient(145deg, #ffffff, #e6f7ee);
    box-shadow: 0 12px 32px rgba(74, 116, 98, 0.16);
  }

  .brand-mark svg {
    width: 29px;
    height: 29px;
    fill: none;
    stroke: var(--accent-strong);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.1;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand strong {
    font-size: 1rem;
  }

  .brand small {
    margin-top: 3px;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 5px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 250, 0.72);
    box-shadow: 0 14px 38px rgba(74, 116, 98, 0.1);
    backdrop-filter: blur(16px);
  }

  .site-nav a {
    min-height: 38px;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.92rem;
    padding: 9px 14px;
    transition:
      color 180ms ease,
      background 180ms ease,
      transform 180ms ease;
  }

  .site-nav a:hover {
    background: var(--accent-soft);
    color: var(--accent-strong);
    transform: translateY(-1px);
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 80px;
    padding: 28px 0 36px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.9rem;
  }

  .section-kicker {
    margin: 0 0 10px;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .page-title {
    margin: 0;
    max-width: 860px;
    color: var(--text);
    font-size: clamp(2.35rem, 7vw, 5.8rem);
    font-weight: 850;
    line-height: 1.02;
  }

  .page-description {
    max-width: 680px;
    margin: 20px 0 0;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.16rem);
    line-height: 1.85;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 290px;
    gap: 28px;
    align-items: end;
    min-height: 52vh;
    padding: 44px 0 32px;
  }

  .hero-panel {
    border: 1px solid var(--line);
    border-radius: 28px;
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: 20px;
    color: var(--muted);
    backdrop-filter: blur(18px);
  }

  .hero-panel strong {
    display: block;
    color: var(--accent-strong);
    font-size: 2.15rem;
    line-height: 1;
  }

  .hero-panel span {
    display: block;
    margin-top: 10px;
    line-height: 1.6;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .button {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 250, 0.72);
    color: var(--text);
    cursor: pointer;
    font-weight: 750;
    padding: 10px 16px;
    box-shadow: 0 12px 28px rgba(74, 116, 98, 0.1);
    transition:
      transform 180ms ease,
      background 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .button.primary {
    border-color: transparent;
    background: linear-gradient(135deg, #8ddfba, #ffe29d);
    color: #20372f;
  }

  .button:hover {
    transform: translateY(-2px);
    border-color: rgba(117, 201, 165, 0.58);
    box-shadow: 0 16px 34px rgba(74, 116, 98, 0.16);
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 310px;
    gap: 24px;
    align-items: start;
    margin-top: 36px;
  }

  .post-list {
    display: grid;
    gap: 14px;
  }

  .post-card {
    display: block;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    padding: 24px;
    box-shadow: 0 16px 46px rgba(74, 116, 98, 0.12);
    backdrop-filter: blur(18px);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .post-card:hover {
    transform: translateY(-3px);
    border-color: rgba(117, 201, 165, 0.72);
    background: rgba(255, 255, 250, 0.94);
    box-shadow: var(--shadow);
  }

  .post-card h2,
  .post-card h3 {
    margin: 12px 0 10px;
    font-size: clamp(1.35rem, 3vw, 2rem);
    line-height: 1.22;
  }

  .post-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    align-items: center;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    border: 1px solid rgba(117, 201, 165, 0.3);
    border-radius: 999px;
    background: rgba(223, 244, 233, 0.7);
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 750;
    padding: 6px 10px;
  }

  .sidebar-panel {
    border: 1px solid var(--line);
    border-radius: 26px;
    background: var(--surface);
    color: var(--text);
    padding: 20px;
    position: sticky;
    top: 20px;
    box-shadow: 0 16px 46px rgba(74, 116, 98, 0.11);
    backdrop-filter: blur(18px);
  }

  .sidebar-panel h2 {
    margin: 0 0 12px;
    font-size: 1.08rem;
  }

  .sidebar-panel p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .profile-card {
    display: grid;
    gap: 16px;
  }

  .profile-head {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    gap: 14px;
    align-items: center;
  }

  .profile-head h2 {
    margin: 0 0 4px;
  }

  .profile-avatar {
    width: 72px;
    height: 72px;
    border: 1px solid var(--line);
    border-radius: 24px;
    box-shadow: 0 14px 34px rgba(74, 116, 98, 0.14);
  }

  .profile-bio {
    font-size: 0.95rem;
  }

  .profile-location,
  .social-links,
  .social-links a {
    display: flex;
    align-items: center;
  }

  .profile-location {
    gap: 8px;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .social-links {
    flex-wrap: wrap;
    gap: 8px;
  }

  .social-links a {
    min-height: 40px;
    gap: 8px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 250, 0.62);
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 750;
    padding: 8px 12px;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .social-links a:hover {
    transform: translateY(-2px);
    border-color: rgba(117, 201, 165, 0.62);
    background: var(--accent-soft);
  }

  .about-links {
    margin-top: 18px;
  }

  .article {
    max-width: 820px;
    margin: 32px auto 0;
    border: 1px solid var(--line);
    border-radius: 30px;
    background: var(--surface-strong);
    color: var(--text);
    padding: clamp(24px, 5vw, 56px);
    box-shadow: var(--shadow);
  }

  .article-header {
    padding-bottom: 28px;
    border-bottom: 1px solid var(--line);
  }

  .article-title {
    margin: 10px 0 16px;
    color: var(--text);
    font-size: clamp(2rem, 6vw, 4.2rem);
    line-height: 1.08;
  }

  .prose {
    margin-top: 34px;
    font-size: 1.06rem;
    line-height: 1.9;
  }

  .prose h2,
  .prose h3 {
    margin-top: 2.2em;
    line-height: 1.3;
  }

  .prose p,
  .prose ul,
  .prose ol {
    color: #33443e;
  }

  .prose a {
    color: var(--accent-strong);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .prose pre {
    overflow: auto;
    border-radius: 18px;
    padding: 18px;
    background: var(--code-bg);
  }

  .prose code {
    font-family: "JetBrains Mono", "SFMono-Regular", Consolas, monospace;
    font-size: 0.92em;
  }

  .archive-list {
    display: grid;
    gap: 12px;
    margin-top: 36px;
    border: 1px solid var(--line);
    border-radius: 26px;
    background: var(--surface);
    color: var(--text);
    padding: 8px 22px;
    box-shadow: 0 16px 46px rgba(74, 116, 98, 0.11);
    backdrop-filter: blur(18px);
  }

  .archive-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 16px;
    align-items: baseline;
    border-bottom: 1px solid var(--line);
    padding: 16px 0;
  }

  .archive-item time {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .archive-item strong {
    font-size: 1.1rem;
  }

  .archive-item:last-child {
    border-bottom: 0;
  }

  @keyframes float-soft {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }

    50% {
      transform: translate3d(0, -16px, 0) scale(1.04);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
    }
  }

  @media (max-width: 760px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .site-nav {
      width: 100%;
      justify-content: space-between;
      overflow-x: auto;
    }

    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 28px;
    }

    .content-grid {
      grid-template-columns: 1fr;
    }

    .sidebar-panel {
      position: static;
    }

    .site-footer {
      flex-direction: column;
    }

    .archive-item {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }
</style>
