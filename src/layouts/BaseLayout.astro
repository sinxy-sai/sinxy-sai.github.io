---
import { Archive, Home, Moon, Rss, Search, Sun, Tags, User } from "lucide-astro";
import { ClientRouter } from "astro:transitions";
import AmbientFlow from "../components/AmbientFlow.astro";
import CornerPet from "../components/CornerPet.astro";
import FloatingMusicPlayer from "../components/FloatingMusicPlayer.astro";
import "katex/dist/katex.min.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  robots?: string;
  type?: "website" | "article";
  publishedTime?: string;
  tags?: string[];
}

const siteTitle = "Sinxy Sai's Blog";
const {
  title = "首页",
  description = "Personal notes on computer science, algorithms, and building things.",
  image = "/avatar.jpg",
  robots = "index, follow",
  type = "website",
  publishedTime,
  tags = [],
} = Astro.props;

const pageTitle = `${title} | ${siteTitle}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const imageUrl = new URL(image, Astro.site ?? Astro.url).toString();
const rssUrl = "https://sinxy-sai-blog.sinxy-sai.workers.dev/api/rss.xml";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Sinxy Sai" />
    <meta name="robots" content={robots} />
    <meta id="theme-color-meta" name="theme-color" content="#f6fbf5" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="Sinxy Sai's Blog" />
    {
      type === "article" && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href={rssUrl} />
    <title>{pageTitle}</title>
    <ClientRouter />
    <script is:inline>
      (() => {
        try {
          const storedTheme = localStorage.getItem("sinxy-theme");
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const theme = storedTheme === "light" || storedTheme === "dark"
            ? storedTheme
            : prefersDark
              ? "dark"
              : "light";

          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme;
        } catch {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>
  </head>
  <body>
    <AmbientFlow />
    <CornerPet />
    <FloatingMusicPlayer />

    <header class="site-header">
      <a class="brand" href="/" aria-label="返回首页">
        <span class="brand-mark" aria-hidden="true">
          <img src="/favicon.png" alt="" width="52" height="52" />
        </span>
        <span>
          <strong>{siteTitle}</strong>
          <small>notes, code, and tiny discoveries</small>
        </span>
      </a>
      <form class="header-search" role="search">
        <label class="header-search-label" for="site-search-input">搜索文章</label>
        <div class="header-search-field">
          <Search size={18} aria-hidden="true" />
          <input
            id="site-search-input"
            class="header-search-input"
            type="search"
            placeholder="搜索 DCP、维纳滤波..."
            autocomplete="off"
          />
        </div>
        <div id="site-search-panel" class="header-search-panel" hidden>
          <p id="site-search-status" class="header-search-status">输入关键词开始搜索。</p>
          <div id="site-search-results" class="header-search-results" aria-live="polite"></div>
        </div>
      </form>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/">
          <Home size={16} aria-hidden="true" />
          <span>首页</span>
        </a>
        <a href="/archive/">
          <Archive size={16} aria-hidden="true" />
          <span>归档</span>
        </a>
        <a href="/tags/">
          <Tags size={16} aria-hidden="true" />
          <span>标签</span>
        </a>
        <a href="/about/">
          <User size={16} aria-hidden="true" />
          <span>关于</span>
        </a>
        <button
          class="theme-toggle"
          type="button"
          data-theme-toggle
          aria-label="切换到夜间模式"
          aria-pressed="false"
        >
          <Sun class="theme-icon theme-icon-sun" size={16} aria-hidden="true" />
          <Moon class="theme-icon theme-icon-moon" size={16} aria-hidden="true" />
          <span data-theme-toggle-text>夜间</span>
        </button>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span>© {new Date().getFullYear()} Sinxy Sai. Content rights reserved.</span>
      <span class="footer-links">
        <a class="footer-rss" href={rssUrl} aria-label="RSS 订阅">
          <Rss size={16} aria-hidden="true" />
          <span>RSS</span>
        </a>
        <span aria-hidden="true">·</span>
        <a href="https://astro.build/" target="_blank" rel="noreferrer">Built with Astro</a>
      </span>
    </footer>
    <script is:inline data-astro-rerun>
      {
      window.__sinxyBaseLayoutController?.abort();
      window.__sinxyBaseLayoutController = new AbortController();
      const baseLayoutSignal = window.__sinxyBaseLayoutController.signal;

      const themeToggle = document.querySelector("[data-theme-toggle]");
      const themeToggleText = document.querySelector("[data-theme-toggle-text]");
      const themeColorMeta = document.querySelector("#theme-color-meta");

      function setSiteTheme(theme, shouldStore = true) {
        const isDark = theme === "dark";

        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
        if (themeColorMeta) {
          themeColorMeta.setAttribute("content", isDark ? "#101815" : "#f6fbf5");
        }

        if (themeToggle) {
          themeToggle.setAttribute("aria-pressed", String(isDark));
          themeToggle.setAttribute("aria-label", isDark ? "切换到白天模式" : "切换到夜间模式");
        }

        if (themeToggleText) {
          themeToggleText.textContent = isDark ? "白天" : "夜间";
        }

        if (shouldStore) {
          localStorage.setItem("sinxy-theme", theme);
        }
      }

      const initialTheme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
      setSiteTheme(initialTheme, false);

      themeToggle?.addEventListener("click", () => {
        const currentTheme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
        setSiteTheme(currentTheme === "dark" ? "light" : "dark");
      }, { signal: baseLayoutSignal });

      window.addEventListener("storage", (event) => {
        if (event.key !== "sinxy-theme") return;
        if (event.newValue !== "light" && event.newValue !== "dark") return;
        setSiteTheme(event.newValue, false);
      }, { signal: baseLayoutSignal });

      const analyticsPath = `${window.location.pathname}${window.location.search}`;
      const shouldTrackAnalytics = !analyticsPath.startsWith("/admin");
      const analyticsObservers = [];

      function getAnalyticsId(storage, key) {
        try {
          const existing = storage.getItem(key);
          if (existing) return existing;
          const created = `${Date.now().toString(36)}-${Math.random().toString(36).slice(2, 12)}`;
          storage.setItem(key, created);
          return created;
        } catch {
          return "";
        }
      }

      const analyticsVisitorId = shouldTrackAnalytics
        ? getAnalyticsId(localStorage, "sinxy-analytics-visitor")
        : "";
      const analyticsSessionId = shouldTrackAnalytics
        ? getAnalyticsId(sessionStorage, "sinxy-analytics-session")
        : "";

      function sendAnalyticsEvent(payload) {
        if (!shouldTrackAnalytics) return;
        const body = JSON.stringify({
          path: analyticsPath,
          pageTitle: document.title,
          visitorId: analyticsVisitorId,
          sessionId: analyticsSessionId,
          ...payload,
        });

        try {
          const blob = new Blob([body], { type: "application/json" });
          if (navigator.sendBeacon?.("/api/analytics/event", blob)) return;
        } catch {
          // Fall through to fetch.
        }

        fetch("/api/analytics/event", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body,
          keepalive: true,
        }).catch(() => {});
      }

      function observeAnalyticsMetric(type, callback) {
        if (!("PerformanceObserver" in window)) return;
        try {
          const observer = new PerformanceObserver((list) => callback(list.getEntries()));
          observer.observe({ type, buffered: true });
          analyticsObservers.push(observer);
        } catch {
          // Unsupported metric in this browser.
        }
      }

      if (shouldTrackAnalytics) {
        const pageStartedAt = performance.now();
        sendAnalyticsEvent({
          type: "pageview",
          referrer: document.referrer,
        });

        observeAnalyticsMetric("paint", (entries) => {
          entries
            .filter((entry) => entry.name === "first-contentful-paint")
            .forEach((entry) => {
              sendAnalyticsEvent({
                type: "web_vital",
                metricName: "FCP",
                metricValue: Math.round(entry.startTime * 100) / 100,
              });
            });
        });

        let latestLcp = 0;
        observeAnalyticsMetric("largest-contentful-paint", (entries) => {
          const lastEntry = entries.at(-1);
          if (lastEntry) latestLcp = lastEntry.startTime;
        });

        let cls = 0;
        observeAnalyticsMetric("layout-shift", (entries) => {
          entries.forEach((entry) => {
            if (!entry.hadRecentInput) cls += entry.value || 0;
          });
        });

        observeAnalyticsMetric("event", (entries) => {
          const slowest = entries.reduce((max, entry) => Math.max(max, entry.duration || 0), 0);
          if (slowest > 0) {
            sendAnalyticsEvent({
              type: "web_vital",
              metricName: "INP",
              metricValue: Math.round(slowest * 100) / 100,
            });
          }
        });

        window.addEventListener("error", (event) => {
          sendAnalyticsEvent({
            type: "client_error",
            metricName: event.message || "window.error",
          });
        }, { signal: baseLayoutSignal });

        window.addEventListener("unhandledrejection", () => {
          sendAnalyticsEvent({
            type: "client_error",
            metricName: "unhandledrejection",
          });
        }, { signal: baseLayoutSignal });

        window.addEventListener("pagehide", () => {
          const durationMs = Math.round((performance.now() - pageStartedAt) * 100) / 100;
          sendAnalyticsEvent({
            type: "web_vital",
            metricName: "session_duration",
            metricValue: durationMs,
            durationMs,
          });
          if (latestLcp > 0) {
            sendAnalyticsEvent({
              type: "web_vital",
              metricName: "LCP",
              metricValue: Math.round(latestLcp * 100) / 100,
            });
          }
          if (cls > 0) {
            sendAnalyticsEvent({
              type: "web_vital",
              metricName: "CLS",
              metricValue: Math.round(cls * 10000) / 10000,
            });
          }
        }, { signal: baseLayoutSignal });

        baseLayoutSignal.addEventListener("abort", () => {
          analyticsObservers.forEach((observer) => observer.disconnect());
        }, { once: true });
      }

      const siteSearchForm = document.querySelector(".header-search");
      const siteSearchInput = document.querySelector("#site-search-input");
      const siteSearchPanel = document.querySelector("#site-search-panel");
      const siteSearchStatus = document.querySelector("#site-search-status");
      const siteSearchResults = document.querySelector("#site-search-results");

      const escapeSearchHtml = (value) =>
        value.replace(/[&<>"']/g, (char) => ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[char]);

      let siteSearchRequestId = 0;

      function closeSiteSearch() {
        if (siteSearchPanel) siteSearchPanel.hidden = true;
      }
      function renderArticleSearchResult(post) {
        return `
          <a class="header-search-result" href="${post.url}">
            <strong>${escapeSearchHtml(post.title || "Untitled")}</strong>
            <span>${escapeSearchHtml(post.excerpt || post.description || "")}</span>
          </a>
        `;
      }

      async function runArticleSearch(query) {
        const currentRequest = ++siteSearchRequestId;
        const trimmed = query.trim();

        if (!trimmed) {
          closeSiteSearch();
          if (siteSearchResults) siteSearchResults.innerHTML = "";
          return;
        }

        if (siteSearchPanel) siteSearchPanel.hidden = false;
        if (siteSearchStatus) siteSearchStatus.textContent = "正在搜索...";

        try {
          const response = await fetch(`/api/search?q=${encodeURIComponent(trimmed)}`, {
            headers: { accept: "application/json" },
          });
          const payload = response.ok ? await response.json() : { data: [] };
          const results = Array.isArray(payload?.data) ? payload.data : [];

          if (currentRequest !== siteSearchRequestId) return;

          if (siteSearchStatus) {
            siteSearchStatus.textContent = results.length
              ? `找到 ${results.length} 条文章结果`
              : "没有找到匹配的文章";
          }

          if (siteSearchResults) {
            siteSearchResults.innerHTML = results.map(renderArticleSearchResult).join("");
          }
        } catch (error) {
          console.error("Search failed:", error);
          if (currentRequest !== siteSearchRequestId) return;
          if (siteSearchStatus) siteSearchStatus.textContent = "搜索暂时不可用";
          if (siteSearchResults) siteSearchResults.innerHTML = "";
        }
      }

      async function runSiteSearch(query) {
        return runArticleSearch(query);
      }

      siteSearchInput?.addEventListener("input", (event) => {
        runArticleSearch(event.target.value);
      }, { signal: baseLayoutSignal });

      siteSearchForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        const firstResult = siteSearchResults?.querySelector("a");
        if (firstResult instanceof HTMLAnchorElement) {
          window.location.href = firstResult.href;
        }
      }, { signal: baseLayoutSignal });

      document.addEventListener("click", (event) => {
        if (!siteSearchForm?.contains(event.target)) {
          closeSiteSearch();
        }
      }, { signal: baseLayoutSignal });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeSiteSearch();
          siteSearchInput?.blur();
        }
      }, { signal: baseLayoutSignal });

      const siteHeader = document.querySelector(".site-header");
      let lastScrollY = window.scrollY;
      let ticking = false;

      function updateHeaderVisibility() {
        const currentScrollY = window.scrollY;
        const scrollingDown = currentScrollY > lastScrollY;
        const searchIsActive =
          siteSearchInput === document.activeElement ||
          (siteSearchPanel && !siteSearchPanel.hidden);

        if (!siteHeader) {
          ticking = false;
          return;
        }

        siteHeader.classList.toggle("is-floating", currentScrollY > 24 || searchIsActive);

        if (currentScrollY < 80 || searchIsActive || currentScrollY < lastScrollY) {
          siteHeader.classList.remove("is-hidden");
        } else if (scrollingDown) {
          siteHeader.classList.add("is-hidden");
        }

        lastScrollY = Math.max(currentScrollY, 0);
        ticking = false;
      }

      window.addEventListener(
        "scroll",
        () => {
          if (!ticking) {
            window.requestAnimationFrame(updateHeaderVisibility);
            ticking = true;
          }
        },
        { passive: true, signal: baseLayoutSignal },
      );

      const tocLinks = Array.from(document.querySelectorAll(".article-toc a[href^='#']"));
      const tocHeadings = tocLinks
        .map((link) => {
          const id = link.getAttribute("href")?.slice(1);
          return id ? document.getElementById(id) : null;
        })
        .filter(Boolean);
      let activeTocId = "";
      let tocTicking = false;

      function keepActiveTocLinkVisible(link) {
        const toc = link.closest(".article-toc");
        if (!(toc instanceof HTMLElement)) return;

        const linkTop = link.offsetTop;
        const linkBottom = linkTop + link.offsetHeight;
        const visibleTop = toc.scrollTop;
        const visibleBottom = visibleTop + toc.clientHeight;

        if (linkTop < visibleTop) {
          toc.scrollTop = Math.max(0, linkTop - 10);
        } else if (linkBottom > visibleBottom) {
          toc.scrollTop = linkBottom - toc.clientHeight + 10;
        }
      }

      function setActiveToc(id) {
        if (!id || id === activeTocId) return;
        activeTocId = id;

        tocLinks.forEach((link) => {
          const isActive = link.getAttribute("href") === `#${id}`;
          link.classList.toggle("is-active", isActive);
          if (isActive) {
            link.setAttribute("aria-current", "true");
            keepActiveTocLinkVisible(link);
          } else {
            link.removeAttribute("aria-current");
          }
        });
      }

      function updateActiveToc() {
        if (!tocHeadings.length) {
          tocTicking = false;
          return;
        }

        const readingLine = window.innerHeight * 0.32;
        let currentHeading = tocHeadings[0];

        tocHeadings.forEach((heading) => {
          if (heading.getBoundingClientRect().top <= readingLine) {
            currentHeading = heading;
          }
        });

        setActiveToc(currentHeading.id);
        tocTicking = false;
      }

      if (tocHeadings.length) {
        updateActiveToc();
        window.addEventListener(
          "scroll",
          () => {
            if (!tocTicking) {
              window.requestAnimationFrame(updateActiveToc);
              tocTicking = true;
            }
          },
          { passive: true, signal: baseLayoutSignal },
        );
        window.addEventListener("resize", updateActiveToc, { signal: baseLayoutSignal });
      }

      const normalizeUrlPath = (url) => {
        try {
          return new URL(url, window.location.origin).pathname;
        } catch {
          return url;
        }
      };

      const getDateKeyFromIso = (value) => String(value || "").slice(0, 10);
      const formatD1Date = (value) => getDateKeyFromIso(value).replaceAll("-", "/");
      const getPublishSortKey = (value) => String(value || "").replace(" ", "T").slice(0, 19);

      const renderD1PostCard = (post) => `
        <a class="post-card" href="${post.url}" data-d1-post="true" data-pub-date="${getDateKeyFromIso(post.pubDate)}">
          <div class="meta">
            <time datetime="${getDateKeyFromIso(post.pubDate)}">${formatD1Date(post.pubDate)}</time>
            ${post.tags?.length ? `<span>${post.tags.slice(0, 2).map(escapeSearchHtml).join(" / ")}</span>` : ""}
          </div>
          <h2>${escapeSearchHtml(post.title)}</h2>
          <p>${escapeSearchHtml(post.description)}</p>
          ${
            post.tags?.length
              ? `<div class="tag-list">${post.tags.map((tag) => `<span class="tag">${escapeSearchHtml(tag)}</span>`).join("")}</div>`
              : ""
          }
        </a>
      `;

      const renderD1ArchiveItem = (post) => `
        <a class="archive-item" href="${post.url}" data-d1-post="true" data-pub-date="${getDateKeyFromIso(post.pubDate)}">
          <time datetime="${getDateKeyFromIso(post.pubDate)}">${formatD1Date(post.pubDate)}</time>
          <strong>${escapeSearchHtml(post.title)}</strong>
        </a>
      `;

      let d1PostsPromise;

      async function loadD1Posts() {
        if (!d1PostsPromise) {
          d1PostsPromise = fetch("/api/posts", {
            headers: { accept: "application/json" },
          })
            .then((response) => (response.ok ? response.json() : null))
            .then((payload) => (Array.isArray(payload?.data) ? payload.data : []))
            .catch(() => []);
        }

        return d1PostsPromise;
      }

      function getItemTime(item) {
        const rawDate = item.getAttribute("data-pub-date") || item.querySelector("time")?.getAttribute("datetime") || "";
        return getPublishSortKey(rawDate);
      }

      function sortItemsByPublishDate(container, selector) {
        const items = Array.from(container.querySelectorAll(selector));
        items
          .sort((a, b) => getItemTime(b).localeCompare(getItemTime(a)))
          .forEach((item) => container.append(item));
      }

      function insertD1Posts(posts) {
        document.querySelectorAll("[data-d1-post-list]").forEach((container) => {
          const tag = container.getAttribute("data-d1-tag");
          const limit = Number(container.getAttribute("data-d1-limit") || "0");
          const existing = new Set(
            Array.from(container.querySelectorAll("a[href]")).map((link) =>
              normalizeUrlPath(link.getAttribute("href")),
            ),
          );
          const filteredPosts = tag
            ? posts.filter((post) => post.tags?.includes(tag))
            : posts;
          const title = container.querySelector(":scope > .section-kicker");

          for (const post of [...filteredPosts].reverse()) {
            if (existing.has(normalizeUrlPath(post.url))) continue;
            if (title) {
              title.insertAdjacentHTML("afterend", renderD1PostCard(post));
            } else {
              container.insertAdjacentHTML("afterbegin", renderD1PostCard(post));
            }
            existing.add(normalizeUrlPath(post.url));
          }

          sortItemsByPublishDate(container, ".post-card");

          if (limit > 0) {
            Array.from(container.querySelectorAll(".post-card"))
              .slice(limit)
              .forEach((item) => item.remove());
          }
        });

        document.querySelectorAll("[data-d1-archive-list]").forEach((container) => {
          const existing = new Set(
            Array.from(container.querySelectorAll("a[href]")).map((link) =>
              normalizeUrlPath(link.getAttribute("href")),
            ),
          );

          for (const post of [...posts].reverse()) {
            if (existing.has(normalizeUrlPath(post.url))) continue;
            container.insertAdjacentHTML("afterbegin", renderD1ArchiveItem(post));
            existing.add(normalizeUrlPath(post.url));
          }

          sortItemsByPublishDate(container, ".archive-item");
        });
      }

      function insertD1Tags(posts) {
        document.querySelectorAll("[data-d1-tag-list]").forEach((container) => {
          if (container.dataset.d1Enhanced === "true") return;
          container.dataset.d1Enhanced = "true";

          const counts = new Map();

          for (const tag of posts.flatMap((post) => post.tags || [])) {
            counts.set(tag, (counts.get(tag) || 0) + 1);
          }

          for (const [tag, count] of counts) {
            const href = `/tags/${encodeURIComponent(tag)}/`;
            const existing = Array.from(container.querySelectorAll("a[href]")).find(
              (link) => normalizeUrlPath(link.getAttribute("href")) === normalizeUrlPath(href),
            );

            if (existing) {
              const text = existing.textContent || "";
              const match = text.match(/^(.*?)(?:\s*[·]\s*(\d+))?$/);
              const currentCount = Number(match?.[2] || "0");
              existing.textContent = `${tag} · ${currentCount + count}`;
            } else {
              container.insertAdjacentHTML(
                "beforeend",
                `<a class="tag" href="${href}" data-d1-tag="true">${escapeSearchHtml(tag)} · ${count}</a>`,
              );
            }
          }
        });
      }

      function updateHomeSummary(posts) {
        const latestLink = document.querySelector("[data-home-latest]");
        const latestTitle = document.querySelector("[data-home-latest-title]");
        const postCount = document.querySelector("[data-home-post-count] span");
        const tagCount = document.querySelector("[data-home-tag-count] span");

        if (postCount) {
          const staticCount = Number(postCount.closest("[data-static-count]")?.getAttribute("data-static-count") || "0");
          postCount.textContent = String(staticCount + posts.length);
        }

        if (tagCount) {
          const visibleTags = new Set(
            Array.from(document.querySelectorAll("[data-d1-tag-list] a[href]"))
              .map((link) => link.getAttribute("href"))
              .filter(Boolean),
          );
          const staticCount = Number(tagCount.closest("[data-static-count]")?.getAttribute("data-static-count") || "0");
          tagCount.textContent = String(visibleTags.size || staticCount);
        }

        if (latestLink instanceof HTMLAnchorElement && latestTitle && posts.length) {
          const currentTime = getPublishSortKey(latestLink.getAttribute("data-latest-pub-date") || "");
          const latestDynamicPost = [...posts].sort(
            (a, b) => getPublishSortKey(b.pubDate).localeCompare(getPublishSortKey(a.pubDate)),
          )[0];
          const latestDynamicTime = getPublishSortKey(latestDynamicPost.pubDate);

          if (!currentTime || latestDynamicTime > currentTime) {
            latestLink.href = latestDynamicPost.url;
            latestLink.setAttribute("data-latest-pub-date", latestDynamicPost.pubDate);
            latestTitle.textContent = latestDynamicPost.title;
          }
        }
      }

      function enhanceD1Content() {
        loadD1Posts()
          .then((posts) => {
            insertD1Posts(posts);
            insertD1Tags(posts);
            updateHomeSummary(posts);
          })
          .catch(() => {
            // GitHub Pages does not provide the Worker API. Keep the static page unchanged.
          });
      }

      enhanceD1Content();
      document.addEventListener("astro:page-load", enhanceD1Content, { signal: baseLayoutSignal });
      }
    </script>
  </body>
