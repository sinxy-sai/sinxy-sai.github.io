---
import { Rss, Search } from "lucide-astro";
import "katex/dist/katex.min.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  tags?: string[];
}

const siteTitle = "Sinxy Sai's Blog";
const {
  title = "首页",
  description = "Personal notes on computer science, algorithms, and building things.",
  image = "/avatar.jpg",
  type = "website",
  publishedTime,
  tags = [],
} = Astro.props;

const pageTitle = `${title} | ${siteTitle}`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const imageUrl = new URL(image, Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Sinxy Sai" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#f6fbf5" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:alt" content="Sinxy Sai's Blog" />
    {
      type === "article" && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="ambient ambient-one" aria-hidden="true"></div>
    <div class="ambient ambient-two" aria-hidden="true"></div>

    <header class="site-header">
      <a class="brand" href="/" aria-label="返回首页">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 32 32" role="img">
            <path d="M7 19.8c5.7-.7 10.7-4.3 14.9-10.6 2.7 7.8-1.2 14.8-8.3 15.5-2.4.2-4.6-.6-6.6-2.1Z" />
            <path d="M8 22.6c4.2-1.8 7.7-4.5 10.6-8.2" />
          </svg>
        </span>
        <span>
          <strong>{siteTitle}</strong>
          <small>notes, code, and tiny discoveries</small>
        </span>
      </a>
      <form class="header-search" role="search" data-pagefind-ignore>
        <label class="header-search-label" for="site-search-input">搜索文章</label>
        <div class="header-search-field">
          <Search size={18} aria-hidden="true" />
          <input
            id="site-search-input"
            class="header-search-input"
            type="search"
            placeholder="搜索 DCP、维纳滤波..."
            autocomplete="off"
          />
        </div>
        <div id="site-search-panel" class="header-search-panel" hidden>
          <p id="site-search-status" class="header-search-status">输入关键词开始搜索。</p>
          <div id="site-search-results" class="header-search-results" aria-live="polite"></div>
        </div>
      </form>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/">首页</a>
        <a href="/archive/">归档</a>
        <a href="/tags/">标签</a>
        <a href="/about/">关于</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span>© {new Date().getFullYear()} Sinxy Sai. Content rights reserved.</span>
      <span class="footer-links">
        <a class="footer-rss" href="/rss.xml" aria-label="RSS 订阅">
          <Rss size={16} aria-hidden="true" />
          <span>RSS</span>
        </a>
        <span aria-hidden="true">·</span>
        <a href="https://astro.build/" target="_blank" rel="noreferrer">Built with Astro</a>
      </span>
    </footer>
    <script is:inline>
      const siteSearchForm = document.querySelector(".header-search");
      const siteSearchInput = document.querySelector("#site-search-input");
      const siteSearchPanel = document.querySelector("#site-search-panel");
      const siteSearchStatus = document.querySelector("#site-search-status");
      const siteSearchResults = document.querySelector("#site-search-results");

      const escapeSearchHtml = (value) =>
        value.replace(/[&<>"']/g, (char) => ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[char]);

      let sitePagefind;
      let siteSearchRequestId = 0;

      async function loadSitePagefind() {
        if (sitePagefind) return sitePagefind;
        const importPagefind = new Function("path", "return import(path)");
        const loadedPagefind = await importPagefind("/pagefind/pagefind.js");
        sitePagefind = loadedPagefind.createInstance({
          basePath: "/pagefind/",
          noWorker: true,
        });
        await sitePagefind.init();
        return sitePagefind;
      }

      function closeSiteSearch() {
        if (siteSearchPanel) siteSearchPanel.hidden = true;
      }

      async function runSiteSearch(query) {
        const currentRequest = ++siteSearchRequestId;
        const trimmed = query.trim();

        if (!trimmed) {
          closeSiteSearch();
          if (siteSearchResults) siteSearchResults.innerHTML = "";
          return;
        }

        if (siteSearchPanel) siteSearchPanel.hidden = false;
        if (siteSearchStatus) siteSearchStatus.textContent = "正在搜索...";

        try {
          const search = await (await loadSitePagefind()).search(trimmed);
          if (currentRequest !== siteSearchRequestId) return;

          const resultData = await Promise.all(
            search.results.slice(0, 6).map((result) => result.data()),
          );

          if (siteSearchStatus) {
            siteSearchStatus.textContent = resultData.length
              ? `找到 ${search.results.length} 条结果`
              : "没有找到匹配的文章";
          }

          if (siteSearchResults) {
            siteSearchResults.innerHTML = resultData
              .map((item) => `
                <a class="header-search-result" href="${item.url}">
                  <strong>${escapeSearchHtml(item.meta.title || "Untitled")}</strong>
                  <span>${item.excerpt || ""}</span>
                </a>
              `)
              .join("");
          }
        } catch (error) {
          console.error("Pagefind search failed:", error);
          if (siteSearchStatus) siteSearchStatus.textContent = "搜索暂时不可用，请先运行构建。";
          if (siteSearchResults) siteSearchResults.innerHTML = "";
        }
      }

      siteSearchInput?.addEventListener("input", (event) => {
        runSiteSearch(event.target.value);
      });

      siteSearchForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        const firstResult = siteSearchResults?.querySelector("a");
        if (firstResult instanceof HTMLAnchorElement) {
          window.location.href = firstResult.href;
        }
      });

      document.addEventListener("click", (event) => {
        if (!siteSearchForm?.contains(event.target)) {
          closeSiteSearch();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closeSiteSearch();
          siteSearchInput?.blur();
        }
      });

      const siteHeader = document.querySelector(".site-header");
      let lastScrollY = window.scrollY;
      let ticking = false;

      function updateHeaderVisibility() {
        const currentScrollY = window.scrollY;
        const scrollingDown = currentScrollY > lastScrollY;
        const searchIsActive =
          siteSearchInput === document.activeElement ||
          (siteSearchPanel && !siteSearchPanel.hidden);

        if (!siteHeader) {
          ticking = false;
          return;
        }

        siteHeader.classList.toggle("is-floating", currentScrollY > 24 || searchIsActive);

        if (currentScrollY < 80 || searchIsActive || currentScrollY < lastScrollY) {
          siteHeader.classList.remove("is-hidden");
        } else if (scrollingDown) {
          siteHeader.classList.add("is-hidden");
        }

        lastScrollY = Math.max(currentScrollY, 0);
        ticking = false;
      }

      window.addEventListener(
        "scroll",
        () => {
          if (!ticking) {
            window.requestAnimationFrame(updateHeaderVisibility);
            ticking = true;
          }
        },
        { passive: true },
      );
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f6fbf5;
    --bg-soft: #eef8ee;
    --surface: rgba(255, 255, 250, 0.82);
    --surface-strong: #fffef8;
    --text: #22342f;
    --muted: #66756f;
    --line: rgba(113, 148, 137, 0.24);
    --accent: #75c9a5;
    --accent-strong: #2f8f70;
    --accent-soft: #dff4e9;
    --sun: #ffd98a;
    --rose: #f6b6c8;
    --code-bg: #24352f;
    --shadow: 0 22px 70px rgba(74, 116, 98, 0.16);
    --radius: 18px;
    font-family:
      ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Noto Sans SC", "Microsoft YaHei", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    overflow-x: hidden;
    color: var(--text);
    background:
      radial-gradient(circle at 12% 8%, rgba(255, 217, 138, 0.48), transparent 22rem),
      radial-gradient(circle at 88% 12%, rgba(117, 201, 165, 0.35), transparent 24rem),
      linear-gradient(180deg, #fbfff9 0%, var(--bg) 46%, #f8fbf4 100%);
    letter-spacing: 0;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -2;
    background-image:
      linear-gradient(rgba(117, 201, 165, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(117, 201, 165, 0.08) 1px, transparent 1px);
    background-size: 34px 34px;
    mask-image: linear-gradient(to bottom, black, transparent 78%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a,
  button {
    -webkit-tap-highlight-color: transparent;
  }

  a:focus-visible,
  button:focus-visible {
    outline: 3px solid rgba(47, 143, 112, 0.45);
    outline-offset: 4px;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .ambient {
    position: fixed;
    z-index: -1;
    border-radius: 999px;
    filter: blur(4px);
    opacity: 0.72;
    pointer-events: none;
    animation: float-soft 9s ease-in-out infinite;
  }

  .ambient-one {
    width: 170px;
    height: 170px;
    right: 8vw;
    top: 160px;
    background: rgba(246, 182, 200, 0.2);
  }

  .ambient-two {
    width: 120px;
    height: 120px;
    left: 7vw;
    bottom: 120px;
    background: rgba(117, 201, 165, 0.18);
    animation-delay: -3s;
  }

  .site-header,
  .site-footer,
  main {
    width: min(1120px, calc(100% - 32px));
    margin-inline: auto;
  }

  .site-header {
    display: grid;
    grid-template-columns: minmax(220px, 0.92fr) minmax(260px, 1fr) auto;
    align-items: center;
    gap: 18px;
    padding: 24px 0;
    position: sticky;
    top: 10px;
    z-index: 10;
    isolation: isolate;
    transition:
      transform 220ms ease,
      opacity 220ms ease;
    will-change: transform;
  }

  .site-header::before {
    content: "";
    position: absolute;
    inset: 10px -14px;
    z-index: -1;
    border: 1px solid var(--line);
    border-radius: 28px;
    background: rgba(255, 255, 250, 0.96);
    box-shadow: 0 18px 54px rgba(74, 116, 98, 0.16);
    opacity: 0;
    backdrop-filter: blur(18px);
    transition: opacity 180ms ease;
  }

  .site-header.is-floating::before {
    opacity: 1;
  }

  .site-header.is-hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(calc(-100% - 24px));
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .brand-mark {
    display: grid;
    width: 46px;
    height: 46px;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid rgba(117, 201, 165, 0.38);
    border-radius: 16px;
    background: linear-gradient(145deg, #ffffff, #e6f7ee);
    box-shadow: 0 12px 32px rgba(74, 116, 98, 0.16);
  }

  .brand-mark svg {
    width: 29px;
    height: 29px;
    fill: none;
    stroke: var(--accent-strong);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2.1;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand strong {
    font-size: 1rem;
  }

  .brand small {
    margin-top: 3px;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .header-search {
    position: relative;
    min-width: 0;
  }

  .header-search-label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .header-search-field {
    position: relative;
    display: flex;
    align-items: center;
  }

  .header-search-field svg {
    position: absolute;
    left: 14px;
    color: var(--muted);
    pointer-events: none;
  }

  .header-search-input {
    width: 100%;
    min-height: 44px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 250, 0.78);
    color: var(--text);
    font: inherit;
    font-size: 0.92rem;
    padding: 0 16px 0 42px;
    box-shadow: 0 14px 38px rgba(74, 116, 98, 0.1);
    backdrop-filter: blur(16px);
    transition:
      border-color 180ms ease,
      background 180ms ease,
      box-shadow 180ms ease;
  }

  .header-search-input::placeholder {
    color: rgba(102, 117, 111, 0.78);
  }

  .header-search-input:focus {
    border-color: rgba(117, 201, 165, 0.8);
    background: rgba(255, 255, 250, 0.94);
    outline: 3px solid rgba(117, 201, 165, 0.22);
    box-shadow: 0 16px 44px rgba(74, 116, 98, 0.14);
  }

  .header-search-panel {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    left: 0;
    z-index: 30;
    max-height: min(520px, calc(100vh - 120px));
    overflow: auto;
    border: 1px solid var(--line);
    border-radius: 22px;
    background: rgba(255, 255, 250, 0.96);
    padding: 12px;
    box-shadow: var(--shadow);
    backdrop-filter: blur(18px);
  }

  .header-search-status {
    margin: 0 0 8px;
    color: var(--muted);
    font-size: 0.82rem;
  }

  .header-search-results {
    display: grid;
    gap: 8px;
  }

  .header-search-result {
    display: grid;
    gap: 5px;
    border: 1px solid transparent;
    border-radius: 16px;
    padding: 10px;
    transition:
      background 180ms ease,
      border-color 180ms ease;
  }

  .header-search-result:hover {
    border-color: rgba(117, 201, 165, 0.48);
    background: var(--accent-soft);
  }

  .header-search-result strong {
    font-size: 0.92rem;
    line-height: 1.35;
  }

  .header-search-result span {
    display: -webkit-box;
    overflow: hidden;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.55;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 5px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 250, 0.72);
    box-shadow: 0 14px 38px rgba(74, 116, 98, 0.1);
    backdrop-filter: blur(16px);
  }

  .site-nav a {
    min-height: 38px;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.92rem;
    padding: 9px 14px;
    transition:
      color 180ms ease,
      background 180ms ease,
      transform 180ms ease;
  }

  .site-nav a:hover {
    background: var(--accent-soft);
    color: var(--accent-strong);
    transform: translateY(-1px);
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 80px;
    padding: 28px 0 36px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.9rem;
  }

  .footer-links {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .footer-links a {
    color: var(--accent-strong);
    font-weight: 750;
  }

  .footer-rss {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .footer-links a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .section-kicker {
    margin: 0 0 10px;
    color: var(--accent-strong);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .page-title {
    margin: 0;
    max-width: 860px;
    color: var(--text);
    font-size: clamp(2.35rem, 7vw, 5.8rem);
    font-weight: 850;
    line-height: 1.02;
  }

  .page-description {
    max-width: 680px;
    margin: 20px 0 0;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.16rem);
    line-height: 1.85;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 290px;
    gap: 28px;
    align-items: end;
    min-height: 52vh;
    padding: 44px 0 32px;
  }

  .hero-panel {
    border: 1px solid var(--line);
    border-radius: 28px;
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: 20px;
    color: var(--muted);
    backdrop-filter: blur(18px);
  }

  .hero-panel strong {
    display: block;
    color: var(--accent-strong);
    font-size: 2.15rem;
    line-height: 1;
  }

  .hero-panel span {
    display: block;
    margin-top: 10px;
    line-height: 1.6;
  }

  .hero-panel h2 {
    margin: 0;
    font-size: 1.35rem;
  }

  .focus-list {
    display: grid;
    gap: 10px;
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
  }

  .focus-list li {
    position: relative;
    padding-left: 18px;
    color: var(--muted);
    line-height: 1.55;
  }

  .focus-list li::before {
    content: "";
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--accent);
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .button {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 250, 0.72);
    color: var(--text);
    cursor: pointer;
    font-weight: 750;
    padding: 10px 16px;
    box-shadow: 0 12px 28px rgba(74, 116, 98, 0.1);
    transition:
      transform 180ms ease,
      background 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease;
  }

  .button.primary {
    border-color: rgba(47, 143, 112, 0.28);
    background: var(--accent-strong);
    color: #fffef8;
    box-shadow: 0 14px 30px rgba(47, 143, 112, 0.22);
  }

  .button:hover {
    transform: translateY(-2px);
    border-color: rgba(117, 201, 165, 0.58);
    box-shadow: 0 16px 34px rgba(74, 116, 98, 0.16);
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 310px;
    gap: 24px;
    align-items: start;
    margin-top: 36px;
  }

  .post-list {
    display: grid;
    gap: 14px;
  }

  .post-card {
    display: block;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    padding: 24px;
    box-shadow: 0 16px 46px rgba(74, 116, 98, 0.12);
    backdrop-filter: blur(18px);
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .post-card:hover {
    transform: translateY(-3px);
    border-color: rgba(117, 201, 165, 0.72);
    background: rgba(255, 255, 250, 0.94);
    box-shadow: var(--shadow);
  }

  .post-card h2,
  .post-card h3 {
    margin: 12px 0 10px;
    font-size: clamp(1.35rem, 3vw, 2rem);
    line-height: 1.22;
  }

  .post-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    align-items: center;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    border: 1px solid rgba(117, 201, 165, 0.3);
    border-radius: 999px;
    background: rgba(223, 244, 233, 0.7);
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 750;
    padding: 6px 10px;
  }

  .sidebar-panel {
    border: 1px solid var(--line);
    border-radius: 26px;
    background: var(--surface);
    color: var(--text);
    padding: 20px;
    position: sticky;
    top: 20px;
    box-shadow: 0 16px 46px rgba(74, 116, 98, 0.11);
    backdrop-filter: blur(18px);
  }

  .sidebar-panel h2 {
    margin: 0 0 12px;
    font-size: 1.08rem;
  }

  .sidebar-panel p {
    margin: 0;
    color: var(--muted);
