---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Sinxy Sai",
  description = "Personal notes on computer science, algorithms, and building things.",
} = Astro.props;

const pageTitle = title === "Sinxy Sai" ? title : `${title} | Sinxy Sai`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" type="application/rss+xml" title="Sinxy Sai" href="/rss.xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Sinxy Sai homepage">
        <span class="brand-mark">S</span>
        <span>
          <strong>Sinxy Sai</strong>
          <small>Notes and code</small>
        </span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/">首页</a>
        <a href="/archive/">归档</a>
        <a href="/tags/">标签</a>
        <a href="/about/">关于</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span>© {new Date().getFullYear()} sinxy-sai</span>
      <span>Built with Astro</span>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --bg: #f7f3ea;
    --surface: #fffaf0;
    --surface-strong: #ffffff;
    --text: #1d2522;
    --muted: #66736f;
    --line: #ddd3c1;
    --accent: #0f766e;
    --accent-strong: #0b5f59;
    --warm: #b45309;
    --code-bg: #17211f;
    --shadow: 0 18px 60px rgba(50, 43, 28, 0.12);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Noto Sans SC", "Microsoft YaHei", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--text);
    background:
      linear-gradient(180deg, rgba(15, 118, 110, 0.08), transparent 320px),
      var(--bg);
    letter-spacing: 0;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .site-header,
  .site-footer,
  main {
    width: min(1120px, calc(100% - 32px));
    margin-inline: auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 28px 0;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .brand-mark {
    display: grid;
    width: 42px;
    height: 42px;
    flex: 0 0 auto;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface-strong);
    color: var(--accent);
    font-weight: 800;
    box-shadow: 0 10px 28px rgba(15, 118, 110, 0.12);
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand strong {
    font-size: 1rem;
  }

  .brand small {
    margin-top: 2px;
    color: var(--muted);
    font-size: 0.78rem;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 4px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 250, 240, 0.72);
    backdrop-filter: blur(18px);
  }

  .site-nav a {
    border-radius: 6px;
    color: var(--muted);
    font-size: 0.92rem;
    padding: 8px 12px;
  }

  .site-nav a:hover {
    background: var(--surface-strong);
    color: var(--text);
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-top: 72px;
    padding: 28px 0 36px;
    border-top: 1px solid var(--line);
    color: var(--muted);
    font-size: 0.9rem;
  }

  .section-kicker {
    margin: 0 0 10px;
    color: var(--accent);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .page-title {
    margin: 0;
    max-width: 780px;
    font-size: clamp(2.4rem, 7vw, 5.5rem);
    line-height: 0.98;
  }

  .page-description {
    max-width: 680px;
    margin: 20px 0 0;
    color: var(--muted);
    font-size: clamp(1rem, 2vw, 1.18rem);
    line-height: 1.8;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .button {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface-strong);
    color: var(--text);
    font-weight: 700;
    padding: 10px 14px;
  }

  .button.primary {
    border-color: var(--accent);
    background: var(--accent);
    color: white;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 28px;
    align-items: start;
    margin-top: 46px;
  }

  .post-list {
    display: grid;
    gap: 16px;
  }

  .post-card {
    display: block;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 250, 240, 0.78);
    padding: 22px;
    box-shadow: 0 12px 38px rgba(50, 43, 28, 0.08);
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    border-color: rgba(15, 118, 110, 0.45);
    box-shadow: var(--shadow);
  }

  .post-card h2,
  .post-card h3 {
    margin: 10px 0 10px;
    font-size: clamp(1.35rem, 3vw, 2rem);
    line-height: 1.22;
  }

  .post-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 12px;
    align-items: center;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(15, 118, 110, 0.26);
    border-radius: 999px;
    background: rgba(15, 118, 110, 0.08);
    color: var(--accent-strong);
    font-size: 0.82rem;
    font-weight: 700;
    padding: 6px 10px;
  }

  .sidebar-panel {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 250, 240, 0.8);
    padding: 20px;
    position: sticky;
    top: 20px;
  }

  .sidebar-panel h2 {
    margin: 0 0 12px;
    font-size: 1.05rem;
  }

  .sidebar-panel p {
    margin: 0;
    color: var(--muted);
    line-height: 1.7;
  }

  .article {
    max-width: 820px;
    margin: 36px auto 0;
  }

  .article-header {
    padding-bottom: 28px;
    border-bottom: 1px solid var(--line);
  }

  .article-title {
    margin: 10px 0 16px;
    font-size: clamp(2rem, 6vw, 4.3rem);
    line-height: 1.06;
  }

  .prose {
    margin-top: 34px;
    font-size: 1.06rem;
    line-height: 1.9;
  }

  .prose h2,
  .prose h3 {
    margin-top: 2.2em;
    line-height: 1.3;
  }

  .prose p,
  .prose ul,
  .prose ol {
    color: #303a36;
  }

  .prose a {
    color: var(--accent-strong);
    text-decoration: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
  }

  .prose pre {
    overflow: auto;
    border-radius: 8px;
    padding: 18px;
    background: var(--code-bg);
  }

  .prose code {
    font-family: "JetBrains Mono", "SFMono-Regular", Consolas, monospace;
    font-size: 0.92em;
  }

  .archive-list {
    display: grid;
    gap: 12px;
    margin-top: 36px;
  }

  .archive-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 16px;
    align-items: baseline;
    border-bottom: 1px solid var(--line);
    padding: 16px 0;
  }

  .archive-item time {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .archive-item strong {
    font-size: 1.1rem;
  }

  @media (max-width: 760px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .site-nav {
      width: 100%;
      justify-content: space-between;
      overflow-x: auto;
    }

    .content-grid {
      grid-template-columns: 1fr;
    }

    .sidebar-panel {
      position: static;
    }

    .site-footer {
      flex-direction: column;
    }

    .archive-item {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }
</style>
