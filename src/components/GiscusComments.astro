---
const repo = import.meta.env.PUBLIC_GISCUS_REPO || "sinxy-sai/sinxy-sai.github.io";
const repoId = import.meta.env.PUBLIC_GISCUS_REPO_ID || "R_kgDOTKYHfA";
const category = import.meta.env.PUBLIC_GISCUS_CATEGORY || "Announcements";
const categoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID || "DIC_kwDOTKYHfM4DAi8w";
const isEnabled = Boolean(repo && repoId && category && categoryId);
---

<section class="article-comments" id="comments" aria-labelledby="comments-title">
  <div class="article-comments-head">
    <p class="section-kicker">Comments</p>
    <h2 id="comments-title">评论</h2>
  </div>
  {
    isEnabled ? (
      <div
        class="giscus-shell"
        data-giscus-thread
        data-repo={repo}
        data-repo-id={repoId}
        data-category={category}
        data-category-id={categoryId}
      />
    ) : (
      <div class="giscus-empty">
        <strong>评论区尚未配置</strong>
        <span>配置 Giscus 环境变量并重新构建后，这里会显示评论区。</span>
      </div>
    )
  }
</section>

{
  isEnabled && (
    <script is:inline data-astro-rerun>
      const getGiscusTheme = () =>
        document.documentElement.dataset.theme === "dark" ? "dark" : "light";

      const setGiscusTheme = () => {
        document.querySelectorAll("iframe.giscus-frame").forEach((frame) => {
          if (!(frame instanceof HTMLIFrameElement) || !frame.contentWindow) return;

          frame.contentWindow.postMessage(
            {
              giscus: {
                setConfig: {
                  theme: getGiscusTheme(),
                },
              },
            },
            "https://giscus.app",
          );
        });
      };

      const createGiscusScript = (thread) => {
        const script = document.createElement("script");
        script.src = "https://giscus.app/client.js";
        script.async = true;
        script.crossOrigin = "anonymous";
        script.setAttribute("data-repo", thread.dataset.repo || "");
        script.setAttribute("data-repo-id", thread.dataset.repoId || "");
        script.setAttribute("data-category", thread.dataset.category || "");
        script.setAttribute("data-category-id", thread.dataset.categoryId || "");
        script.setAttribute("data-mapping", "pathname");
        script.setAttribute("data-strict", "0");
        script.setAttribute("data-reactions-enabled", "1");
        script.setAttribute("data-emit-metadata", "0");
        script.setAttribute("data-input-position", "bottom");
        script.setAttribute("data-theme", getGiscusTheme());
        script.setAttribute("data-lang", "zh-CN");
        script.setAttribute("data-loading", "lazy");

        return script;
      };

      const initGiscusComments = () => {
        document.querySelectorAll("[data-giscus-thread]").forEach((thread) => {
          if (!(thread instanceof HTMLElement)) return;

          const currentPath = window.location.pathname;
          const hasLoadedThread =
            thread.dataset.loadedPath === currentPath &&
            Boolean(thread.querySelector("iframe.giscus-frame, script[src='https://giscus.app/client.js']"));

          if (hasLoadedThread) return;

          thread.replaceChildren();
          thread.dataset.loadedPath = currentPath;
          thread.append(createGiscusScript(thread));
        });
      };

      initGiscusComments();

      const pageLoadHandlerKey = "__sinxyGiscusPageLoadHandler";
      const oldPageLoadHandler = window[pageLoadHandlerKey];
      if (typeof oldPageLoadHandler === "function") {
        document.removeEventListener("astro:page-load", oldPageLoadHandler);
      }
      window[pageLoadHandlerKey] = initGiscusComments;
      document.addEventListener("astro:page-load", initGiscusComments);

      if (document.documentElement.dataset.giscusThemeObserver !== "true") {
        document.documentElement.dataset.giscusThemeObserver = "true";

        const themeObserver = new MutationObserver(setGiscusTheme);
        themeObserver.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["data-theme"],
        });
      }
    </script>
  )
}

<style>
  .article-comments {
    margin-top: 36px;
    padding-top: 28px;
    border-top: 1px solid var(--line);
  }

  .article-comments-head {
    display: grid;
    gap: 8px;
    margin-bottom: 18px;
  }

  .article-comments-head h2 {
    margin: 0;
    color: var(--text);
    font-size: clamp(1.45rem, 3vw, 2rem);
    line-height: 1.25;
  }

  .giscus-shell {
    min-height: 190px;
  }

  .giscus-empty {
    display: grid;
    gap: 6px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: var(--surface-control);
    padding: 16px 18px;
  }

  .giscus-empty strong {
    color: var(--text);
  }

  .giscus-empty span {
    color: var(--muted);
    line-height: 1.65;
  }
</style>
