<div class="ambient-flow" aria-hidden="true">
  <canvas data-galaxy-background></canvas>
</div>

<script>
  const galaxyVertexShader = `
    attribute vec2 uv;
    attribute vec2 position;
    varying vec2 vUv;

    void main() {
      vUv = uv;
      gl_Position = vec4(position, 0.0, 1.0);
    }
  `;

  const galaxyFragmentShader = `
    precision highp float;

    uniform float uTime;
    uniform vec3 uResolution;
    uniform vec2 uFocal;
    uniform vec2 uRotation;
    uniform float uStarSpeed;
    uniform float uDensity;
    uniform float uHueShift;
    uniform float uSpeed;
    uniform vec2 uMouse;
    uniform float uGlowIntensity;
    uniform float uSaturation;
    uniform bool uMouseRepulsion;
    uniform float uTwinkleIntensity;
    uniform float uRotationSpeed;
    uniform float uRepulsionStrength;
    uniform float uMouseActiveFactor;
    uniform bool uTransparent;

    varying vec2 vUv;

    #define NUM_LAYER 4.0
    #define STAR_COLOR_CUTOFF 0.2
    #define MAT45 mat2(0.7071, -0.7071, 0.7071, 0.7071)
    #define PERIOD 3.0

    float hash21(vec2 p) {
      p = fract(p * vec2(123.34, 456.21));
      p += dot(p, p + 45.32);
      return fract(p.x * p.y);
    }

    float tri(float x) {
      return abs(fract(x) * 2.0 - 1.0);
    }

    float tris(float x) {
      float t = fract(x);
      return 1.0 - smoothstep(0.0, 1.0, abs(2.0 * t - 1.0));
    }

    float trisn(float x) {
      float t = fract(x);
      return 2.0 * (1.0 - smoothstep(0.0, 1.0, abs(2.0 * t - 1.0))) - 1.0;
    }

    vec3 hsv2rgb(vec3 c) {
      vec4 k = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
      vec3 p = abs(fract(c.xxx + k.xyz) * 6.0 - k.www);
      return c.z * mix(k.xxx, clamp(p - k.xxx, 0.0, 1.0), c.y);
    }

    float star(vec2 uv, float flare) {
      float d = max(length(uv), 0.001);
      float value = (0.05 * uGlowIntensity) / d;
      float rays = smoothstep(0.0, 1.0, 1.0 - abs(uv.x * uv.y * 1000.0));
      value += rays * flare * uGlowIntensity;
      uv *= MAT45;
      rays = smoothstep(0.0, 1.0, 1.0 - abs(uv.x * uv.y * 1000.0));
      value += rays * 0.3 * flare * uGlowIntensity;
      value *= smoothstep(1.0, 0.2, d);
      return value;
    }

    vec3 starLayer(vec2 uv) {
      vec3 color = vec3(0.0);
      vec2 grid = fract(uv) - 0.5;
      vec2 id = floor(uv);

      for (int y = -1; y <= 1; y++) {
        for (int x = -1; x <= 1; x++) {
          vec2 offset = vec2(float(x), float(y));
          vec2 cell = id + offset;
          float seed = hash21(cell);
          float size = fract(seed * 345.32);
          float gloss = tri(uStarSpeed / (PERIOD * seed + 1.0));
          float flare = smoothstep(0.9, 1.0, size) * gloss;

          float hue = fract(uHueShift / 360.0 + (seed - 0.5) * 0.12);
          float saturation = mix(0.08, uSaturation, 0.7 + seed * 0.3);
          vec3 base = hsv2rgb(vec3(hue, saturation, 0.94));

          vec2 drift = vec2(
            tris(seed * 34.0 + uTime * uSpeed / 10.0),
            tris(seed * 38.0 + uTime * uSpeed / 30.0)
          ) - 0.5;

          float point = star(grid - offset - drift, flare);
          float twinkle = trisn(uTime * uSpeed + seed * 6.2831) * 0.5 + 1.0;
          point *= mix(1.0, twinkle, uTwinkleIntensity);
          color += point * size * base;
        }
      }

      return color;
    }

    void main() {
      vec2 focalPx = uFocal * uResolution.xy;
      vec2 uv = (vUv * uResolution.xy - focalPx) / uResolution.y;
      vec2 mousePos = (uMouse * uResolution.xy - focalPx) / uResolution.y;

      if (uMouseRepulsion) {
        float mouseDistance = length(uv - mousePos);
        vec2 repulsion = normalize(uv - mousePos) * (uRepulsionStrength / (mouseDistance + 0.1));
        uv += repulsion * 0.05 * uMouseActiveFactor;
      }

      float rotationAngle = uTime * uRotationSpeed;
      mat2 rotation = mat2(cos(rotationAngle), -sin(rotationAngle), sin(rotationAngle), cos(rotationAngle));
      uv = rotation * uv;
      uv = mat2(uRotation.x, -uRotation.y, uRotation.y, uRotation.x) * uv;

      vec3 color = vec3(0.0);
      for (float layer = 0.0; layer < 1.0; layer += 1.0 / NUM_LAYER) {
        float depth = fract(layer + uStarSpeed * uSpeed);
        float scale = mix(20.0 * uDensity, 0.5 * uDensity, depth);
        float fade = depth * smoothstep(1.0, 0.9, depth);
        color += starLayer(uv * scale + layer * 453.32) * fade;
      }

      float alpha = smoothstep(0.0, 0.3, length(color));
      gl_FragColor = uTransparent ? vec4(color, min(alpha, 1.0)) : vec4(color, 1.0);
    }
  `;

  function initGalaxyBackgrounds() {
    document.querySelectorAll("[data-galaxy-background]").forEach((canvas) => {
      if (!(canvas instanceof HTMLCanvasElement) || canvas.dataset.galaxyInitialized === "true") return;
      canvas.dataset.galaxyInitialized = "true";

      const controller = new AbortController();
      const { signal } = controller;
      document.addEventListener("astro:before-swap", () => controller.abort(), { once: true, signal });

      const start = async () => {
        const { Renderer, Program, Mesh, Color, Triangle } = await import("ogl");
        if (signal.aborted || !canvas.isConnected) return;

        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const compactViewport = window.matchMedia("(max-width: 760px)").matches;
        const supportsFinePointer = window.matchMedia("(pointer: fine)").matches;
        const renderer = new Renderer({ canvas, alpha: true, premultipliedAlpha: false });
        const gl = renderer.gl;
        gl.enable(gl.BLEND);
        gl.blendFunc(gl.SRC_ALPHA, gl.ONE_MINUS_SRC_ALPHA);
        gl.clearColor(0, 0, 0, 0);

        const pointer = {
          x: 0.5,
          y: 0.5,
          targetX: 0.5,
          targetY: 0.5,
          active: 0,
          targetActive: 0,
        };
        const program = new Program(gl, {
          vertex: galaxyVertexShader,
          fragment: galaxyFragmentShader,
          uniforms: {
            uTime: { value: 0 },
            uResolution: { value: new Color(1, 1, 1) },
            uFocal: { value: new Float32Array([0.52, 0.42]) },
            uRotation: { value: new Float32Array([1, 0]) },
            uStarSpeed: { value: 0 },
            uDensity: { value: 0.28 },
            uHueShift: { value: 155 },
            uSpeed: { value: 0.5 },
            uMouse: { value: new Float32Array([0.5, 0.5]) },
            uGlowIntensity: { value: 0.042 },
            uSaturation: { value: 0.16 },
            uMouseRepulsion: { value: supportsFinePointer && !reduceMotion },
            uTwinkleIntensity: { value: 0.1 },
            uRotationSpeed: { value: 0.025 },
            uRepulsionStrength: { value: 0.72 },
            uMouseActiveFactor: { value: 0 },
            uTransparent: { value: true },
          },
        });
        const mesh = new Mesh(gl, { geometry: new Triangle(gl), program });
        let animationFrame = 0;
        let lastFrame = 0;
        let isVisible = !document.hidden;

        function applyTheme() {
          const dark = document.documentElement.dataset.theme === "dark";
          program.uniforms.uDensity.value = compactViewport ? (dark ? 0.3 : 0.22) : (dark ? 0.42 : 0.28);
          program.uniforms.uHueShift.value = dark ? 164 : 154;
          program.uniforms.uGlowIntensity.value = dark ? 0.072 : 0.042;
          program.uniforms.uSaturation.value = dark ? 0.22 : 0.16;
        }

        function resize() {
          const dpr = Math.min(window.devicePixelRatio || 1, compactViewport ? 1 : 1.25);
          renderer.setSize(window.innerWidth * dpr, window.innerHeight * dpr);
          canvas.style.width = `${window.innerWidth}px`;
          canvas.style.height = `${window.innerHeight}px`;
          program.uniforms.uResolution.value = new Color(gl.canvas.width, gl.canvas.height, gl.canvas.width / gl.canvas.height);
        }

        function draw(now) {
          if (signal.aborted || !canvas.isConnected || !isVisible) return;
          animationFrame = window.requestAnimationFrame(draw);
          const interval = compactViewport ? 1000 / 30 : 1000 / 45;
          if (now - lastFrame < interval) return;
          lastFrame = now;

          pointer.x += (pointer.targetX - pointer.x) * 0.05;
          pointer.y += (pointer.targetY - pointer.y) * 0.05;
          pointer.active += (pointer.targetActive - pointer.active) * 0.05;
          program.uniforms.uMouse.value[0] = pointer.x;
          program.uniforms.uMouse.value[1] = pointer.y;
          program.uniforms.uMouseActiveFactor.value = pointer.active;
          program.uniforms.uTime.value = reduceMotion ? 0 : now * 0.001;
          program.uniforms.uStarSpeed.value = reduceMotion ? 0 : (now * 0.001 * 0.48) / 10;
          renderer.render({ scene: mesh });
        }

        function resume() {
          isVisible = !document.hidden;
          if (isVisible && !animationFrame && !signal.aborted) animationFrame = window.requestAnimationFrame(draw);
        }

        function updatePointer(event) {
          if (!supportsFinePointer) return;
          pointer.targetX = event.clientX / Math.max(window.innerWidth, 1);
          pointer.targetY = 1 - event.clientY / Math.max(window.innerHeight, 1);
          pointer.targetActive = 1;
        }

        function clearPointer() {
          pointer.targetActive = 0;
        }

        const themeObserver = new MutationObserver(applyTheme);
        themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
        window.addEventListener("resize", resize, { signal });
        window.addEventListener("pointermove", updatePointer, { passive: true, signal });
        window.addEventListener("pointerleave", clearPointer, { signal });
        document.addEventListener("visibilitychange", () => {
          if (document.hidden) {
            isVisible = false;
            window.cancelAnimationFrame(animationFrame);
            animationFrame = 0;
          } else {
            resume();
          }
        }, { signal });
        signal.addEventListener("abort", () => {
          window.cancelAnimationFrame(animationFrame);
          themeObserver.disconnect();
          gl.getExtension("WEBGL_lose_context")?.loseContext();
        }, { once: true });

        applyTheme();
        resize();
        if (reduceMotion) {
          renderer.render({ scene: mesh });
        } else {
          animationFrame = window.requestAnimationFrame(draw);
        }
      };

      if ("requestIdleCallback" in window) {
        const idleId = window.requestIdleCallback(start, { timeout: 700 });
        signal.addEventListener("abort", () => window.cancelIdleCallback(idleId), { once: true });
      } else {
        const timeoutId = window.setTimeout(start, 180);
        signal.addEventListener("abort", () => window.clearTimeout(timeoutId), { once: true });
      }
    });
  }

  initGalaxyBackgrounds();
  document.addEventListener("astro:page-load", initGalaxyBackgrounds);
</script>

<style>
  .ambient-flow {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .ambient-flow canvas {
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0.26;
  }

  :global(html[data-theme="dark"]) .ambient-flow canvas {
    opacity: 0.46;
  }

  @media (max-width: 760px) {
    .ambient-flow canvas {
      opacity: 0.2;
    }

    :global(html[data-theme="dark"]) .ambient-flow canvas {
      opacity: 0.34;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ambient-flow canvas {
      opacity: 0.16;
    }
  }
</style>
