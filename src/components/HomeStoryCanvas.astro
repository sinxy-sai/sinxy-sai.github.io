---
import { WandSparkles } from "lucide-astro";

const {
  latestTitle = "Latest note",
  latestUrl = "/archive/",
  latestPubDate = "",
  postCount = 0,
  tagCount = 0,
} = Astro.props;
---

<section class="story-visual" aria-labelledby="story-title">
  <div class="story-stage">
    <canvas class="story-canvas" data-story-canvas></canvas>
    <div class="story-overlay">
      <h1 id="story-title" class="story-sr-title">Sinxy Sai's Blog</h1>
    </div>
    <div class="story-hint" aria-label="Drag to grow a thought path" role="img">
      <WandSparkles size={21} aria-hidden="true" />
    </div>
  </div>

  <div class="story-actions" aria-label="Homepage actions">
    <a class="story-latest" href={latestUrl} data-home-latest data-latest-pub-date={latestPubDate}>
      <span>Latest</span>
      <strong data-home-latest-title>{latestTitle}</strong>
    </a>
    <a class="story-pill" href="/archive/" data-home-post-count data-static-count={postCount}>
      <span>{postCount}</span>
      <strong>Posts</strong>
    </a>
    <a class="story-pill" href="/tags/" data-home-tag-count data-static-count={tagCount}>
      <span>{tagCount}</span>
      <strong>Topics</strong>
    </a>
  </div>
</section>

<script>
  const canvas = document.querySelector("[data-story-canvas]");

  if (canvas instanceof HTMLCanvasElement) {
    const context = canvas.getContext("2d", { alpha: true });
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (context) {
      const state = {
        width: 0,
        height: 0,
        dpr: 1,
        particles: [],
        outlineSegments: [],
        blooms: [],
        sparks: [],
        pointer: { x: 0, y: 0, active: false, inside: false },
        lastBloomAt: 0,
        startedAt: performance.now(),
      };

      function getWelcomeFontSize() {
        return Math.max(58, Math.min(state.width * 0.18, state.height * 0.28, 122));
      }

      function getTheme() {
        return document.documentElement.dataset.theme === "dark" ? "dark" : "light";
      }

      function createTargets() {
        const textCanvas = document.createElement("canvas");
        const textContext = textCanvas.getContext("2d", { willReadFrequently: true });
        if (!textContext) return [];

        const width = Math.max(360, Math.floor(state.width));
        const height = Math.max(240, Math.floor(state.height));
        textCanvas.width = width;
        textCanvas.height = height;

        const fontSize = getWelcomeFontSize();
        textContext.clearRect(0, 0, width, height);
        textContext.fillStyle = "#ffffff";
        textContext.font = `900 ${fontSize}px Inter, ui-sans-serif, system-ui`;
        textContext.textAlign = "center";
        textContext.textBaseline = "middle";
        textContext.fillText("Welcome", width / 2, height * 0.5);

        const image = textContext.getImageData(0, 0, width, height).data;
        const step = Math.max(6, Math.floor(fontSize / 13));
        const targets = [];

        for (let y = 0; y < height; y += step) {
          for (let x = 0; x < width; x += step) {
            const alpha = image[(y * width + x) * 4 + 3];
            if (alpha > 90 && Math.random() > 0.18) {
              targets.push({ x, y });
            }
          }
        }

        return targets.slice(0, 920);
      }

      function easeOutCubic(value) {
        return 1 - Math.pow(1 - value, 3);
      }

      function clamp01(value) {
        return Math.max(0, Math.min(1, value));
      }

      function createOutlineSegments() {
        const fontSize = getWelcomeFontSize();
        context.save();
        context.font = `900 ${fontSize}px Inter, ui-sans-serif, system-ui`;
        const metrics = context.measureText("Welcome");
        context.restore();

        const textWidth = metrics.width;
        const textHeight = fontSize * 1.08;
        const left = state.width / 2 - textWidth / 2 - fontSize * 0.06;
        const top = state.height * 0.5 - textHeight / 2;
        const columns = 14;
        const rows = 4;
        const gap = Math.max(2, fontSize * 0.012);
        const cellWidth = (textWidth + fontSize * 0.12) / columns;
        const cellHeight = textHeight / rows;
        const segments = [];

        for (let row = 0; row < rows; row += 1) {
          for (let column = 0; column < columns; column += 1) {
            const wave = Math.sin(column * 1.7 + row * 2.4) * 0.16;
            const centerBias = Math.abs(column - (columns - 1) / 2) / columns;
            const scatter = ((column * 7 + row * 11) % 9) / 9;

            segments.push({
              x: left + column * cellWidth - gap,
              y: top + row * cellHeight - gap,
              width: cellWidth + gap * 2,
              height: cellHeight + gap * 2,
              delay: 0.03 + centerBias * 0.28 + row * 0.055 + scatter * 0.22 + wave,
              duration: 0.52 + ((row + column) % 5) * 0.045,
              phase: column * 0.73 + row * 1.91,
              direction: (column + row) % 2 === 0 ? 1 : -1,
            });
          }
        }

        state.outlineSegments = segments;
      }

      function resetParticles() {
        const targets = createTargets();

        state.particles = targets.map((target, index) => ({
          x: state.width / 2 + Math.cos(index * 0.48) * (80 + Math.random() * state.width * 0.42),
          y: state.height / 2 + Math.sin(index * 0.48) * (60 + Math.random() * state.height * 0.38),
          tx: target.x,
          ty: target.y,
          vx: 0,
          vy: 0,
          size: 1.1 + Math.random() * 1.9,
          phase: index * 0.19,
          hue: 185 + Math.random() * 55,
        }));
      }

      function resize() {
        const rect = canvas.getBoundingClientRect();
        state.width = Math.max(1, rect.width);
        state.height = Math.max(1, rect.height);
        state.dpr = Math.min(window.devicePixelRatio || 1, 2);
        canvas.width = Math.floor(state.width * state.dpr);
        canvas.height = Math.floor(state.height * state.dpr);
        context.setTransform(state.dpr, 0, 0, state.dpr, 0, 0);
        resetParticles();
        createOutlineSegments();
      }

      function addBloom(x, y, pressure = 1) {
        const hue = 176 + Math.random() * 62;
        state.blooms.push({
          x,
          y,
          born: performance.now(),
          life: 1800 + Math.random() * 900,
          size: (18 + Math.random() * 28) * pressure,
          hue,
          spin: Math.random() * Math.PI,
        });
      }

      function addSpark(x, y) {
        for (let index = 0; index < 14; index += 1) {
          const angle = (index / 14) * Math.PI * 2;
          const speed = 0.8 + Math.random() * 2.6;
          state.sparks.push({
            x,
            y,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            born: performance.now(),
            life: 620 + Math.random() * 480,
          });
        }
      }

      function drawBackground(theme, elapsed) {
        const bg = context.createRadialGradient(
          state.width * 0.38,
          state.height * 0.34,
          0,
          state.width * 0.5,
          state.height * 0.52,
          Math.max(state.width, state.height) * 0.82,
        );

        if (theme === "dark") {
          bg.addColorStop(0, "rgba(73, 95, 84, 0.34)");
          bg.addColorStop(0.45, "rgba(15, 31, 27, 0.5)");
          bg.addColorStop(1, "rgba(6, 17, 15, 0.04)");
        } else {
          bg.addColorStop(0, "rgba(255, 246, 213, 0.66)");
          bg.addColorStop(0.52, "rgba(218, 241, 236, 0.34)");
          bg.addColorStop(1, "rgba(255, 255, 255, 0.08)");
        }

        context.fillStyle = bg;
        context.fillRect(0, 0, state.width, state.height);

        context.save();
        context.globalAlpha = theme === "dark" ? 0.18 : 0.24;
        context.strokeStyle = theme === "dark" ? "rgba(157, 228, 198, 0.36)" : "rgba(81, 140, 128, 0.28)";
        context.lineWidth = 1;

        for (let index = 0; index < 8; index += 1) {
          const y = state.height * (0.18 + index * 0.09) + Math.sin(elapsed * 0.0007 + index) * 12;
          context.beginPath();
          context.moveTo(state.width * 0.08, y);
          context.bezierCurveTo(
            state.width * 0.32,
            y - 22,
            state.width * 0.62,
            y + 20,
            state.width * 0.92,
            y - 8,
          );
          context.stroke();
        }

        context.restore();
      }

      function updateParticles() {
        const pointer = state.pointer;

        state.particles.forEach((particle) => {
          const arrive = 0.085;
          let ax = (particle.tx - particle.x) * arrive;
          let ay = (particle.ty - particle.y) * arrive;

          if (pointer.inside) {
            const dx = particle.x - pointer.x;
            const dy = particle.y - pointer.y;
            const distance = Math.hypot(dx, dy) || 1;
            const radius = pointer.active ? 170 : 110;

            if (distance < radius) {
              const force = (1 - distance / radius) * (pointer.active ? 1.8 : 0.7);
              ax += (dx / distance) * force;
              ay += (dy / distance) * force;
            }
          }

          particle.vx = (particle.vx + ax) * 0.82;
          particle.vy = (particle.vy + ay) * 0.82;
          particle.x += particle.vx;
          particle.y += particle.vy;
        });
      }

      function drawSegmentedOutline(theme, elapsed) {
        const intro = prefersReducedMotion ? 1 : clamp01((elapsed - 1000) / 2700);
        if (intro <= 0) return;

        context.save();
        context.globalCompositeOperation = "lighter";
        context.font = `900 ${getWelcomeFontSize()}px Inter, ui-sans-serif, system-ui`;
        context.textAlign = "center";
        context.textBaseline = "middle";
        context.lineWidth = theme === "dark" ? 1.35 : 1.9;
        context.strokeStyle = theme === "dark" ? "rgba(213, 249, 240, 0.82)" : "rgba(35, 82, 95, 0.9)";
        context.shadowColor = theme === "dark" ? "rgba(150, 236, 214, 0.42)" : "rgba(62, 135, 148, 0.24)";
        context.shadowBlur = theme === "dark" ? 12 : 5;

        state.outlineSegments.forEach((segment) => {
          const segmentProgress = clamp01((intro - segment.delay) / segment.duration);
          if (segmentProgress <= 0) return;

          const eased = easeOutCubic(segmentProgress);
          const shimmer = 0.86 + Math.sin(elapsed * 0.004 + segment.phase) * 0.14;
          const width = segment.width * eased;
          const x = segment.direction > 0 ? segment.x : segment.x + segment.width - width;

          context.save();
          context.beginPath();
          context.rect(x, segment.y, width, segment.height);
          context.clip();
          context.globalAlpha = (theme === "dark" ? 0.22 : 0.28) * eased * shimmer;
          context.strokeText("Welcome", state.width / 2, state.height * 0.5);
          context.restore();
        });

        context.restore();
      }

      function drawTargetGhosts(theme, elapsed) {
        const intro = prefersReducedMotion ? 1 : clamp01((elapsed - 1200) / 2300);
        if (intro <= 0) return;

        context.save();
        context.globalCompositeOperation = "lighter";

        context.globalAlpha = (theme === "dark" ? 0.16 : 0.12) * easeOutCubic(intro);
        context.fillStyle = theme === "dark" ? "rgba(188, 238, 228, 0.84)" : "rgba(72, 125, 139, 0.58)";
        state.particles.forEach((particle, index) => {
          if (index % 2 !== 0) return;
          context.beginPath();
          context.arc(particle.tx, particle.ty, 0.9, 0, Math.PI * 2);
          context.fill();
        });

        context.restore();
      }

      function drawParticleConnections(theme) {
        context.save();
        context.globalCompositeOperation = "lighter";

        for (let i = 0; i < state.particles.length; i += 4) {
          const a = state.particles[i];
          for (let j = i + 4; j < Math.min(i + 56, state.particles.length); j += 8) {
            const b = state.particles[j];
            const distance = Math.hypot(a.x - b.x, a.y - b.y);

            if (distance < 54) {
              context.globalAlpha = (1 - distance / 54) * (theme === "dark" ? 0.18 : 0.14);
              context.strokeStyle = theme === "dark" ? "rgba(141, 227, 207, 0.85)" : "rgba(74, 132, 145, 0.64)";
              context.lineWidth = 1;
              context.beginPath();
              context.moveTo(a.x, a.y);
              context.lineTo(b.x, b.y);
              context.stroke();
            }
          }
        }

        context.restore();
      }

      function drawParticleDots(theme, elapsed) {
        context.save();
        context.globalCompositeOperation = "lighter";

        state.particles.forEach((particle) => {
          const pulse = 0.7 + Math.sin(elapsed * 0.003 + particle.phase) * 0.3;
          context.globalAlpha = theme === "dark" ? 0.8 : 0.72;
          context.fillStyle = `hsla(${particle.hue}, 76%, ${theme === "dark" ? 72 : 42}%, ${0.62 + pulse * 0.28})`;
          context.beginPath();
          context.arc(particle.x, particle.y, particle.size + pulse * 0.9, 0, Math.PI * 2);
          context.fill();
        });

        context.restore();
      }

      function drawParticles(theme, elapsed) {
        updateParticles();
        drawSegmentedOutline(theme, elapsed);
        drawTargetGhosts(theme, elapsed);
        drawParticleConnections(theme);
        drawParticleDots(theme, elapsed);
      }

      function drawBlooms(now, theme) {
        state.blooms = state.blooms.filter((bloom) => now - bloom.born < bloom.life);
        state.sparks = state.sparks.filter((spark) => now - spark.born < spark.life);

        context.save();
        context.globalCompositeOperation = "lighter";

        state.blooms.forEach((bloom) => {
          const age = Math.max(0, Math.min(1, (now - bloom.born) / bloom.life));
          const grow = Math.sin(Math.min(age, 1) * Math.PI);
          const radius = bloom.size * Math.min(age * 2.8, 1);

          context.save();
          context.translate(bloom.x, bloom.y);
          context.rotate(bloom.spin + age * 0.7);
          context.globalAlpha = (1 - age) * (theme === "dark" ? 0.72 : 0.58);

          for (let petal = 0; petal < 6; petal += 1) {
            context.rotate(Math.PI / 3);
            const petalGradient = context.createRadialGradient(radius * 0.34, 0, 0, radius * 0.62, 0, radius);
            petalGradient.addColorStop(0, `hsla(${bloom.hue}, 88%, 82%, 0.88)`);
            petalGradient.addColorStop(1, `hsla(${bloom.hue + 34}, 76%, 58%, 0)`);
            context.fillStyle = petalGradient;
            context.beginPath();
            context.ellipse(radius * 0.46, 0, radius * 0.5, radius * 0.14 * grow, 0, 0, Math.PI * 2);
            context.fill();
          }

          context.fillStyle = theme === "dark" ? "rgba(255, 230, 164, 0.8)" : "rgba(196, 126, 76, 0.56)";
          context.beginPath();
          context.arc(0, 0, Math.max(1.4, radius * 0.07), 0, Math.PI * 2);
          context.fill();
          context.restore();
        });

        state.sparks.forEach((spark) => {
          const age = Math.max(0, Math.min(1, (now - spark.born) / spark.life));
          spark.x += spark.vx;
          spark.y += spark.vy;
          spark.vx *= 0.98;
          spark.vy *= 0.98;
          context.globalAlpha = 1 - age;
          context.fillStyle = theme === "dark" ? "rgba(184, 229, 255, 0.78)" : "rgba(73, 137, 162, 0.54)";
          context.beginPath();
          context.arc(spark.x, spark.y, 1.5 + (1 - age) * 2.5, 0, Math.PI * 2);
          context.fill();
        });

        context.restore();
      }

      function animate(now) {
        const theme = getTheme();
        const elapsed = now - state.startedAt;

        context.clearRect(0, 0, state.width, state.height);
        drawBackground(theme, elapsed);
        drawParticles(theme, elapsed);
        drawBlooms(now, theme);

        if (!prefersReducedMotion) {
          window.requestAnimationFrame(animate);
        }
      }

      function setPointer(event) {
        const rect = canvas.getBoundingClientRect();
        state.pointer.x = event.clientX - rect.left;
        state.pointer.y = event.clientY - rect.top;
        state.pointer.inside = true;

        if (state.pointer.active) {
          const now = performance.now();
          if (now - state.lastBloomAt > 46) {
            addBloom(state.pointer.x, state.pointer.y, event.pressure || 1);
            state.lastBloomAt = now;
          }
        }
      }

      canvas.addEventListener("pointerdown", (event) => {
        state.pointer.active = true;
        canvas.setPointerCapture(event.pointerId);
        setPointer(event);
        addBloom(state.pointer.x, state.pointer.y, 1.2);
        addSpark(state.pointer.x, state.pointer.y);
      });

      canvas.addEventListener("pointermove", setPointer);

      canvas.addEventListener("pointerup", (event) => {
        state.pointer.active = false;
        setPointer(event);
        addSpark(state.pointer.x, state.pointer.y);
      });

      canvas.addEventListener("pointerleave", () => {
        state.pointer.inside = false;
        state.pointer.active = false;
      });

      new ResizeObserver(resize).observe(canvas);
      resize();
      animate(performance.now());
    }
  }
</script>

<style>
  .story-visual {
    display: grid;
    gap: 18px;
    min-width: 0;
  }

  .story-stage {
    position: relative;
    min-height: clamp(420px, 58vh, 680px);
    overflow: hidden;
    border: 1px solid rgba(117, 201, 165, 0.22);
    border-radius: 34px;
    background:
      radial-gradient(circle at 18% 14%, rgba(255, 228, 156, 0.42), transparent 34%),
      radial-gradient(circle at 80% 24%, rgba(246, 182, 200, 0.24), transparent 30%),
      radial-gradient(circle at 52% 82%, rgba(130, 199, 232, 0.22), transparent 42%),
      rgba(255, 255, 250, 0.68);
    box-shadow: var(--shadow);
    isolation: isolate;
  }

  .story-stage::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.38), transparent 34%),
      linear-gradient(0deg, rgba(255, 255, 250, 0.08), rgba(255, 255, 250, 0));
    pointer-events: none;
  }

  .story-canvas {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    width: 100%;
    height: 100%;
    cursor: crosshair;
    touch-action: none;
  }

  .story-overlay {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
    padding: clamp(22px, 4vw, 38px);
    pointer-events: none;
  }

  .story-sr-title {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .story-hint {
    position: absolute;
    right: clamp(18px, 3vw, 34px);
    bottom: clamp(18px, 3vw, 34px);
    z-index: 2;
    display: grid;
    width: 44px;
    height: 44px;
    place-items: center;
    border: 1px solid rgba(117, 201, 165, 0.28);
    border-radius: 50%;
    background: rgba(255, 255, 250, 0.62);
    color: var(--muted);
    backdrop-filter: blur(16px);
  }

  .story-hint svg {
    width: 21px;
    height: 21px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  .story-actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr) repeat(2, minmax(96px, 0.24fr));
    gap: 12px;
  }

  .story-latest,
  .story-pill {
    display: grid;
    min-height: 82px;
    align-content: center;
    border: 1px solid rgba(117, 201, 165, 0.22);
    border-radius: 20px;
    background: var(--surface);
    padding: 14px 16px;
    box-shadow: 0 16px 38px rgba(74, 116, 98, 0.08);
    transition:
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .story-latest:hover,
  .story-pill:hover {
    border-color: rgba(117, 201, 165, 0.52);
    box-shadow: 0 18px 42px rgba(74, 116, 98, 0.12);
    transform: translateY(-2px);
  }

  .story-latest span,
  .story-pill strong {
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 850;
    text-transform: uppercase;
  }

  .story-latest strong,
  .story-pill span {
    color: var(--text);
    font-size: clamp(1rem, 1.6vw, 1.25rem);
    line-height: 1.3;
  }

  .story-pill span {
    font-size: 2rem;
    font-weight: 950;
    line-height: 1;
  }

  :global(html[data-theme="dark"]) .story-stage {
    border-color: rgba(157, 228, 198, 0.16);
    background:
      radial-gradient(circle at 18% 14%, rgba(244, 201, 112, 0.18), transparent 34%),
      radial-gradient(circle at 80% 24%, rgba(246, 182, 200, 0.12), transparent 30%),
      radial-gradient(circle at 52% 82%, rgba(130, 199, 232, 0.12), transparent 42%),
      rgba(18, 29, 25, 0.7);
  }

  :global(html[data-theme="dark"]) .story-hint {
    background: rgba(24, 35, 31, 0.72);
  }

  @media (max-width: 760px) {
    .story-stage {
      min-height: 420px;
      border-radius: 26px;
    }

    .story-overlay {
      display: grid;
    }

    .story-overlay h1 {
      text-align: left;
    }

    .story-actions {
      grid-template-columns: 1fr;
    }
  }
</style>
