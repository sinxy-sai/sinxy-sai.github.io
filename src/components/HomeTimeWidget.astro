---
import { CalendarDays, ChevronLeft, ChevronRight, RotateCcw } from "lucide-astro";

const { posts = [] } = Astro.props;
const timeWidgetPosts = posts
  .map((post) => {
    const data = post.data ?? post;
    const pubDate = data.pubDate ? String(data.pubDate).slice(0, 10) : "";
    const slug = post.id ?? data.slug;
    const url = data.url ?? (slug ? `/blog/${slug}/` : "");

    if (!data.title || !pubDate || !url) return null;

    return {
      title: data.title,
      description: data.description ?? "",
      date: pubDate,
      url,
    };
  })
  .filter(Boolean);
---

<aside class="time-widget" aria-label="Live clock and calendar">
  <div class="time-widget-head">
    <p class="section-kicker">Now</p>
    <span class="time-zone" data-time-zone>Local time</span>
  </div>

  <div class="clock-stage" aria-hidden="true">
    <div class="clock-aurora"></div>
    <div class="clock-shadow-plane"></div>
    <canvas class="clock-canvas" data-clock-canvas></canvas>
  </div>

  <div class="time-readout">
    <strong data-time-text>--:--</strong>
    <span data-date-text>Loading date</span>
  </div>

  <div class="mini-calendar">
    <div class="calendar-head">
      <span>
        <CalendarDays size={16} aria-hidden="true" />
        <strong data-month-label>Month</strong>
      </span>
      <span data-year-label>Year</span>
    </div>
    <div class="calendar-controls" aria-label="日历切换">
      <button class="calendar-control" type="button" data-prev-month aria-label="上个月">
        <ChevronLeft size={16} aria-hidden="true" />
      </button>
      <button class="calendar-reset" type="button" data-current-month>
        <RotateCcw size={14} aria-hidden="true" />
        <span>今天</span>
      </button>
      <button class="calendar-control" type="button" data-next-month aria-label="下个月">
        <ChevronRight size={16} aria-hidden="true" />
      </button>
    </div>
    <div class="weekday-row" aria-hidden="true">
      <span>一</span>
      <span>二</span>
      <span>三</span>
      <span>四</span>
      <span>五</span>
      <span>六</span>
      <span>日</span>
    </div>
    <div class="calendar-grid" data-calendar-grid role="list"></div>
  </div>

  <section class="today-posts" aria-label="今日发布文章">
    <div class="today-posts-head">
      <strong data-selected-date-title>今日发布</strong>
      <span data-today-count>0</span>
    </div>
    <div class="today-post-list" data-today-post-list></div>
    <p class="today-post-empty" data-today-post-empty>今天没有新文章。</p>
  </section>

  <script type="application/json" data-time-widget-posts set:html={JSON.stringify(timeWidgetPosts)} />
</aside>

<script>
  import * as THREE from "three";

  function configureCanvasTexture(texture) {
    texture.colorSpace = THREE.SRGBColorSpace;
    texture.generateMipmaps = false;
    texture.minFilter = THREE.LinearFilter;
    texture.magFilter = THREE.LinearFilter;
    return texture;
  }

  function createClockLabel(text) {
    const textureCanvas = document.createElement("canvas");
    const size = 128;
    textureCanvas.width = size;
    textureCanvas.height = size;

    const context = textureCanvas.getContext("2d");
    if (!context) return null;

    context.clearRect(0, 0, size, size);
    context.fillStyle = "rgba(48, 65, 83, 0.88)";
    context.font = "700 40px Inter, ui-sans-serif, system-ui";
    context.textAlign = "center";
    context.textBaseline = "middle";
    context.fillText(text, size / 2, size / 2);

    const texture = configureCanvasTexture(new THREE.CanvasTexture(textureCanvas));

    const material = new THREE.SpriteMaterial({
      map: texture,
      transparent: true,
      opacity: 0.82,
      depthWrite: false,
    });

    return new THREE.Sprite(material);
  }

  function createThreeClock(canvas) {
    let renderer;
    const MAX_RENDER_PIXELS = 1200 * 1200;

    try {
      renderer = new THREE.WebGLRenderer({
        canvas,
        alpha: true,
        antialias: false,
        powerPreference: "high-performance",
      });
    } catch {
      canvas.closest(".clock-stage")?.classList.add("is-three-unavailable");
      return null;
    }

    renderer.setClearColor(0x000000, 0);
    renderer.setPixelRatio(1);
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.12;

    const gl = renderer.getContext();
    const maxRenderbufferSize = gl.getParameter(gl.MAX_RENDERBUFFER_SIZE) || 4096;

    const scene = new THREE.Scene();
    const camera = new THREE.OrthographicCamera(-1.75, 1.75, 1.75, -1.75, 0.1, 20);
    camera.position.set(0, 0, 6);

    const root = new THREE.Group();
    const face = new THREE.Group();
    root.add(face);
    scene.add(root);

    const glassMaterial = new THREE.MeshPhysicalMaterial({
      color: 0xf9fdff,
      roughness: 0.04,
      metalness: 0,
      transmission: 0.52,
      thickness: 0.72,
      ior: 1.48,
      transparent: true,
      opacity: 0.48,
      clearcoat: 1,
      clearcoatRoughness: 0.04,
      depthWrite: false,
      side: THREE.DoubleSide,
    });

    const rimMaterial = new THREE.MeshPhysicalMaterial({
      color: 0xdff8ff,
      roughness: 0.12,
      metalness: 0.06,
      transparent: true,
      opacity: 0.74,
      clearcoat: 1,
      clearcoatRoughness: 0.08,
    });

    const accentMaterial = new THREE.MeshPhysicalMaterial({
      color: 0x7fc5e8,
      roughness: 0.22,
      metalness: 0.2,
      transparent: true,
      opacity: 0.92,
      clearcoat: 0.8,
      clearcoatRoughness: 0.18,
    });

    const roseMaterial = new THREE.MeshPhysicalMaterial({
      color: 0xf4a8bb,
      roughness: 0.2,
      metalness: 0.18,
      transparent: true,
      opacity: 0.9,
      clearcoat: 0.8,
    });

    const inkMaterial = new THREE.MeshPhysicalMaterial({
      color: 0x304153,
      roughness: 0.34,
      metalness: 0.12,
      clearcoat: 0.35,
    });

    const tickMaterial = new THREE.MeshBasicMaterial({
      color: 0x486176,
      transparent: true,
      opacity: 0.42,
    });

    const majorTickMaterial = new THREE.MeshBasicMaterial({
      color: 0x304153,
      transparent: true,
      opacity: 0.74,
    });

    const causticMaterials = [
      new THREE.MeshBasicMaterial({
        color: 0x9fd7ff,
        transparent: true,
        opacity: 0.18,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
      }),
      new THREE.MeshBasicMaterial({
        color: 0xf7a8bb,
        transparent: true,
        opacity: 0.12,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
      }),
      new THREE.MeshBasicMaterial({
        color: 0xf8d48a,
        transparent: true,
        opacity: 0.1,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
      }),
    ];

    const beadMaterials = [
      new THREE.MeshBasicMaterial({
        color: 0x9fd7ff,
        transparent: true,
        opacity: 0.34,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
      }),
      new THREE.MeshBasicMaterial({
        color: 0xf7a8bb,
        transparent: true,
        opacity: 0.24,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
      }),
    ];

    const meteorTextureCanvas = document.createElement("canvas");
    meteorTextureCanvas.width = 512;
    meteorTextureCanvas.height = 96;
    const meteorTextureContext = meteorTextureCanvas.getContext("2d");

    if (meteorTextureContext) {
      const tail = meteorTextureContext.createLinearGradient(0, 48, 512, 48);
      tail.addColorStop(0, "rgba(255, 255, 255, 0)");
      tail.addColorStop(0.42, "rgba(180, 226, 255, 0.12)");
      tail.addColorStop(0.72, "rgba(236, 246, 255, 0.54)");
      tail.addColorStop(0.9, "rgba(255, 255, 255, 0.92)");
      tail.addColorStop(1, "rgba(255, 255, 255, 0)");
      meteorTextureContext.fillStyle = tail;
      meteorTextureContext.beginPath();
      meteorTextureContext.ellipse(260, 48, 236, 20, 0, 0, Math.PI * 2);
      meteorTextureContext.fill();

      const head = meteorTextureContext.createRadialGradient(438, 48, 0, 438, 48, 58);
      head.addColorStop(0, "rgba(255, 255, 255, 1)");
      head.addColorStop(0.32, "rgba(190, 231, 255, 0.82)");
      head.addColorStop(1, "rgba(190, 231, 255, 0)");
      meteorTextureContext.fillStyle = head;
      meteorTextureContext.beginPath();
      meteorTextureContext.arc(438, 48, 58, 0, Math.PI * 2);
      meteorTextureContext.fill();
    }

    const meteorTexture = configureCanvasTexture(new THREE.CanvasTexture(meteorTextureCanvas));
    const meteorColors = [0xb8e7ff, 0xf6b8cc, 0xf8d996, 0xd7c6ff];

    const nightVeilCanvas = document.createElement("canvas");
    nightVeilCanvas.width = 512;
    nightVeilCanvas.height = 512;
    const nightVeilContext = nightVeilCanvas.getContext("2d");

    if (nightVeilContext) {
      const veil = nightVeilContext.createRadialGradient(224, 172, 0, 256, 256, 286);
      veil.addColorStop(0, "rgba(176, 216, 255, 0.18)");
      veil.addColorStop(0.34, "rgba(28, 48, 72, 0.34)");
      veil.addColorStop(0.72, "rgba(9, 20, 34, 0.24)");
      veil.addColorStop(1, "rgba(9, 20, 34, 0)");
      nightVeilContext.fillStyle = veil;
      nightVeilContext.fillRect(0, 0, 512, 512);

      const moonGlow = nightVeilContext.createRadialGradient(172, 112, 0, 172, 112, 138);
      moonGlow.addColorStop(0, "rgba(230, 247, 255, 0.22)");
      moonGlow.addColorStop(0.42, "rgba(160, 210, 255, 0.1)");
      moonGlow.addColorStop(1, "rgba(160, 210, 255, 0)");
      nightVeilContext.fillStyle = moonGlow;
      nightVeilContext.fillRect(0, 0, 512, 512);
    }

    const nightVeilTexture = configureCanvasTexture(new THREE.CanvasTexture(nightVeilCanvas));

    const glassDisc = new THREE.Mesh(
      new THREE.CylinderGeometry(1.18, 1.24, 0.16, 128, 1, false),
      glassMaterial,
    );
    glassDisc.rotation.x = Math.PI / 2;
    glassDisc.position.z = 0;
    face.add(glassDisc);

    const outerRim = new THREE.Mesh(new THREE.TorusGeometry(1.25, 0.035, 18, 160), rimMaterial);
    outerRim.position.z = 0.12;
    face.add(outerRim);

    const innerRim = new THREE.Mesh(new THREE.TorusGeometry(0.88, 0.01, 12, 128), rimMaterial);
    innerRim.position.z = 0.18;
    innerRim.material.opacity = 0.34;
    face.add(innerRim);

    const progressRing = new THREE.Mesh(
      new THREE.TorusGeometry(1.08, 0.012, 10, 128),
      accentMaterial,
    );
    progressRing.position.z = 0.2;
    face.add(progressRing);

    const causticRings = [
      { radius: 0.68, tube: 0.006, scaleY: 0.56, rotation: -0.5, z: 0.32 },
      { radius: 0.92, tube: 0.005, scaleY: 0.7, rotation: 0.84, z: 0.34 },
      { radius: 1.12, tube: 0.004, scaleY: 0.82, rotation: -1.1, z: 0.3 },
    ].map((config, index) => {
      const ring = new THREE.Mesh(
        new THREE.TorusGeometry(config.radius, config.tube, 8, 160),
        causticMaterials[index],
      );

      ring.scale.y = config.scaleY;
      ring.rotation.z = config.rotation;
      ring.position.z = config.z;
      ring.userData.speed = index % 2 === 0 ? 0.00018 : -0.00014;
      face.add(ring);
      return ring;
    });

    const beadGroup = new THREE.Group();
    const beadGeometry = new THREE.SphereGeometry(0.012, 10, 8);

    for (let index = 0; index < 44; index += 1) {
      const angle = (index / 44) * Math.PI * 2;
      const radius = index % 4 === 0 ? 1.34 : 1.29;
      const bead = new THREE.Mesh(beadGeometry, beadMaterials[index % beadMaterials.length]);

      bead.position.set(Math.sin(angle) * radius, Math.cos(angle) * radius, 0.18 + (index % 3) * 0.018);
      bead.scale.setScalar(index % 5 === 0 ? 1.7 : 1);
      bead.userData.phase = index * 0.41;
      beadGroup.add(bead);
    }

    face.add(beadGroup);

    const nightVeil = new THREE.Mesh(
      new THREE.PlaneGeometry(2.55, 2.55),
      new THREE.MeshBasicMaterial({
        map: nightVeilTexture,
        transparent: true,
        opacity: 0,
        depthWrite: false,
      }),
    );
    nightVeil.position.z = 0.46;
    face.add(nightVeil);

    const constellationCount = 110;
    const constellationPositions = new Float32Array(constellationCount * 3);
    const constellationData = [];

    for (let index = 0; index < constellationCount; index += 1) {
      const targetAngle = Math.random() * Math.PI * 2;
      const targetRadius = 0.42 + Math.random() * 0.9;
      const startAngle = targetAngle - 0.9 + Math.random() * 1.8;
      const startRadius = 1.42 + Math.random() * 0.72;
      const targetX = Math.sin(targetAngle) * targetRadius;
      const targetY = Math.cos(targetAngle) * targetRadius;
      const startX = Math.sin(startAngle) * startRadius;
      const startY = Math.cos(startAngle) * startRadius;

      constellationData.push({
        startX,
        startY,
        targetX,
        targetY,
        z: 0.52 + Math.random() * 0.16,
        phase: Math.random() * Math.PI * 2,
        drift: 0.006 + Math.random() * 0.014,
      });

      constellationPositions[index * 3] = startX;
      constellationPositions[index * 3 + 1] = startY;
      constellationPositions[index * 3 + 2] = 0.52;
    }

    const constellationGeometry = new THREE.BufferGeometry();
    constellationGeometry.setAttribute("position", new THREE.BufferAttribute(constellationPositions, 3));

    const constellationMaterial = new THREE.PointsMaterial({
      color: 0xc9ecff,
      size: 0.026,
      transparent: true,
      opacity: 0,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
      sizeAttenuation: true,
    });

    const constellation = new THREE.Points(constellationGeometry, constellationMaterial);
    face.add(constellation);

    const meteorGroup = new THREE.Group();

    for (let index = 0; index < 24; index += 1) {
      const material = new THREE.SpriteMaterial({
        map: meteorTexture,
        color: meteorColors[index % meteorColors.length],
        transparent: true,
        opacity: 0,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
      });
      const meteor = new THREE.Sprite(material);

      meteor.position.z = 0.66 + Math.random() * 0.16;
      meteor.scale.set(0.42 + Math.random() * 0.4, 0.052 + Math.random() * 0.04, 1);
      meteor.userData.arcStart = -2.45 + Math.random() * 2.1;
      meteor.userData.arcSpan = 0.54 + Math.random() * 0.48;
      meteor.userData.radius = 0.92 + Math.random() * 0.5;
      meteor.userData.offsetX = -0.08 + Math.random() * 0.16;
      meteor.userData.offsetY = -0.08 + Math.random() * 0.16;
      meteor.userData.delay = index * 42 + Math.random() * 240;
      meteor.userData.duration = 720 + Math.random() * 520;
      meteor.userData.baseOpacity = 0.42 + Math.random() * 0.44;
      meteor.userData.rotation = -0.74 + Math.random() * 0.32;
      meteor.visible = false;
      meteorGroup.add(meteor);
    }

    face.add(meteorGroup);

    const tickGeometry = new THREE.BoxGeometry(0.012, 0.065, 0.012);
    const majorTickGeometry = new THREE.BoxGeometry(0.02, 0.12, 0.018);

    for (let index = 0; index < 60; index += 1) {
      const isMajor = index % 5 === 0;
      const angle = (index / 60) * Math.PI * 2;
      const tick = new THREE.Mesh(
        isMajor ? majorTickGeometry : tickGeometry,
        isMajor ? majorTickMaterial : tickMaterial,
      );

      tick.position.set(Math.sin(angle) * 1.04, Math.cos(angle) * 1.04, 0.24);
      tick.rotation.z = -angle;
      face.add(tick);
    }

    [
      ["12", 0],
      ["3", 15],
      ["6", 30],
      ["9", 45],
    ].forEach(([label, index]) => {
      const numeral = createClockLabel(label);
      if (!numeral) return;

      const angle = (Number(index) / 60) * Math.PI * 2;
      numeral.position.set(Math.sin(angle) * 0.76, Math.cos(angle) * 0.76, 0.27);
      numeral.scale.set(0.48, 0.48, 0.48);
      face.add(numeral);
    });

    function createHand(length, width, material, z) {
      const handGroup = new THREE.Group();
      const hand = new THREE.Mesh(new THREE.BoxGeometry(width, length, width), material);
      hand.position.y = length / 2;
      hand.position.z = z;
      handGroup.add(hand);
      face.add(handGroup);
      return handGroup;
    }

    const hourHand = createHand(0.52, 0.055, inkMaterial, 0.35);
    const minuteHand = createHand(0.78, 0.035, accentMaterial, 0.39);
    const secondHand = createHand(0.92, 0.014, roseMaterial, 0.43);

    const core = new THREE.Mesh(
      new THREE.SphereGeometry(0.075, 32, 16),
      new THREE.MeshPhysicalMaterial({
        color: 0xffffff,
        roughness: 0.06,
        metalness: 0,
        transmission: 0.4,
        thickness: 0.28,
        transparent: true,
        opacity: 0.84,
        clearcoat: 1,
      }),
    );
    core.position.z = 0.52;
    face.add(core);

    const glareTextureCanvas = document.createElement("canvas");
    glareTextureCanvas.width = 256;
    glareTextureCanvas.height = 256;
    const glareContext = glareTextureCanvas.getContext("2d");
    if (glareContext) {
      const gradient = glareContext.createLinearGradient(30, 10, 218, 190);
      gradient.addColorStop(0, "rgba(255,255,255,0.82)");
      gradient.addColorStop(0.28, "rgba(255,255,255,0.24)");
      gradient.addColorStop(1, "rgba(255,255,255,0)");
      glareContext.fillStyle = gradient;
      glareContext.beginPath();
      glareContext.ellipse(118, 82, 112, 40, -0.36, 0, Math.PI * 2);
      glareContext.fill();
    }

    const glareTexture = configureCanvasTexture(new THREE.CanvasTexture(glareTextureCanvas));
    const glare = new THREE.Mesh(
      new THREE.PlaneGeometry(1.5, 1),
      new THREE.MeshBasicMaterial({
        map: glareTexture,
        transparent: true,
        opacity: 0.66,
        depthWrite: false,
        blending: THREE.AdditiveBlending,
      }),
    );
    glare.position.set(-0.12, 0.32, 0.5);
    glare.rotation.z = -0.18;
    face.add(glare);

    scene.add(new THREE.HemisphereLight(0xffffff, 0xb5c8d8, 2.15));

    const keyLight = new THREE.DirectionalLight(0xffffff, 3.4);
    keyLight.position.set(-2.4, 3.2, 4.8);
    scene.add(keyLight);

    const rimLight = new THREE.PointLight(0xb4d7ff, 5.4, 8);
    rimLight.position.set(2.2, -1.8, 3.4);
    scene.add(rimLight);

    const warmLight = new THREE.PointLight(0xffd38d, 2.8, 7);
    warmLight.position.set(-2.2, -2, 2.8);
    scene.add(warmLight);

    const cursorLight = new THREE.PointLight(0xffffff, 2.6, 5.6);
    cursorLight.position.set(-0.9, 0.9, 2.8);
    scene.add(cursorLight);

    let targetTiltX = 0;
    let targetTiltY = 0;
    const targetLightPosition = new THREE.Vector3(-0.9, 0.9, 2.8);
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let darkTarget = document.documentElement.dataset.theme === "dark" ? 1 : 0;
    let darkBlend = darkTarget;
    let lastThemeIsDark = Boolean(darkTarget);
    let meteorBurstStart = -Infinity;
    let meteorBurstDirection = darkTarget ? 1 : -1;

    function resize() {
      const rect = canvas.getBoundingClientRect();
      if (rect.width < 1 || rect.height < 1) return;

      const width = Math.max(1, Math.min(720, Math.floor(rect.width)));
      const height = Math.max(1, Math.min(720, Math.floor(rect.height)));
      const pixelRatio = Math.max(
        0.75,
        Math.min(
          window.devicePixelRatio || 1,
          1.25,
          maxRenderbufferSize / width,
          maxRenderbufferSize / height,
          Math.sqrt(MAX_RENDER_PIXELS / Math.max(1, width * height)),
        ),
      );

      try {
        renderer.setPixelRatio(pixelRatio);
        renderer.setSize(width, height, false);
      } catch (error) {
        console.warn("3D clock disabled after resize failure.", error);
        canvas.closest(".clock-stage")?.classList.add("is-three-unavailable");
        return;
      }

      const aspect = width / height;
      const frustum = 3.16;
      camera.left = (-frustum * aspect) / 2;
      camera.right = (frustum * aspect) / 2;
      camera.top = frustum / 2;
      camera.bottom = -frustum / 2;
      camera.updateProjectionMatrix();
    }

    const resizeObserver = new ResizeObserver(resize);
    resizeObserver.observe(canvas);
    resize();

    function applyTheme(shouldAnimate = false) {
      const isDark = document.documentElement.dataset.theme === "dark";
      if (shouldAnimate && isDark !== lastThemeIsDark && !reducedMotion) {
        meteorBurstStart = performance.now();
        meteorBurstDirection = isDark ? 1 : -1;
      }

      lastThemeIsDark = isDark;
      darkTarget = isDark ? 1 : 0;
      glassMaterial.color.set(isDark ? 0xddeef8 : 0xf9fdff);
      rimMaterial.color.set(isDark ? 0xbfe7f6 : 0xdff8ff);
      accentMaterial.color.set(isDark ? 0x80d0f0 : 0x7fc5e8);
      roseMaterial.color.set(isDark ? 0xf0a7bb : 0xf4a8bb);
      inkMaterial.color.set(isDark ? 0xe9f4f0 : 0x304153);
      tickMaterial.color.set(isDark ? 0xd3e4ee : 0x486176);
      majorTickMaterial.color.set(isDark ? 0xf1f8f4 : 0x304153);
      cursorLight.color.set(isDark ? 0xbfe7ff : 0xffffff);
    }

    applyTheme();
    new MutationObserver(() => applyTheme(true)).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });

    return {
      setTilt(rotateX, rotateY, pointerX = 0.18, pointerY = 0.18) {
        targetTiltX = THREE.MathUtils.degToRad(rotateX);
        targetTiltY = THREE.MathUtils.degToRad(rotateY);
        targetLightPosition.set((pointerX - 0.5) * 3.2, (0.5 - pointerY) * 3.2, 2.8);
      },
      update(now, smoothHours, smoothMinutes, smoothSeconds) {
        const elapsed = now.getTime();
        darkBlend += (darkTarget - darkBlend) * 0.055;
        const burstAge = performance.now() - meteorBurstStart;
        const burstProgress = Math.max(0, Math.min(1, burstAge / 1500));
        const burstPresence = burstAge >= 0 && burstAge < 1500
          ? Math.sin(burstProgress * Math.PI)
          : 0;
        const starPresence = THREE.MathUtils.clamp(darkBlend * 1.35 + burstPresence * 0.86, 0, 1.35);
        const starStrength = THREE.MathUtils.clamp(starPresence, 0, 1);
        const nightReveal = THREE.MathUtils.clamp(
          meteorBurstDirection === 1 && burstAge >= 0 && burstAge < 1500
            ? Math.max(darkBlend, burstProgress)
            : darkBlend,
          0,
          1,
        );

        hourHand.rotation.z = -THREE.MathUtils.degToRad(smoothHours * 30);
        minuteHand.rotation.z = -THREE.MathUtils.degToRad(smoothMinutes * 6);
        secondHand.rotation.z = -THREE.MathUtils.degToRad(smoothSeconds * 6);
        cursorLight.position.lerp(targetLightPosition, 0.08);
        glassMaterial.opacity = THREE.MathUtils.lerp(0.48, 0.28, darkBlend);
        rimMaterial.opacity = THREE.MathUtils.lerp(0.74, 0.46, darkBlend);
        tickMaterial.opacity = THREE.MathUtils.lerp(0.42, 0.36, darkBlend);
        majorTickMaterial.opacity = THREE.MathUtils.lerp(0.74, 0.66, darkBlend);
        cursorLight.intensity = THREE.MathUtils.lerp(2.6, 3.2, darkBlend) + burstPresence * 0.9;
        causticMaterials[0].opacity = THREE.MathUtils.lerp(0.18, 0.22, starStrength);
        causticMaterials[1].opacity = THREE.MathUtils.lerp(0.12, 0.16, starStrength);
        causticMaterials[2].opacity = THREE.MathUtils.lerp(0.1, 0.14, starStrength);
        beadMaterials[0].opacity = THREE.MathUtils.lerp(0.26, 0.92, starStrength);
        beadMaterials[1].opacity = THREE.MathUtils.lerp(0.18, 0.72, starStrength);
        nightVeil.material.opacity = THREE.MathUtils.lerp(0, 0.72, nightReveal) + burstPresence * 0.1;
        constellationMaterial.opacity = THREE.MathUtils.lerp(0, 0.86, starStrength);
        constellationMaterial.size = THREE.MathUtils.lerp(0.014, 0.032, starStrength);

        if (!reducedMotion) {
          root.rotation.x += (targetTiltX - root.rotation.x) * 0.08;
          root.rotation.y += (targetTiltY - root.rotation.y) * 0.08;
          face.rotation.z = Math.sin(elapsed * 0.00035) * 0.012;
          glare.rotation.z = -0.18 + Math.sin(elapsed * 0.0006) * 0.025;
          progressRing.rotation.z = -Math.PI / 2 + ((now.getHours() * 60 + now.getMinutes()) / 1440) * Math.PI * 2;
          beadGroup.rotation.z = elapsed * 0.00008;
          causticRings.forEach((ring) => {
            ring.rotation.z += ring.userData.speed * (1 + starPresence * 1.4);
          });
          beadGroup.children.forEach((bead) => {
            const pulse = 0.88 + Math.sin(elapsed * 0.0024 + bead.userData.phase) * (0.2 + starPresence * 0.26);
            bead.scale.setScalar((0.76 + starPresence * 0.52) * pulse * (bead.userData.phase % 2 > 1 ? 1.24 : 1));
          });
          nightVeil.rotation.z = -0.08 + Math.sin(elapsed * 0.00028) * 0.035;
          const positions = constellationGeometry.attributes.position.array;
          constellationData.forEach((star, index) => {
            const driftX = Math.sin(elapsed * 0.001 + star.phase) * star.drift * starStrength;
            const driftY = Math.cos(elapsed * 0.0012 + star.phase) * star.drift * starStrength;
            const x = THREE.MathUtils.lerp(star.startX, star.targetX, nightReveal) + driftX;
            const y = THREE.MathUtils.lerp(star.startY, star.targetY, nightReveal) + driftY;

            positions[index * 3] = x;
            positions[index * 3 + 1] = y;
            positions[index * 3 + 2] = star.z;
          });
          constellationGeometry.attributes.position.needsUpdate = true;
          constellation.rotation.z = elapsed * 0.00005;
          meteorGroup.rotation.z = Math.sin(elapsed * 0.0005) * 0.03;
          meteorGroup.children.forEach((meteor) => {
            const t = (burstAge - meteor.userData.delay) / meteor.userData.duration;

            if (t <= 0 || t >= 1) {
              meteor.visible = false;
              meteor.material.opacity = 0;
              return;
            }

            const ease = t * t * (3 - 2 * t);
            const direction = meteorBurstDirection === 1 ? 1 : -1;
            const theta = meteor.userData.arcStart + meteor.userData.arcSpan * ease * direction;
            const shimmer = Math.sin(t * Math.PI);
            meteor.visible = true;
            meteor.position.x = Math.sin(theta) * meteor.userData.radius + meteor.userData.offsetX;
            meteor.position.y = Math.cos(theta) * meteor.userData.radius + meteor.userData.offsetY;
            meteor.material.rotation = meteor.userData.rotation + direction * (0.18 - ease * 0.34);
            meteor.material.opacity = meteor.userData.baseOpacity * shimmer * shimmer * (meteorBurstDirection === 1 ? 1 : 0.55);
            meteor.scale.x = (0.42 + meteor.userData.radius * 0.2) * (0.88 + shimmer * 0.38);
            meteor.scale.y = (0.046 + meteor.userData.radius * 0.014) * (0.82 + shimmer * 0.34);
          });
        }

        renderer.render(scene, camera);
      },
    };
  }

  function initHomeTimeWidgets() {
    document.querySelectorAll(".time-widget").forEach((widget) => {
      if (!(widget instanceof HTMLElement) || widget.dataset.timeWidgetInitialized === "true") return;

      widget.dataset.timeWidgetInitialized = "true";
      const controller = new AbortController();
      const { signal } = controller;
      document.addEventListener("astro:before-swap", () => controller.abort(), { once: true, signal });

    const clockCanvas = widget.querySelector("[data-clock-canvas]");
    const threeClock = clockCanvas instanceof HTMLCanvasElement
      ? createThreeClock(clockCanvas)
      : null;
    const timeText = widget.querySelector("[data-time-text]");
    const dateText = widget.querySelector("[data-date-text]");
    const timeZone = widget.querySelector("[data-time-zone]");
    const monthLabel = widget.querySelector("[data-month-label]");
    const yearLabel = widget.querySelector("[data-year-label]");
    const calendarGrid = widget.querySelector("[data-calendar-grid]");
    const prevMonthButton = widget.querySelector("[data-prev-month]");
    const nextMonthButton = widget.querySelector("[data-next-month]");
    const currentMonthButton = widget.querySelector("[data-current-month]");
    const postsData = widget.querySelector("[data-time-widget-posts]");
    const selectedDateTitle = widget.querySelector("[data-selected-date-title]");
    const todayCount = widget.querySelector("[data-today-count]");
    const todayPostList = widget.querySelector("[data-today-post-list]");
    const todayPostEmpty = widget.querySelector("[data-today-post-empty]");
    let posts = postsData ? JSON.parse(postsData.textContent || "[]") : [];
    let postsByDate = groupPostsByDate(posts);

    const monthFormatter = new Intl.DateTimeFormat("zh-CN", { month: "long" });
    const dateFormatter = new Intl.DateTimeFormat("zh-CN", {
      weekday: "long",
      month: "long",
      day: "numeric",
    });

    let visibleYear;
    let visibleMonth;
    let selectedDateKey = "";

    function normalizePostUrl(url) {
      try {
        return new URL(url, window.location.origin).pathname;
      } catch {
        return url;
      }
    }

    function normalizeD1TimeWidgetPost(post) {
      if (!post?.pubDate || !post?.url || !post?.title) return null;

      return {
        title: post.title,
        description: post.description || "",
        date: String(post.pubDate).slice(0, 10),
        url: post.url,
      };
    }

    function groupPostsByDate(postItems) {
      return postItems.reduce((dateMap, post) => {
        dateMap[post.date] = dateMap[post.date] || [];
        dateMap[post.date].push(post);
        return dateMap;
      }, {});
    }

    function mergeTimeWidgetPosts(incomingPosts) {
      const existingUrls = new Set(posts.map((post) => normalizePostUrl(post.url)));
      const normalizedPosts = incomingPosts
        .map(normalizeD1TimeWidgetPost)
        .filter(Boolean)
        .filter((post) => {
          const url = normalizePostUrl(post.url);
          if (existingUrls.has(url)) return false;
          existingUrls.add(url);
          return true;
        });

      if (!normalizedPosts.length) return;

      posts = [...posts, ...normalizedPosts].sort((a, b) => b.date.localeCompare(a.date));
      postsByDate = groupPostsByDate(posts);
      renderCalendar(new Date());
      if (selectedDateKey) renderSelectedPosts(selectedDateKey);
    }

    function renderCalendar(now) {
      if (!calendarGrid || !monthLabel || !yearLabel) return;

      const todayKey = getDateKey(now);
      const year = visibleYear ?? now.getFullYear();
      const month = visibleMonth ?? now.getMonth();
      const firstDay = new Date(year, month, 1);
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      const leadingEmptyDays = (firstDay.getDay() + 6) % 7;
      const cells = [];

      for (let i = 0; i < leadingEmptyDays; i += 1) {
        cells.push(`<span class="calendar-day is-empty" aria-hidden="true"></span>`);
      }

      for (let day = 1; day <= daysInMonth; day += 1) {
        const dateKey = getDateKey(new Date(year, month, day));
        const isToday = dateKey === todayKey;
        const isSelected = dateKey === selectedDateKey;
        const hasPosts = Boolean(postsByDate[dateKey]?.length);
        cells.push(`
          <button
            class="calendar-day${isToday ? " is-today" : ""}${hasPosts ? " has-posts" : ""}${isSelected ? " is-selected" : ""}"
            type="button"
            data-date="${dateKey}"
            ${isToday ? 'aria-current="date"' : ""}
            aria-label="${dateKey}${isToday ? "，今天" : ""}${hasPosts ? `，${postsByDate[dateKey].length} 篇文章` : ""}"
          >
            ${day}
          </button>
        `);
      }

      monthLabel.textContent = monthFormatter.format(firstDay);
      yearLabel.textContent = String(year);
      calendarGrid.innerHTML = cells.join("");
    }

    let renderedMonthKey = "";

    function getDateKey(date) {
      return [
        date.getFullYear(),
        String(date.getMonth() + 1).padStart(2, "0"),
        String(date.getDate()).padStart(2, "0"),
      ].join("-");
    }

    function renderSelectedPosts(dateKey) {
      if (!todayPostList || !todayPostEmpty || !todayCount) return;

      const now = new Date();
      const todayKey = getDateKey(now);
      const selectedDate = new Date(`${dateKey}T00:00:00`);
      const selectedPosts = postsByDate[dateKey] || [];
      const isToday = dateKey === todayKey;

      if (selectedDateTitle) {
        selectedDateTitle.textContent = isToday
          ? "今日发布"
          : `${selectedDate.getMonth() + 1}月${selectedDate.getDate()}日发布`;
      }

      todayCount.textContent = String(selectedPosts.length);
      todayPostList.replaceChildren();

      selectedPosts.forEach((post) => {
        const link = document.createElement("a");
        const title = document.createElement("strong");
        const description = document.createElement("span");

        link.className = "today-post-link";
        link.href = post.url;
        title.textContent = post.title;
        description.textContent = post.description;

        link.append(title, description);
        todayPostList.append(link);
      });

      todayPostEmpty.textContent = isToday ? "今天没有新文章。" : "这一天没有发布文章。";
      todayPostEmpty.hidden = selectedPosts.length > 0;
    }

    function updateClock() {
      if (signal.aborted || !widget.isConnected) return;

      const now = new Date();
      const hours = now.getHours();
      const minutes = now.getMinutes();
      const seconds = now.getSeconds();
      const milliseconds = now.getMilliseconds();
      const smoothSeconds = seconds + milliseconds / 1000;
      const smoothMinutes = minutes + smoothSeconds / 60;
      const smoothHours = (hours % 12) + smoothMinutes / 60;
      const monthKey = `${now.getFullYear()}-${now.getMonth()}-${now.getDate()}`;

      widget.style.setProperty("--hour-angle", `${smoothHours * 30}deg`);
      widget.style.setProperty("--minute-angle", `${smoothMinutes * 6}deg`);
      widget.style.setProperty("--second-angle", `${smoothSeconds * 6}deg`);
      widget.style.setProperty("--day-progress", `${(hours * 60 + minutes) / 14.4}deg`);
      threeClock?.update(now, smoothHours, smoothMinutes, smoothSeconds);

      if (timeText) {
        timeText.textContent = [
          String(hours).padStart(2, "0"),
          String(minutes).padStart(2, "0"),
          String(seconds).padStart(2, "0"),
        ].join(":");
      }

      if (dateText) {
        dateText.textContent = dateFormatter.format(now);
      }

      if (timeZone) {
        timeZone.textContent = Intl.DateTimeFormat().resolvedOptions().timeZone || "Local time";
      }

      if (monthKey !== renderedMonthKey) {
        if (visibleYear === undefined || visibleMonth === undefined) {
          visibleYear = now.getFullYear();
          visibleMonth = now.getMonth();
        }
        if (!selectedDateKey) {
          selectedDateKey = getDateKey(now);
        }
        renderCalendar(now);
        renderSelectedPosts(selectedDateKey);
        renderedMonthKey = monthKey;
      }

      window.requestAnimationFrame(updateClock);
    }

    updateClock();

    const clockStage = widget.querySelector(".clock-stage");
    let tiltFrame = 0;

    function setClockTilt(event) {
      if (!clockStage) return;
      window.cancelAnimationFrame(tiltFrame);
      tiltFrame = window.requestAnimationFrame(() => {
        const rect = clockStage.getBoundingClientRect();
        const x = (event.clientX - rect.left) / rect.width;
        const y = (event.clientY - rect.top) / rect.height;
        const rotateY = (x - 0.5) * 14;
        const rotateX = (0.5 - y) * 14;

        widget.style.setProperty("--tilt-x", `${rotateX.toFixed(2)}deg`);
        widget.style.setProperty("--tilt-y", `${rotateY.toFixed(2)}deg`);
        widget.style.setProperty("--glare-x", `${(x * 100).toFixed(1)}%`);
        widget.style.setProperty("--glare-y", `${(y * 100).toFixed(1)}%`);
        threeClock?.setTilt(rotateX, rotateY, x, y);
      });
    }

    clockStage?.addEventListener("pointermove", setClockTilt, { signal });
    clockStage?.addEventListener("pointerleave", () => {
      widget.style.setProperty("--tilt-x", "0deg");
      widget.style.setProperty("--tilt-y", "0deg");
      widget.style.setProperty("--glare-x", "35%");
      widget.style.setProperty("--glare-y", "24%");
      threeClock?.setTilt(0, 0);
    }, { signal });

    calendarGrid?.addEventListener("click", (event) => {
      const dayButton = event.target.closest("[data-date]");
      if (!(dayButton instanceof HTMLButtonElement)) return;

      selectedDateKey = dayButton.dataset.date || selectedDateKey;
      renderCalendar(new Date());
      renderSelectedPosts(selectedDateKey);
    }, { signal });

    prevMonthButton?.addEventListener("click", () => {
      const previousMonth = new Date(visibleYear, visibleMonth - 1, 1);
      visibleYear = previousMonth.getFullYear();
      visibleMonth = previousMonth.getMonth();
      renderCalendar(new Date());
    }, { signal });

    nextMonthButton?.addEventListener("click", () => {
      const nextMonth = new Date(visibleYear, visibleMonth + 1, 1);
      visibleYear = nextMonth.getFullYear();
      visibleMonth = nextMonth.getMonth();
      renderCalendar(new Date());
    }, { signal });

    currentMonthButton?.addEventListener("click", () => {
      const now = new Date();
      visibleYear = now.getFullYear();
      visibleMonth = now.getMonth();
      selectedDateKey = getDateKey(now);
      renderCalendar(now);
      renderSelectedPosts(selectedDateKey);
    }, { signal });

    fetch("/api/posts", { headers: { accept: "application/json" } })
      .then((response) => (response.ok ? response.json() : null))
      .then((payload) => {
        if (!signal.aborted && Array.isArray(payload?.data)) mergeTimeWidgetPosts(payload.data);
      })
      .catch(() => {
        // Static-only deployments do not expose the Worker API.
      });
    });
  }

  initHomeTimeWidgets();
  document.addEventListener("astro:page-load", initHomeTimeWidgets);
</script>

