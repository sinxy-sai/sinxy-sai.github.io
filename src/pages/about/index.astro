---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProfileCard from "../../components/ProfileCard.astro";
import { Github, Mail } from "lucide-astro";
import { socialLinks } from "../../lib/profile";
---

<BaseLayout title="关于" description="About Sinxy Sai.">
  <section>
    <p class="section-kicker">About</p>
    <h1 class="page-title">关于这个博客</h1>
    <p class="page-description">
      这是 sinxy-sai 的个人博客，用来记录学习、项目和思考。当前版本先把写作系统搭起来，之后会逐步补充更完整的个人介绍、项目展示和常用资源。
    </p>
  </section>

  <section class="content-grid">
    <div class="post-card">
      <h2>现在关注的内容</h2>
      <p>计算机科学基础、算法、前端工程、工具链，以及能帮助长期积累的写作流程。</p>
      <div class="social-links about-links" aria-label="Contact links">
        {
          socialLinks.map((link) => (
            <a href={link.href} target={link.icon === "github" ? "_blank" : undefined} rel={link.icon === "github" ? "noreferrer" : undefined}>
              {link.icon === "github" ? <Github size={18} aria-hidden="true" /> : <Mail size={18} aria-hidden="true" />}
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
    <aside class="sidebar-panel">
      <ProfileCard />
    </aside>
  </section>
</BaseLayout>
