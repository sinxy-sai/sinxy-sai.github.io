---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeStoryCanvas from "../components/HomeStoryCanvas.astro";
import HomeMusicPlayer from "../components/HomeMusicPlayer.astro";
import HomeTimeWidget from "../components/HomeTimeWidget.astro";
import ProfileCard from "../components/ProfileCard.astro";
---

<BaseLayout
  title="首页"
  description="Sinxy Sai 的个人博客，记录计算机科学、算法学习和工程实践。"
>
  <section class="home-layout" aria-label="Homepage">
    <div class="home-main-stack">
      <HomeStoryCanvas
        latestTitle="正在读取最新文章"
        latestUrl="/archive/"
        latestPubDate=""
        postCount={0}
        tagCount={0}
      >
        <HomeMusicPlayer />
      </HomeStoryCanvas>
      <section class="post-list" data-d1-post-list data-d1-limit="5" aria-label="Recent posts">
        <p class="section-kicker">Latest Notes</p>
      </section>
    </div>

    <div class="home-side-stack">
      <aside class="home-profile-panel">
        <ProfileCard />
      </aside>
      <HomeTimeWidget posts={[]} />
      <aside class="sidebar-panel home-topics-panel">
        <div class="side-section-title side-section-title-first">
          <p class="section-kicker">Topics</p>
          <h2>常写主题</h2>
        </div>
        <div class="tag-list" data-d1-tag-list></div>
      </aside>
    </div>
  </section>

  <style>
    .home-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(300px, 370px);
      align-items: start;
      gap: clamp(20px, 3.4vw, 40px);
    }

    .home-main-stack {
      display: grid;
      min-width: 0;
      gap: 20px;
    }

    .home-side-stack {
      display: grid;
      gap: 14px;
      align-self: start;
    }

    .home-profile-panel {
      border: 1px solid var(--line);
      border-radius: 24px;
      background: var(--surface);
      color: var(--text);
      padding: 18px;
      box-shadow: 0 16px 42px rgba(74, 116, 98, 0.1);
      backdrop-filter: blur(18px);
    }

    .home-profile-panel :global(.profile-card) {
      gap: 12px;
    }

    .home-profile-panel :global(.profile-head) {
      grid-template-columns: 60px minmax(0, 1fr);
      gap: 12px;
    }

    .home-profile-panel :global(.profile-avatar) {
      width: 60px;
      height: 60px;
      border-radius: 20px;
    }

    .home-profile-panel :global(.profile-head h2) {
      font-size: 1.1rem;
    }

    .home-profile-panel :global(.profile-bio) {
      font-size: 0.88rem;
      line-height: 1.65;
    }

    .home-profile-panel :global(.profile-location) {
      font-size: 0.84rem;
    }

    .home-profile-panel :global(.social-links a) {
      min-height: 34px;
      font-size: 0.82rem;
      padding: 6px 10px;
    }

    .side-section-title-first {
      margin-top: 0;
      padding-top: 0;
      border-top: 0;
    }

    .home-topics-panel {
      position: static;
      width: 100%;
    }

    @media (max-width: 1080px) {
      .home-layout {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .home-profile-panel {
        padding: 16px;
      }
    }
  </style>
</BaseLayout>
