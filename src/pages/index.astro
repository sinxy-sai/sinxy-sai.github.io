---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomeStoryCanvas from "../components/HomeStoryCanvas.astro";
import HomeTimeWidget from "../components/HomeTimeWidget.astro";
import ProfileCard from "../components/ProfileCard.astro";
---

<BaseLayout
  title="首页"
  description="Sinxy Sai 的个人博客，记录计算机科学、算法学习和工程实践。"
>
  <section class="home-hero" aria-label="Homepage introduction">
    <HomeStoryCanvas
      latestTitle="正在读取最新文章"
      latestUrl="/archive/"
      latestPubDate=""
      postCount={0}
      tagCount={0}
    />
    <HomeTimeWidget posts={[]} />
  </section>

  <section class="content-grid" aria-label="Recent posts">
    <div class="post-list" data-d1-post-list data-d1-limit="5">
      <p class="section-kicker">Latest Notes</p>
    </div>

    <aside class="sidebar-panel">
      <ProfileCard />
      <div class="side-section-title">
        <p class="section-kicker">Topics</p>
        <h2>常写主题</h2>
      </div>
      <div class="tag-list" data-d1-tag-list></div>
    </aside>
  </section>

  <style>
    .home-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(340px, 430px);
      align-items: start;
      gap: clamp(22px, 4vw, 46px);
      min-height: calc(100vh - 160px);
    }

    @media (max-width: 1080px) {
      .home-hero {
        grid-template-columns: 1fr;
        min-height: 0;
      }
    }
  </style>
</BaseLayout>
