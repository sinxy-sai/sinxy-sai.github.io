---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GiscusComments from "../../components/GiscusComments.astro";
import { Focus } from "lucide-astro";
---

<BaseLayout
  title="__D1_POST_TITLE__"
  description="__D1_POST_DESCRIPTION__"
  type="article"
  publishedTime="__D1_POST_PUBLISHED_TIME__"
  robots="noindex, nofollow"
>
  <div class="article-layout __D1_POST_LAYOUT_CLASS__">
    __D1_POST_TOC__
    <article class="article">
      <header class="article-header">
        <p class="section-kicker">Article</p>
        <h1 class="article-title">__D1_POST_TITLE__</h1>
        <div class="meta">
          __D1_POST_ORIGIN__
          <time datetime="__D1_POST_PUBLISHED_TIME__">__D1_POST_DATE__</time>
          __D1_POST_UPDATED__
        </div>
        <div class="tag-list">__D1_POST_TAGS__</div>
        <div class="article-header-actions">
          <button
            class="article-immersive-toggle"
            type="button"
            data-immersive-reading-toggle
            aria-label="进入沉浸阅读"
            aria-pressed="false"
            title="进入沉浸阅读"
          >
            <Focus size={16} aria-hidden="true" />
            <span data-immersive-reading-label>沉浸阅读</span>
          </button>
        </div>
      </header>
      <div class="prose">__D1_POST_CONTENT__</div>
      __D1_POST_CREATION_STATEMENT__
      <GiscusComments />
      <nav class="post-nav" aria-label="文章导航">
        __D1_POST_NAV__
      </nav>
    </article>
  </div>
</BaseLayout>
