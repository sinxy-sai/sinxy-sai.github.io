    const postFilterInput = app?.querySelector("[data-post-filter]");
    const statusFilterInput = app?.querySelector("[data-status-filter]");
    const deleteButton = app?.querySelector("[data-delete-post]");
    const wordCountEl = app?.querySelector("[data-word-count]");
    const actionTitleEl = app?.querySelector("[data-action-title]");
    const actionMetaEl = app?.querySelector("[data-action-meta]");
    const toggleLibraryButton = app?.querySelector("[data-toggle-library]");
    const coverSummary = app?.querySelector("[data-cover-summary]");
    const clearCoverButton = app?.querySelector("[data-clear-cover]");
    const editorView = app?.querySelector("[data-editor-view]");
    const settingsView = app?.querySelector("[data-settings-view]");
    const mediaView = app?.querySelector("[data-media-view]");
    const analyticsView = app?.querySelector("[data-analytics-view]");
    const analyticsSummary = app?.querySelector("[data-analytics-summary]");
    const analyticsOverview = app?.querySelector("[data-analytics-overview]");
    const analyticsDetail = app?.querySelector("[data-analytics-detail]");
    const analyticsDetailKicker = app?.querySelector("[data-analytics-detail-kicker]");
    const analyticsDetailTitle = app?.querySelector("[data-analytics-detail-title]");
