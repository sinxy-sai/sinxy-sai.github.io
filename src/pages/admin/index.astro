    .admin-shell.is-library-collapsed .post-library {
      padding: 10px;
      grid-template-rows: auto auto;
      align-content: start;
    }

    .admin-shell.is-library-collapsed .post-library .panel-head {
      justify-content: center;
    }

    .admin-shell.is-library-collapsed .post-library .panel-head > div:first-child,
    .admin-shell.is-library-collapsed .post-library [data-new-post],
    .admin-shell.is-library-collapsed .post-library [data-refresh-posts],
    .admin-shell.is-library-collapsed .library-tools,
    .admin-shell.is-library-collapsed .post-list {
      display: none;
    }

    .admin-shell.is-library-collapsed .library-icon-collapse {
      display: none;
    }

    .admin-shell.is-library-collapsed .library-icon-expand {
      display: block;
    }

    .admin-shell.is-library-collapsed .library-rail {
      display: grid;
      gap: 10px;
      justify-items: center;
      margin-top: 12px;
    }

    .rail-button {
      display: grid;
      width: 38px;
      min-height: 48px;
      place-items: center;
      gap: 3px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--admin-panel-strong);
      color: var(--muted);
      cursor: pointer;
      font: inherit;
      font-size: 0.65rem;
      font-weight: 850;
      transition: border-color 160ms ease, background 160ms ease, color 160ms ease;
    }

    .rail-button.is-active,
    .rail-button:hover {
      border-color: rgba(117, 201, 165, 0.62);
      background: var(--accent-soft);
      color: var(--accent-strong);
    }

    input,
    select,
    textarea {
      width: 100%;
      min-width: 0;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--admin-panel-strong);
      color: var(--text);
      font: inherit;
      padding: 10px 12px;
      outline: none;
    }

    input:focus,
    select:focus,
    textarea:focus {
      border-color: color-mix(in srgb, var(--accent-strong) 70%, white);
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-strong) 18%, transparent);
    }

    .post-form,
    .asset-upload,
    .media-upload-card,
    .library-tools,
    .post-list,
    .asset-list,
    .media-list {
      display: grid;
      gap: 10px;
    }

    .post-form {
      grid-template-rows: minmax(0, 1fr);
      min-height: 0;
      overflow: hidden;
    }

    .editor-view,
    .settings-view,
    .media-view,
    .analytics-view {
      min-height: 0;
    }

    .editor-view {
      display: grid;
      grid-template-rows: auto minmax(0, 1fr);
      gap: 12px;
      overflow: visible;
    }

    .settings-view,
    .media-view,
    .analytics-view {
      display: grid;
      align-content: start;
      gap: 18px;
      overflow: auto;
      padding: 4px;
    }

    .editor-view[hidden],
    .settings-view[hidden],
    .media-view[hidden],
    .analytics-view[hidden] {
      display: none;
    }

    .settings-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 14px;
      border-bottom: 1px solid var(--line);
      padding-bottom: 14px;
    }

    .settings-head h2 {
      margin: 4px 0 0;
      font-size: 1.25rem;
    }

    .settings-media-card {
      display: grid;
      gap: 12px;
      min-height: 0;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: color-mix(in srgb, var(--admin-panel-strong) 72%, transparent);
      padding: 14px;
    }

    .settings-card-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .settings-card-head h3 {
      margin: 4px 0 0;
      font-size: 1rem;
    }

    .settings-media-card .asset-upload {
      grid-template-columns: minmax(0, 1fr) minmax(180px, 0.55fr) auto;
      align-items: end;
    }

    .media-view {
      grid-template-rows: auto auto minmax(0, 1fr);
      align-content: stretch;
      overflow: hidden;
    }

    .media-toolbar {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 320px);
      gap: 12px;
      align-items: end;
    }

    .media-upload-card {
      grid-template-columns: minmax(180px, 0.7fr) minmax(220px, 1fr) auto;
      align-items: end;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.026);
      padding: 12px;
    }

    .media-upload-card label {
      display: grid;
      gap: 7px;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 780;
      min-width: 0;
    }

    .media-search {
      align-self: stretch;
    }

    .media-search input {
      height: 100%;
    }

    .media-file-manager {
      min-height: 0;
      display: grid;
      grid-template-rows: auto minmax(0, 1fr);
      border: 1px solid var(--line);
      border-radius: 16px;
      background: color-mix(in srgb, var(--surface) 86%, transparent);
      overflow: hidden;
    }

    .media-table-head,
    :global(.media-row) {
      display: grid;
      grid-template-columns: minmax(220px, 1fr) 96px 112px 150px minmax(220px, auto);
      gap: 14px;
      align-items: center;
      padding: 10px 14px;
    }

    .media-table-head {
      border-bottom: 1px solid var(--line);
      color: var(--muted);
      font-size: 0.76rem;
      font-weight: 860;
    }

    .media-list {
      min-height: 0;
      overflow: auto;
      gap: 0;
    }

    :global(.media-row) {
      min-height: 72px;
      border-bottom: 1px solid color-mix(in srgb, var(--line) 72%, transparent);
      color: var(--muted);
      font-size: 0.8rem;
    }

    :global(.media-row:hover) {
      background: rgba(117, 201, 165, 0.06);
    }

    :global(.media-file) {
      min-width: 0;
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr);
      gap: 12px;
      align-items: center;
      color: inherit;
      text-decoration: none;
    }

    :global(.media-file img) {
      width: 44px;
      height: 44px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--bg-soft);
      object-fit: cover;
    }

    :global(.media-file strong),
    :global(.media-file small) {
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    :global(.media-file strong) {
      color: var(--text);
      font-size: 0.88rem;
      font-weight: 860;
    }

    :global(.media-file small) {
      margin-top: 3px;
      color: var(--muted);
      font-size: 0.7rem;
    }

    :global(.media-actions) {
      display: flex;
      justify-content: flex-end;
      gap: 7px;
      flex-wrap: wrap;
    }

    :global(.media-actions .mini-button) {
      min-height: 30px;
      border: 1px solid var(--line);
      border-radius: 9px;
      background: transparent;
      color: var(--muted);
      cursor: pointer;
      font: inherit;
      font-size: 0.76rem;
      padding: 5px 9px;
    }

    :global(.media-actions .mini-button:hover) {
      border-color: rgba(117, 201, 165, 0.46);
      color: var(--accent-strong);
    }

    :global(.media-actions .mini-button.danger) {
      background: rgba(218, 91, 91, 0.07);
      color: #ffb0b0;
    }

    .analytics-view {
      grid-template-rows: auto auto auto;
      align-content: start;
      overflow-x: hidden;
      overflow-y: auto;
      scrollbar-gutter: stable;
    }

    .analytics-summary {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }

    .analytics-summary article,
    .analytics-card {
      border: 1px solid var(--line);
      border-radius: 16px;
      background: color-mix(in srgb, var(--admin-panel-strong) 78%, transparent);
    }

    .analytics-summary article {
      display: grid;
      gap: 6px;
      padding: 14px;
    }

    .analytics-summary span,
    .analytics-row small,
    .analytics-bar small {
      color: var(--muted);
      font-size: 0.76rem;
      font-weight: 780;
    }

    .analytics-summary strong {
      color: var(--text);
      font-size: clamp(1.35rem, 3vw, 2rem);
      line-height: 1;
    }

    .analytics-summary[hidden],
    .analytics-overview[hidden],
    .analytics-detail[hidden],
    .analytics-card[hidden] {
      display: none;
    }

    .analytics-overview {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 12px;
    }

    .analytics-entry {
      min-width: 0;
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr) auto;
      align-items: center;
      gap: 12px;
      min-height: 92px;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: color-mix(in srgb, var(--admin-panel-strong) 78%, transparent);
      color: var(--text);
      cursor: pointer;
      font: inherit;
      padding: 14px;
      text-align: left;
      transition: border-color 160ms ease, background 160ms ease, transform 160ms ease;
    }

    .analytics-entry:last-child {
      grid-column: 1 / -1;
    }

    .analytics-entry:hover {
      border-color: rgba(117, 201, 165, 0.58);
      background: var(--accent-soft);
      transform: translateY(-1px);
    }

    .analytics-entry:disabled {
      cursor: wait;
      opacity: 0.62;
      transform: none;
    }

    .analytics-entry > span:nth-child(2) {
      min-width: 0;
      display: grid;
      gap: 3px;
    }

    .analytics-entry small {
      color: var(--accent-strong);
      font-size: 0.7rem;
      font-weight: 900;
      text-transform: uppercase;
    }

    .analytics-entry strong {
      overflow: hidden;
      color: var(--text);
      font-size: 0.96rem;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .analytics-entry b {
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 760;
    }

    .analytics-entry > svg {
      color: var(--muted);
    }

    .analytics-entry-icon {
      display: grid;
      width: 44px;
      height: 44px;
      place-items: center;
      border: 1px solid rgba(117, 201, 165, 0.34);
      border-radius: 12px;
      background: rgba(117, 201, 165, 0.1);
      color: var(--accent-strong);
    }

    .analytics-detail {
      display: grid;
      gap: 12px;
    }

    .analytics-detail-head {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .analytics-detail-head h3 {
      margin: 4px 0 0;
      font-size: 1.08rem;
    }

    .analytics-detail-panels {
      display: grid;
    }

    .analytics-card {
      display: grid;
      align-content: start;
      gap: 12px;
      min-height: 0;
      padding: 14px;
      overflow: hidden;
    }

    .analytics-card h3 {
      margin: 4px 0 0;
      font-size: 1rem;
    }

    .analytics-bars {
      display: grid;
      grid-template-columns: repeat(7, minmax(44px, 1fr));
      align-items: end;
      gap: 10px;
      min-height: 160px;
    }

    :global(.analytics-bar) {
      display: grid;
      grid-template-rows: minmax(80px, 1fr) auto auto;
      justify-items: center;
      gap: 6px;
      min-width: 0;
    }

    :global(.analytics-bar span) {
      align-self: end;
      width: 100%;
      min-height: 8px;
      border-radius: 8px 8px 3px 3px;
      background: linear-gradient(180deg, var(--accent), var(--accent-strong));
      box-shadow: 0 10px 24px rgba(47, 143, 112, 0.18);
    }

    :global(.analytics-bar strong) {
      color: var(--text);
      font-size: 0.82rem;
    }

    .analytics-list {
      display: grid;
      gap: 8px;
      min-height: auto;
    }

    :global(.analytics-row) {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
      gap: 12px;
      border: 1px solid color-mix(in srgb, var(--line) 72%, transparent);
      border-radius: 12px;
      padding: 10px 12px;
      background: rgba(255, 255, 255, 0.026);
    }

    :global(.analytics-row span) {
      min-width: 0;
      display: grid;
      gap: 3px;
    }

    :global(.analytics-row strong),
    :global(.analytics-row small) {
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    :global(.analytics-row strong) {
      color: var(--text);
      font-size: 0.86rem;
    }

    :global(.analytics-row b) {
      color: var(--accent-strong);
      font-size: 0.84rem;
      white-space: nowrap;
    }

    .cover-current {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      gap: 10px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--admin-panel-strong);
      padding: 10px 12px;
    }

    .cover-current span {
      color: var(--muted);
      font-size: 0.78rem;
      font-weight: 820;
    }

    .cover-current strong {
      overflow: hidden;
      color: var(--muted);
      font-size: 0.88rem;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .cover-current.has-cover {
      border-color: rgba(47, 143, 112, 0.36);
      background: var(--accent-soft);
    }

    .cover-current.has-cover strong {
      color: var(--accent-strong);
    }

    .post-form label,
    .asset-upload label,
    .markdown-column,
    .preview-column {
      display: grid;
      gap: 7px;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 780;
      min-width: 0;
    }

    .title-row,
    .publish-strip,
    .editor-split {
      display: grid;
      gap: 10px;
      min-width: 0;
    }

    .title-row {
      grid-template-columns: minmax(0, 1fr) minmax(180px, 260px);
    }

    .description-field input,
    .title-row input[name="title"] {
      font-weight: 820;
    }

    .title-row input[name="title"] {
      min-height: 48px;
      font-size: 1.18rem;
    }

    .publish-strip {
      grid-template-columns: minmax(210px, 0.8fr) minmax(190px, 0.65fr) minmax(190px, 0.65fr);
    }

    .publish-strip.secondary {
      grid-template-columns: minmax(0, 1fr);
    }

    .status-toggle {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      border: 0;
      margin: 0;
      padding: 0;
    }

    .status-toggle legend {
      grid-column: 1 / -1;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 780;
    }

    .status-toggle label {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 7px;
      min-height: 40px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--admin-panel-strong);
      color: var(--muted);
      cursor: pointer;
      font-weight: 820;
    }

    .status-toggle input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }

    .status-toggle label:has(input:checked) {
      border-color: rgba(47, 143, 112, 0.52);
      background: var(--accent-soft);
      color: var(--accent-strong);
    }

    .publishing-meta-grid {
      display: grid;
      grid-template-columns: minmax(280px, 0.95fr) minmax(260px, 1fr) minmax(260px, 0.8fr);
      gap: 12px;
      align-items: end;
    }

    .settings-choice-group {
      display: flex;
      align-items: center;
      gap: 8px;
      min-height: 48px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--admin-panel-strong);
      margin: 0;
      padding: 9px 10px;
    }

    .settings-choice-group legend,
    .statement-field > span {
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 780;
    }

    .settings-choice-group legend {
      padding: 0 4px;
    }

    .settings-choice-group label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--muted);
      cursor: pointer;
      font-size: 0.84rem;
      font-weight: 820;
      white-space: nowrap;
    }

    .settings-choice-group input {
      width: 15px;
      height: 15px;
      accent-color: var(--accent-strong);
    }

    .settings-choice-group label:has(input:checked) {
      color: var(--accent-strong);
    }

    .statement-field {
      display: grid;
      gap: 7px;
      color: var(--muted);
      font-size: 0.82rem;
      font-weight: 780;
    }

    .markdown-toolbar {
      position: static;
      z-index: 20;
      align-self: start;
      min-height: 42px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: color-mix(in srgb, var(--surface) 96%, transparent);
      padding: 6px;
      overflow: visible;
      flex-wrap: wrap;
    }

    .toolbar-spacer {
      flex: 1 1 auto;
    }

    .tool-button,
    .icon-button,
    .icon-link {
      width: 34px;
      height: 34px;
      flex: 0 0 auto;
      border-radius: 10px;
      padding: 0;
    }

    .tool-button.text-tool {
      width: auto;
      gap: 6px;
      padding: 0 10px;
      font-size: 0.78rem;
    }

    .toolbar-view-mode {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      flex: 0 0 auto;
    }

    .view-mode-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      min-width: 72px;
      height: 34px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--admin-panel-strong);
      color: var(--muted);
      cursor: pointer;
      font: inherit;
      font-size: 0.78rem;
      font-weight: 860;
      padding: 0 10px;
      white-space: nowrap;
    }

    .view-mode-button:hover {
      border-color: rgba(117, 201, 165, 0.62);
      color: var(--accent-strong);
    }

    .view-mode-button.is-active {
      border-color: var(--text);
      background: var(--text);
      color: var(--surface);
    }

    .toolbar-menu {
      position: relative;
      flex: 0 0 auto;
      z-index: 30;
    }

    .toolbar-menu:has(.toolbar-menu-list:not([hidden])) {
      z-index: 90;
    }

    .toolbar-menu-trigger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      min-width: 48px;
      height: 34px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--admin-panel-strong);
      color: var(--text);
      cursor: pointer;
      font: inherit;
      font-size: 0.78rem;
      font-weight: 820;
      padding: 0 8px;
      white-space: nowrap;
    }

    .heading-trigger-label {
      font-size: 0.98rem;
      font-weight: 900;
      line-height: 1;
    }

    .toolbar-menu-trigger:hover,
    .toolbar-menu-trigger[aria-expanded="true"] {
      border-color: rgba(117, 201, 165, 0.62);
      background: var(--accent-soft);
      color: var(--accent-strong);
    }

    .toolbar-menu-list {
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      z-index: 80;
      min-width: 128px;
      display: grid;
      gap: 3px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--surface);
      box-shadow: 0 14px 38px rgba(0, 0, 0, 0.18);
      padding: 6px;
    }

    .toolbar-menu-list[hidden] {
      display: none;
    }

    .toolbar-menu-list.wide {
      min-width: 156px;
    }

    .toolbar-menu-list.code-languages {
      width: 286px;
      max-height: min(420px, calc(100vh - 180px));
      grid-template-columns: repeat(2, minmax(0, 1fr));
      overflow-y: auto;
    }

    .toolbar-menu-list button {
      display: flex;
      align-items: center;
      gap: 8px;
      min-height: 30px;
      border: 0;
      border-radius: 8px;
      background: transparent;
      color: var(--text);
      cursor: pointer;
      font: inherit;
      font-size: 0.8rem;
      font-weight: 760;
      padding: 6px 9px;
      text-align: left;
      white-space: nowrap;
    }

    .toolbar-menu-list .heading-option {
      line-height: 1.2;
    }

    .toolbar-menu-list .heading-option[data-heading-level="1"] {
      font-size: 1rem;
      font-weight: 900;
    }

    .toolbar-menu-list .heading-option[data-heading-level="2"] {
      font-size: 0.92rem;
      font-weight: 860;
    }

    .toolbar-menu-list .heading-option[data-heading-level="3"] {
      font-size: 0.84rem;
      font-weight: 820;
    }

    .toolbar-menu-list .heading-option[data-heading-level="4"] {
      font-size: 0.78rem;
      font-weight: 780;
    }

    .toolbar-menu-list button:hover {
      background: var(--accent-soft);
      color: var(--accent-strong);
    }

    .editor-dialog {
      width: min(680px, calc(100vw - 32px));
      border: 1px solid var(--line);
      border-radius: 18px;
      background: var(--surface);
      color: var(--text);
      padding: 16px;
      box-shadow: 0 20px 70px rgba(0, 0, 0, 0.24);
    }

    .editor-dialog::backdrop {
      background: rgba(12, 23, 19, 0.38);
      backdrop-filter: blur(3px);
    }

    .dialog-head,
    .dialog-actions {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .dialog-head {
      border-bottom: 1px solid var(--line);
      padding-bottom: 12px;
    }

    .dialog-head h3,
    .image-insert-card h4 {
      margin: 4px 0 0;
    }

    .dialog-grid,
    .image-insert-grid {
      display: grid;
      gap: 12px;
      margin-top: 14px;
    }

    .dialog-grid label,
    .image-insert-card label {
      display: grid;
      gap: 7px;
      color: var(--muted);
