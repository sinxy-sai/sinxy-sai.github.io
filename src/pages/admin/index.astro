    const analyticsDetailButtons = app?.querySelectorAll("[data-open-analytics-detail]") || [];
    const analyticsDaily = app?.querySelector("[data-analytics-daily]");
    const analyticsPages = app?.querySelector("[data-analytics-pages]");
    const analyticsApi = app?.querySelector("[data-analytics-api]");
    const analyticsVitals = app?.querySelector("[data-analytics-vitals]");
    const analyticsErrors = app?.querySelector("[data-analytics-errors]");
    const openEditorButtons = app?.querySelectorAll("[data-open-editor]") || [];
    const openSettingsButtons = app?.querySelectorAll("[data-open-settings]") || [];
    const openMediaButtons = app?.querySelectorAll("[data-open-media]") || [];
    const openAnalyticsButtons = app?.querySelectorAll("[data-open-analytics]") || [];
    const openTocButtons = app?.querySelectorAll("[data-open-toc]") || [];
    const closeTocButton = app?.querySelector("[data-close-toc]");
    const linkDialog = app?.querySelector("[data-link-dialog]");
    const imageDialog = app?.querySelector("[data-image-dialog]");
    const adminThemeButtons = app?.querySelectorAll("[data-admin-theme-toggle]") || [];
    const adminThemeTexts = app?.querySelectorAll("[data-admin-theme-text]") || [];

    let postsCache = [];
    let assetsCache = [];
    let analyticsCache = null;
    let isSyncingScroll = false;
    let activeWorkspaceView = "editor";
    let activeEditorMode = "compare";

    const setStatus = (message, type = "neutral") => {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.dataset.type = type;
    };

    const setLoginStatus = (message, type = "neutral") => {
      if (!loginStatusEl) return;
      loginStatusEl.textContent = message;
      loginStatusEl.dataset.type = type;
    };

    const setAuthenticated = (value) => {
      app?.classList.toggle("is-authenticated", value);
      if (authGate instanceof HTMLElement) authGate.hidden = value;
    };

    const getToken = () => tokenInput?.value.trim() || "";

    const adminHeaders = () => {
      const token = getToken();
      if (!token) throw new Error("请先填写 Admin Token。");
      return { Authorization: `Bearer ${token}` };
    };

    function setAdminTheme(theme) {
      const safeTheme = theme === "dark" ? "dark" : "light";
      const isDark = safeTheme === "dark";
      document.documentElement.dataset.theme = safeTheme;
      document.documentElement.style.colorScheme = safeTheme;
      localStorage.setItem("sinxy-theme", safeTheme);
      adminThemeButtons.forEach((button) => {
        button.setAttribute("aria-pressed", String(isDark));
        button.setAttribute("aria-label", isDark ? "切换到白天模式" : "切换到夜间模式");
      });
      adminThemeTexts.forEach((text) => {
        text.textContent = isDark ? "白天" : "夜间";
      });
    }

    function syncAdminTheme() {
      const storedTheme = localStorage.getItem("sinxy-theme");
      const currentTheme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
      setAdminTheme(storedTheme === "light" || storedTheme === "dark" ? storedTheme : currentTheme);
    }

    async function readJson(response) {
      const payload = await response.json().catch(() => null);
      if (!response.ok) {
        throw new Error(payload?.error?.message || `Request failed: ${response.status}`);
      }
      return payload?.data;
    }

    async function authenticateAdmin() {
      if (!(loginButton instanceof HTMLButtonElement)) return;
      const token = getToken();
      if (!token) {
        setLoginStatus("请先填写 Admin Token。", "error");
        tokenInput?.focus();
        return;
      }

      loginButton.disabled = true;
      setLoginStatus("正在验证 Token...");

      try {
        postsCache = await readJson(await fetch("/api/admin/posts", {
          headers: adminHeaders(),
        })) || [];
        renderPosts(postsCache);
        setLoginStatus("");
        setAuthenticated(true);
        setStatus(`已读取 ${postsCache.length} 篇文章。`, "success");
        await loadAssets();
      } catch (error) {
        setAuthenticated(false);
        setLoginStatus(error.message || "Token 验证失败。", "error");
        tokenInput?.focus();
      } finally {
        loginButton.disabled = false;
      }
    }

    function escapeHtml(value) {
      return String(value ?? "").replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      })[char]);
    }

    function renderMath(latex, displayMode) {
      try {
        return katex.renderToString(String(latex || "").trim(), {
          displayMode,
          throwOnError: false,
          strict: false,
          output: "html",
        });
      } catch {
        return `<code>${escapeHtml(latex)}</code>`;
      }
    }

    function safeMarkdownUrl(value) {
      const url = String(value || "").trim();
      if (/^(https?:|\/|\.\/|\.\.\/|#|mailto:)/i.test(url)) return escapeHtml(url);
      return "#";
    }

    function renderInlineText(value) {
      return escapeHtml(value)
        .replace(/!\[([^\]]*)\]\(([^)\s]+)(?:\s+"[^"]*")?\)/g, (_, alt, url) => (
          `<img src="${safeMarkdownUrl(url)}" alt="${alt}" loading="lazy" decoding="async" />`
        ))
        .replace(/\[([^\]]+)\]\(([^)\s]+)(?:\s+"[^"]*")?\)/g, (_, text, url) => (
          `<a href="${safeMarkdownUrl(url)}" target="_blank" rel="noreferrer">${text}</a>`
        ))
        .replace(/`([^`]+)`/g, "<code>$1</code>")
        .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
        .replace(/~~([^~]+)~~/g, "<del>$1</del>")
        .replace(/\*([^*]+)\*/g, "<em>$1</em>");
    }

    function renderInlineMarkdown(value) {
      const source = String(value || "");
      let html = "";
      let cursor = 0;
      const inlineMath = /(^|[^\\])\$([^$\n]+?)\$/g;
      let match;

      while ((match = inlineMath.exec(source))) {
        const mathStart = match.index + match[1].length;
        html += renderInlineText(source.slice(cursor, mathStart));
        html += renderMath(match[2], false);
        cursor = inlineMath.lastIndex;
      }

      html += renderInlineText(source.slice(cursor));
      return html;
    }

    function splitMarkdownTableRow(line) {
      const trimmed = String(line || "").trim();
      const normalized = trimmed.startsWith("|") ? trimmed.slice(1) : trimmed;
      const source = normalized.endsWith("|") ? normalized.slice(0, -1) : normalized;
      const cells = [];
      let cell = "";
      let isEscaped = false;

      for (const char of source) {
        if (char === "|" && !isEscaped) {
          cells.push(cell.trim());
          cell = "";
          continue;
        }

        cell += char;
        isEscaped = char === "\\" && !isEscaped;
        if (char !== "\\") isEscaped = false;
      }

      cells.push(cell.trim());
      return cells;
    }

    function getMarkdownTableAlignments(line, columnCount) {
      const cells = splitMarkdownTableRow(line);
      if (cells.length !== columnCount) return null;

      const alignments = [];
      for (const cell of cells) {
        const value = cell.replace(/\s+/g, "");
        if (!/^:?-{3,}:?$/.test(value)) return null;
        const left = value.startsWith(":");
        const right = value.endsWith(":");
        alignments.push(left && right ? "center" : right ? "right" : left ? "left" : "");
      }

      return alignments;
    }

    function isPotentialMarkdownTableRow(line) {
      return String(line || "").includes("|") && splitMarkdownTableRow(line).length > 1;
    }

    function renderMarkdownTable(rows, alignments) {
      const header = rows[0] || [];
      const body = rows.slice(1);
      const deferredClass = body.length >= 12 || header.length >= 8 ? " deferred-table" : "";
      const renderAlign = (index) => (alignments[index] ? ` style="text-align: ${alignments[index]}"` : "");

      return `
        <div class="table-scroll${deferredClass}">
          <table>
            <thead>
              <tr>${header.map((cell, index) => `<th${renderAlign(index)}>${renderInlineMarkdown(cell)}</th>`).join("")}</tr>
            </thead>
            <tbody>
              ${body.map((row) => (
                `<tr>${header.map((_, index) => `<td${renderAlign(index)}>${renderInlineMarkdown(row[index] || "")}</td>`).join("")}</tr>`
              )).join("")}
            </tbody>
          </table>
        </div>
      `;
    }

    function getPlainHeadingText(value) {
      return String(value || "")
        .replace(/`([^`]+)`/g, "$1")
        .replace(/\*\*([^*]+)\*\*/g, "$1")
        .replace(/\*([^*]+)\*/g, "$1")
        .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
        .replace(/\$([^$]+)\$/g, "$1")
        .replace(/#+\s*$/g, "")
        .trim();
    }

    function slugifyHeading(value, index) {
      const slug = getPlainHeadingText(value)
        .toLowerCase()
        .replace(/[^a-z0-9\u4e00-\u9fa5]+/g, "-")
        .replace(/^-+|-+$/g, "");
      return `heading-${index + 1}${slug ? `-${slug}` : ""}`;
    }

    function extractHeadings(markdown) {
      const headings = [];
      let inCode = false;
      let inDisplayMath = false;

      String(markdown || "").replace(/\r\n/g, "\n").split("\n").forEach((line, lineIndex) => {
        if (/^```/.test(line)) {
          inCode = !inCode;
          return;
        }

        const trimmed = line.trim();
        if (!inCode && trimmed === "$$") {
          inDisplayMath = !inDisplayMath;
          return;
        }

        if (inCode || inDisplayMath) return;

        const heading = line.match(/^(#{1,4})\s+(.+?)\s*#*\s*$/);
        if (!heading) return;

        const text = getPlainHeadingText(heading[2]);
        if (!text) return;

        headings.push({
          depth: heading[1].length,
          id: slugifyHeading(text, headings.length),
          lineIndex,
          text,
        });
      });

      return headings;
    }

    function renderToc(markdown) {
      if (!(tocList instanceof HTMLElement)) return;
      const headings = extractHeadings(markdown);

      if (tocCountEl) {
        tocCountEl.textContent = `${headings.length} 节`;
      }

      if (!headings.length) {
        tocList.innerHTML = `<p class="admin-empty toc-empty">正文里添加 Markdown 标题后会生成目录。</p>`;
        return;
      }

      tocList.innerHTML = headings.map((heading) => `
        <button
          class="toc-item depth-${heading.depth}"
          type="button"
          data-toc-line="${heading.lineIndex}"
          data-toc-heading="${escapeHtml(heading.id)}"
          title="${escapeHtml(heading.text)}"
        >
          <span>${escapeHtml(heading.text)}</span>
        </button>
      `).join("");
    }

    function renderMarkdown(markdown) {
      const codeLanguageAliases = {
        "c#": "csharp", "c++": "cpp", cs: "csharp", js: "javascript", md: "markdown",
        plain: "text", plaintext: "text", py: "python", sh: "bash", shell: "bash",
        ts: "typescript", txt: "text", yml: "yaml",
      };
      const codeLanguageLabels = {
        bash: "Bash", c: "C", cpp: "C++", csharp: "C#", css: "CSS", go: "Go",
        html: "HTML", java: "Java", javascript: "JavaScript", json: "JSON", kotlin: "Kotlin",
        markdown: "Markdown", php: "PHP", python: "Python", rust: "Rust", sql: "SQL",
        swift: "Swift", text: "Text", typescript: "TypeScript", yaml: "YAML",
      };
      const html = [];
      const headings = extractHeadings(markdown);
      let headingCursor = 0;
      let paragraph = [];
      let code = [];
      let codeLanguage = "";
      let inCode = false;
      let listType = "";
      let listItems = [];
      let displayMath = [];
      let inDisplayMath = false;

      const flushParagraph = () => {
        if (!paragraph.length) return;
        html.push(`<p>${renderInlineMarkdown(paragraph.join(" "))}</p>`);
        paragraph = [];
      };

      const flushCode = () => {
        const requestedLanguage = String(codeLanguage || "text").toLowerCase();
        const normalizedLanguage = codeLanguageAliases[requestedLanguage] || requestedLanguage;
        const languageLabel = codeLanguageLabels[normalizedLanguage] || normalizedLanguage.toUpperCase();
        html.push(`<pre data-language="${escapeHtml(languageLabel)}" data-code-language="${escapeHtml(normalizedLanguage)}"><code class="language-${escapeHtml(normalizedLanguage)}">${escapeHtml(code.join("\n"))}</code></pre>`);
        code = [];
        codeLanguage = "";
      };

      const flushList = () => {
        if (!listItems.length || !listType) return;
        const tag = listType === "ordered" ? "ol" : "ul";
        html.push(`<${tag}>${listItems.map((item) => `<li>${renderInlineMarkdown(item)}</li>`).join("")}</${tag}>`);
        listItems = [];
        listType = "";
      };

      const flushDisplayMath = () => {
        html.push(renderMath(displayMath.join("\n"), true));
        displayMath = [];
      };

      const lines = String(markdown || "").replace(/\r\n/g, "\n").split("\n");

      for (let index = 0; index < lines.length; index += 1) {
        const line = lines[index];
        const codeFence = line.match(/^```\s*([A-Za-z0-9_+#.-]+)?\s*$/);
        if (codeFence) {
          if (inCode) {
            flushCode();
            inCode = false;
          } else {
            flushParagraph();
            flushList();
            codeLanguage = codeFence[1] || "";
            inCode = true;
          }
          continue;
        }

        const trimmed = line.trim();

        if (!inCode && trimmed === "$$") {
          if (inDisplayMath) {
            flushDisplayMath();
            inDisplayMath = false;
          } else {
            flushParagraph();
            flushList();
            inDisplayMath = true;
          }
          continue;
        }

        if (!inCode && inDisplayMath) {
          displayMath.push(line);
          continue;
        }

        if (inCode) {
          code.push(line);
          continue;
        }

        const singleLineDisplayMath = trimmed.match(/^\$\$(.+)\$\$$/);
        if (singleLineDisplayMath) {
          flushParagraph();
          flushList();
          html.push(renderMath(singleLineDisplayMath[1], true));
          continue;
        }

        if (!trimmed) {
          flushParagraph();
          flushList();
          continue;
        }

        const tableHeader = splitMarkdownTableRow(line);
        const tableAlignments =
          tableHeader.length > 1 && lines[index + 1]
            ? getMarkdownTableAlignments(lines[index + 1], tableHeader.length)
            : null;
        if (tableAlignments) {
          flushParagraph();
          flushList();
          const tableRows = [tableHeader];
          index += 2;

          while (index < lines.length && isPotentialMarkdownTableRow(lines[index])) {
            tableRows.push(splitMarkdownTableRow(lines[index]));
            index += 1;
          }

          index -= 1;
          html.push(renderMarkdownTable(tableRows, tableAlignments));
          continue;
        }

        const heading = line.match(/^(#{1,4})\s+(.+?)\s*#*\s*$/);
        if (heading) {
          const headingText = getPlainHeadingText(heading[2]);
          if (!headingText) continue;
          flushParagraph();
          flushList();
          const depth = heading[1].length;
          const currentHeading = headings[headingCursor];
          headingCursor += 1;
          const id = currentHeading?.id || slugifyHeading(heading[2], headingCursor);
          html.push(`<h${depth} id="${escapeHtml(id)}" data-heading-id="${escapeHtml(id)}">${renderInlineMarkdown(heading[2])}</h${depth}>`);
          continue;
        }

        const unorderedListItem = line.match(/^\s*[-*+]\s+(.+)$/);
        const orderedListItem = line.match(/^\s*\d+\.\s+(.+)$/);
        if (unorderedListItem || orderedListItem) {
          flushParagraph();
          const nextType = orderedListItem ? "ordered" : "unordered";
          if (listType && listType !== nextType) flushList();
          listType = nextType;
          listItems.push((orderedListItem || unorderedListItem)[1].trim());
          continue;
        }

        paragraph.push(line.trim());
      }

      if (inCode) flushCode();
      if (inDisplayMath) flushDisplayMath();
      flushList();
      flushParagraph();
      return html.join("");
    }

    function updatePreview() {
      if (!markdownPreview || !postForm) return;
      const data = new FormData(postForm);
      const content = data.get("contentMarkdown") || "";
      markdownPreview.innerHTML = renderMarkdown(content);
      renderToc(content);
      updateEditorMeta();
      syncPreviewScroll();
    }

    function scrollRatio(element) {
      const max = element.scrollHeight - element.clientHeight;
      return max > 0 ? element.scrollTop / max : 0;
    }

    function applyScrollRatio(element, ratio) {
      const max = element.scrollHeight - element.clientHeight;
      element.scrollTop = max > 0 ? ratio * max : 0;
    }

    function syncPreviewScroll() {
      if (!(markdownInput instanceof HTMLTextAreaElement) || !(markdownPreview instanceof HTMLElement)) return;
      applyScrollRatio(markdownPreview, scrollRatio(markdownInput));
    }

    function syncMarkdownScroll() {
      if (!(markdownInput instanceof HTMLTextAreaElement) || !(markdownPreview instanceof HTMLElement)) return;
      applyScrollRatio(markdownInput, scrollRatio(markdownPreview));
    }

    function withScrollSync(callback) {
      if (isSyncingScroll) return;
      isSyncingScroll = true;
      callback();
      window.requestAnimationFrame(() => {
        isSyncingScroll = false;
      });
    }

    function toggleLibrary() {
      if (!app || !toggleLibraryButton) return;
      const isCollapsed = app.classList.toggle("is-library-collapsed");
      toggleLibraryButton.setAttribute("aria-label", isCollapsed ? "展开文章库" : "收起文章库");
      toggleLibraryButton.setAttribute("aria-pressed", String(isCollapsed));
    }

    function setTocVisible(visible) {
      if (!app) return;
      app.classList.toggle("is-toc-collapsed", !visible);
      openTocButtons.forEach((button) => {
        button.classList.toggle("is-active", visible);
        button.setAttribute("aria-pressed", String(visible));
      });
    }

    function closeTocPanel() {
      if (!app) return;
      app.classList.add("is-library-collapsed");
      toggleLibraryButton?.setAttribute("aria-label", "展开文章库");
      toggleLibraryButton?.setAttribute("aria-pressed", "true");
      setTocVisible(false);
    }

    function toggleTocPanel() {
      if (!app) return;
      setTocVisible(app.classList.contains("is-toc-collapsed"));
    }

    function formatMetricNumber(value, digits = 0) {
      const numberValue = Number(value);
      if (!Number.isFinite(numberValue)) return "--";
      return numberValue.toLocaleString("zh-CN", {
        maximumFractionDigits: digits,
        minimumFractionDigits: digits,
      });
    }

    function formatDuration(value) {
      const numberValue = Number(value);
      if (!Number.isFinite(numberValue)) return "--";
      return `${formatMetricNumber(numberValue, numberValue >= 100 ? 0 : 1)} ms`;
    }

    function renderAnalyticsList(container, items, renderer, emptyText) {
      if (!(container instanceof HTMLElement)) return;
      if (!items?.length) {
        container.innerHTML = `<div class="admin-empty">${escapeHtml(emptyText)}</div>`;
        return;
      }
      container.innerHTML = items.map(renderer).join("");
    }

    const analyticsDetailMeta = {
      traffic: { kicker: "Traffic", title: "最近 7 天访问" },
      pages: { kicker: "Pages", title: "热门页面" },
      api: { kicker: "Performance", title: "API 延迟" },
      vitals: { kicker: "Web Vitals", title: "前端性能" },
      errors: { kicker: "Errors", title: "最近错误" },
    };

    function setAnalyticsDetail(detail = "") {
      const safeDetail = Object.hasOwn(analyticsDetailMeta, detail) ? detail : "";
      const showDetail = Boolean(safeDetail);

      if (analyticsSummary instanceof HTMLElement) analyticsSummary.hidden = showDetail;
      if (analyticsOverview instanceof HTMLElement) analyticsOverview.hidden = showDetail;
      if (analyticsDetail instanceof HTMLElement) analyticsDetail.hidden = !showDetail;

      analyticsDetailPanels.forEach((panel) => {
        if (panel instanceof HTMLElement) panel.hidden = panel.dataset.analyticsPanel !== safeDetail;
      });

      const meta = analyticsDetailMeta[safeDetail];
      if (meta && analyticsDetailKicker) analyticsDetailKicker.textContent = meta.kicker;
      if (meta && analyticsDetailTitle) analyticsDetailTitle.textContent = meta.title;

      if (analyticsView instanceof HTMLElement) analyticsView.scrollTop = 0;
    }

    function setAnalyticsEntryMetric(name, value) {
      const metric = app?.querySelector(`[data-analytics-entry-metric="${name}"]`);
      if (metric) metric.textContent = value;
    }

    function renderAnalytics(data) {
      analyticsCache = data;

      if (analyticsSummary instanceof HTMLElement) {
        const today = data?.today || {};
        const summary = data?.summary || {};
        analyticsSummary.innerHTML = `
          <article>
            <span>今日 PV</span>
            <strong>${formatMetricNumber(today.totalPageviews)}</strong>
          </article>
          <article>
            <span>今日 UV</span>
            <strong>${formatMetricNumber(today.uniqueVisitors)}</strong>
          </article>
          <article>
            <span>平均 API 延迟</span>
            <strong>${formatDuration(summary.averageApiDurationMs)}</strong>
          </article>
          <article>
            <span>最近错误</span>
            <strong>${formatMetricNumber(summary.clientErrors)}</strong>
          </article>
        `;
      }

      if (analyticsDaily instanceof HTMLElement) {
        const daily = data?.daily || [];
        const maxPageviews = Math.max(1, ...daily.map((item) => Number(item.pageviews) || 0));
        analyticsDaily.innerHTML = daily.length
          ? daily.map((item) => {
              const height = Math.max(8, Math.round(((Number(item.pageviews) || 0) / maxPageviews) * 100));
              return `
                <article class="analytics-bar" title="${escapeHtml(item.date)} · ${formatMetricNumber(item.pageviews)} PV">
                  <span style="height:${height}%"></span>
                  <small>${escapeHtml(String(item.date || "").slice(5).replace("-", "/"))}</small>
                  <strong>${formatMetricNumber(item.pageviews)}</strong>
                </article>
              `;
            }).join("")
          : `<div class="admin-empty">暂无访问数据。</div>`;
      }

      const dailyPageviews = (data?.daily || []).reduce(
        (total, item) => total + (Number(item.pageviews) || 0),
        0,
      );
      setAnalyticsEntryMetric("traffic", `${formatMetricNumber(dailyPageviews)} PV`);
      setAnalyticsEntryMetric("pages", `${formatMetricNumber(data?.popularPages?.length || 0)} 个页面`);
      setAnalyticsEntryMetric("api", formatDuration(data?.summary?.averageApiDurationMs));
      setAnalyticsEntryMetric("vitals", `${formatMetricNumber(data?.webVitals?.length || 0)} 项指标`);
      setAnalyticsEntryMetric("errors", `${formatMetricNumber(data?.recentErrors?.length || 0)} 条记录`);
      analyticsDetailButtons.forEach((button) => {
        if (button instanceof HTMLButtonElement) button.disabled = false;
      });

      renderAnalyticsList(
        analyticsPages,
        data?.popularPages || [],
        (item) => `
          <article class="analytics-row">
            <span>
              <strong>${escapeHtml(item.pageTitle || item.path || "/")}</strong>
              <small>${escapeHtml(item.path || "/")}</small>
            </span>
            <b>${formatMetricNumber(item.pageviews)} PV</b>
          </article>
        `,
        "暂无热门页面数据。",
      );

      renderAnalyticsList(
        analyticsApi,
        data?.api || [],
        (item) => `
          <article class="analytics-row">
            <span>
              <strong>${escapeHtml(item.path || "/api")}</strong>
              <small>${formatMetricNumber(item.requests)} requests · ${formatMetricNumber(item.errors)} errors</small>
            </span>
            <b>${formatDuration(item.averageDurationMs)}</b>
          </article>
        `,
        "暂无 API 延迟数据。",
      );

      renderAnalyticsList(
        analyticsVitals,
        data?.webVitals || [],
        (item) => `
          <article class="analytics-row">
            <span>
              <strong>${escapeHtml(item.metricName || "Metric")}</strong>
              <small>${formatMetricNumber(item.samples)} samples · latest ${formatMetricNumber(item.latestValue, 2)}</small>
            </span>
            <b>${formatMetricNumber(item.averageValue, 2)}</b>
          </article>
        `,
        "暂无 Web Vitals 数据。",
      );

      renderAnalyticsList(
        analyticsErrors,
        data?.recentErrors || [],
        (item) => `
          <article class="analytics-row">
            <span>
              <strong>${escapeHtml(item.metricName || `HTTP ${item.statusCode || "error"}`)}</strong>
              <small>${escapeHtml(item.path || "/")} · ${escapeHtml(formatAdminDate(item.createdAt))}</small>
            </span>
            <b>${escapeHtml(item.statusCode || "")}</b>
          </article>
        `,
        "最近没有错误。",
      );
    }

    async function loadAnalytics() {
      try {
        setStatus("正在读取统计数据...");
        const data = await readJson(await fetch("/api/admin/analytics?days=7", {
          headers: adminHeaders(),
        }));
        renderAnalytics(data);
        setStatus("统计数据已更新。", "success");
      } catch (error) {
        setStatus(error.message, "error");
      }
    }

    function setWorkspaceView(view) {
      if (
        !(editorView instanceof HTMLElement) ||
        !(settingsView instanceof HTMLElement) ||
        !(mediaView instanceof HTMLElement) ||
        !(analyticsView instanceof HTMLElement)
      ) return;
      activeWorkspaceView = ["settings", "media", "analytics"].includes(view) ? view : "editor";
      const showSettings = activeWorkspaceView === "settings";
      const showMedia = activeWorkspaceView === "media";
      const showAnalytics = activeWorkspaceView === "analytics";
      const showEditor = activeWorkspaceView === "editor";

      editorView.hidden = !showEditor;
      settingsView.hidden = !showSettings;
      mediaView.hidden = !showMedia;
      analyticsView.hidden = !showAnalytics;
      app?.classList.toggle("is-settings-view", showSettings);
      app?.classList.toggle("is-media-view", showMedia);
      app?.classList.toggle("is-analytics-view", showAnalytics);

      openEditorButtons.forEach((button) => {
        button.classList.toggle("is-active", showEditor);
        button.setAttribute("aria-pressed", String(showEditor));
      });

      openSettingsButtons.forEach((button) => {
        button.classList.toggle("is-active", showSettings);
        button.setAttribute("aria-pressed", String(showSettings));
      });

      openMediaButtons.forEach((button) => {
        button.classList.toggle("is-active", showMedia);
        button.setAttribute("aria-pressed", String(showMedia));
      });

      openAnalyticsButtons.forEach((button) => {
        button.classList.toggle("is-active", showAnalytics);
        button.setAttribute("aria-pressed", String(showAnalytics));
      });

      if (showEditor) {
        window.requestAnimationFrame(syncPreviewScroll);
      }
    }

    function setEditorMode(mode) {
      const safeMode = ["markdown", "compare", "preview"].includes(mode) ? mode : "compare";
      activeEditorMode = safeMode;

      if (editorSplit instanceof HTMLElement) {
        editorSplit.dataset.editorMode = safeMode;
      }

      editorModeButtons.forEach((button) => {
        const isActive = button.dataset.editorModeButton === safeMode;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", String(isActive));
      });

      if (safeMode !== "markdown") {
        window.requestAnimationFrame(syncPreviewScroll);
      }
    }

    function toggleSettingsView() {
      setWorkspaceView(activeWorkspaceView === "settings" ? "editor" : "settings");
    }

    function scrollMarkdownToLine(lineIndex) {
      if (!(markdownInput instanceof HTMLTextAreaElement)) return;
      const lines = markdownInput.value.replace(/\r\n/g, "\n").split("\n");
      const safeLineIndex = Math.max(0, Math.min(Number(lineIndex) || 0, lines.length - 1));
      const position = lines.slice(0, safeLineIndex).join("\n").length + (safeLineIndex > 0 ? 1 : 0);
      const lineHeight = Number.parseFloat(getComputedStyle(markdownInput).lineHeight) || 24;

      markdownInput.focus();
      markdownInput.setSelectionRange(position, position);
      markdownInput.scrollTop = Math.max(0, safeLineIndex * lineHeight - markdownInput.clientHeight * 0.18);
    }

    function scrollPreviewToHeading(headingId) {
      if (!(markdownPreview instanceof HTMLElement)) return;
      const heading = markdownPreview.querySelector(`[data-heading-id="${headingId}"]`);
      if (!(heading instanceof HTMLElement)) return;
      markdownPreview.scrollTop = Math.max(0, heading.offsetTop - markdownPreview.offsetTop - 12);
    }

    function goToTocHeading(lineIndex, headingId) {
      setWorkspaceView("editor");
      window.requestAnimationFrame(() => {
        isSyncingScroll = true;
        scrollMarkdownToLine(lineIndex);
        scrollPreviewToHeading(headingId);
        window.requestAnimationFrame(() => {
          isSyncingScroll = false;
        });
      });
    }

    function updateEditorMeta() {
      if (!postForm) return;
      const data = new FormData(postForm);
      const title = String(data.get("title") || "").trim() || "新文章";
      const status = String(data.get("status") || "DRAFT") === "PUBLISHED" ? "已发布" : "草稿";
      const pubDate = String(data.get("pubDate") || "").replace("T", " ") || "未设置发布时间";
      const content = String(data.get("contentMarkdown") || "").trim();
      const textCount = content.replace(/\s/g, "").length;

      if (wordCountEl) wordCountEl.textContent = `${textCount} 字`;
      if (actionTitleEl) actionTitleEl.textContent = title;
      if (actionMetaEl) actionMetaEl.textContent = `${status} · ${pubDate}`;
    }

    function currentCoverAssetId() {
      return String(postForm?.elements.coverAssetId?.value || "").trim();
    }

    function updateCoverSummary() {
      if (!(coverSummary instanceof HTMLElement)) return;
      const coverId = currentCoverAssetId();
      const asset = assetsCache.find((item) => item.id === coverId);
      const title = coverSummary.querySelector("strong");

      coverSummary.classList.toggle("has-cover", Boolean(coverId));
      if (title) {
        title.textContent = asset?.filename || (coverId ? "已选择封面" : "未选择封面");
      }
      if (clearCoverButton instanceof HTMLElement) {
        clearCoverButton.hidden = !coverId;
      }
    }

    function localDateTimeValue(date = new Date()) {
      const offset = date.getTimezoneOffset() * 60000;
      return new Date(date.valueOf() - offset).toISOString().slice(0, 16);
    }

    function postDateTimeInputValue(value) {
      if (!value) return "";
      return String(value).replace(" ", "T").slice(0, 16);
    }

    function formatAdminDate(value) {
      if (!value) return "未记录";
      const date = new Date(value);
      if (Number.isNaN(date.valueOf())) return String(value);
      return new Intl.DateTimeFormat("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
      }).format(date);
    }

    function formatAdminPublishDate(value) {
      const inputValue = postDateTimeInputValue(value);
      return inputValue ? inputValue.replace("T", " ") : "未记录";
    }

    function setPostStatus(value) {
      const input = postForm?.querySelector(`input[name="status"][value="${value}"]`);
      if (input) input.checked = true;
    }

    function setRadioValue(name, value) {
      const input = postForm?.querySelector(`input[name="${name}"][value="${value}"]`);
      if (input) input.checked = true;
    }

    function currentPostId() {
      return postForm?.elements.id.value || "";
    }

    function resetPostForm() {
      postForm?.reset();
      if (postForm?.elements.id) postForm.elements.id.value = "";
      if (postForm?.elements.coverAssetId) postForm.elements.coverAssetId.value = "";
      if (postForm?.elements.pubDate) postForm.elements.pubDate.value = localDateTimeValue();
      if (postForm?.elements.updatedAt) postForm.elements.updatedAt.value = "";
      setPostStatus("DRAFT");
      setRadioValue("contentOrigin", "ORIGINAL");
      setRadioValue("visibility", "PUBLIC");
      if (postForm?.elements.creationStatement) postForm.elements.creationStatement.value = "NONE";
      if (deleteButton) deleteButton.hidden = true;
      updateCoverSummary();
      updatePreview();
      renderPosts(postsCache);
    }

    function fillPostForm(post) {
      if (!postForm) return;
      postForm.elements.id.value = post.id || "";
      postForm.elements.title.value = post.title || "";
      postForm.elements.slug.value = post.slug || "";
      postForm.elements.description.value = post.description || "";
      setPostStatus(post.status || "DRAFT");
      setRadioValue("contentOrigin", post.contentOrigin || "ORIGINAL");
      setRadioValue("visibility", post.visibility || "PUBLIC");
      postForm.elements.creationStatement.value = post.creationStatement || "NONE";
      postForm.elements.pubDate.value = postDateTimeInputValue(post.pubDate);
      postForm.elements.updatedAt.value = formatAdminDate(post.updatedAt || post.updatedDate);
      postForm.elements.coverAssetId.value = post.coverAssetId || "";
      postForm.elements.tags.value = Array.isArray(post.tags) ? post.tags.join(", ") : "";
      postForm.elements.contentMarkdown.value = post.contentMarkdown || "";
      if (deleteButton) deleteButton.hidden = false;
      updateCoverSummary();
      updatePreview();
      renderPosts(postsCache);
    }

    function getPostPayload() {
      if (!postForm) throw new Error("Post form is missing.");
      const data = new FormData(postForm);
      const tags = String(data.get("tags") || "")
        .split(",")
        .map((tag) => tag.trim())
        .filter(Boolean);
      const pubDate = data.get("pubDate") ? String(data.get("pubDate")) : undefined;

      return {
        title: String(data.get("title") || "").trim(),
        slug: String(data.get("slug") || "").trim() || undefined,
        description: String(data.get("description") || "").trim(),
        contentMarkdown: String(data.get("contentMarkdown") || ""),
        status: String(data.get("status") || "DRAFT"),
        contentOrigin: String(data.get("contentOrigin") || "ORIGINAL"),
        creationStatement: String(data.get("creationStatement") || "NONE"),
        visibility: String(data.get("visibility") || "PUBLIC"),
        pubDate,
        coverAssetId: String(data.get("coverAssetId") || "").trim() || null,
        tags,
      };
    }

    function filterPosts(posts) {
      const query = String(postFilterInput?.value || "").trim().toLocaleLowerCase();
      const status = String(statusFilterInput?.value || "ALL");

      return posts.filter((post) => {
        const matchesStatus = status === "ALL" || post.status === status;
        const haystack = [
          post.title,
          post.slug,
          post.description,
          ...(post.tags || []),
        ].join(" ").toLocaleLowerCase();
        return matchesStatus && (!query || haystack.includes(query));
      });
    }

    function renderPosts(posts) {
      if (!postList) return;
      const visiblePosts = filterPosts(posts);

      if (!visiblePosts.length) {
        postList.innerHTML = `<div class="admin-empty">没有匹配的文章。</div>`;
        return;
      }

      const selectedId = currentPostId();
      postList.innerHTML = visiblePosts.map((post) => `
        <article class="post-item${post.id === selectedId ? " is-active" : ""}">
          <button class="post-select" type="button" data-edit-post="${escapeHtml(post.id)}">
            <span class="post-title-line">
              <span class="post-state ${post.status === "PUBLISHED" ? "published" : "draft"}">
                ${post.status === "PUBLISHED" ? "已发布" : "草稿"}
              </span>
              <strong>${escapeHtml(post.title)}</strong>
            </span>
            <small>${escapeHtml(formatAdminPublishDate(post.pubDate))} · ${escapeHtml(post.slug)}</small>
            <span class="post-description">${escapeHtml(post.description || "暂无摘要")}</span>
          </button>
          <div class="post-actions">
            <a class="icon-link open-post-link" href="${escapeHtml(post.url)}" target="_blank" rel="noreferrer" aria-label="打开文章">
              打开 ↗
            </a>
            <button class="mini-button danger" type="button" data-delete-list-post="${escapeHtml(post.id)}">
              删除
            </button>
          </div>
        </article>
      `).join("");

      postList.querySelectorAll("[data-edit-post]").forEach((button) => {
        button.addEventListener("click", () => {
          const post = postsCache.find((item) => item.id === button.dataset.editPost);
          if (post) fillPostForm(post);
        });
      });

      postList.querySelectorAll("[data-delete-list-post]").forEach((button) => {
        button.addEventListener("click", () => deletePost(button.dataset.deleteListPost));
      });
    }

    async function loadPosts() {
      try {
        setStatus("正在读取文章列表...");
        postsCache = await readJson(await fetch("/api/admin/posts", {
          headers: adminHeaders(),
        })) || [];
        renderPosts(postsCache);
        setStatus(`已读取 ${postsCache.length} 篇文章。`, "success");
      } catch (error) {
        setStatus(error.message, "error");
      }
    }

    async function savePost() {
      try {
        setStatus("正在保存文章...");
        const id = currentPostId();
        const response = await fetch(id ? `/api/admin/posts/${encodeURIComponent(id)}` : "/api/admin/posts", {
          method: id ? "PATCH" : "POST",
          headers: {
            ...adminHeaders(),
            "Content-Type": "application/json",
          },
          body: JSON.stringify(getPostPayload()),
        });
        const saved = await readJson(response);
        setStatus(`已保存：${saved.title}`, "success");
        await loadPosts();
        fillPostForm(saved);
      } catch (error) {
        setStatus(error.message, "error");
      }
    }

    async function deletePost(id = currentPostId()) {
      const post = postsCache.find((item) => item.id === id);
      if (!id || !post) {
        setStatus("请先选择要删除的文章。", "error");
        return;
      }

      if (!window.confirm(`确认删除「${post.title}」？这个操作不能撤销。`)) return;

      try {
        setStatus("正在删除文章...");
        await readJson(await fetch(`/api/admin/posts/${encodeURIComponent(id)}`, {
          method: "DELETE",
          headers: adminHeaders(),
        }));
        setStatus(`已删除：${post.title}`, "success");
        resetPostForm();
        await loadPosts();
      } catch (error) {
        setStatus(error.message, "error");
      }
    }

    async function loadAssets() {
      try {
        assetsCache = [];
        renderAssets(assetsCache);
        renderMediaAssets(assetsCache);
        updateCoverSummary();
        assetsCache = await readJson(await fetch("/api/admin/assets", {
          headers: adminHeaders(),
        })) || [];
        renderAssets(assetsCache);
        renderMediaAssets(assetsCache);
        updateCoverSummary();
      } catch (error) {
        assetsCache = [];
        renderAssets(assetsCache);
        renderMediaAssets(assetsCache);
        updateCoverSummary();
        setStatus(error.message, "error");
      }
    }

    function markdownForAsset(asset) {
      return `![${asset.alt || asset.filename}](${asset.url})`;
    }

    function browserUrlForAsset(asset) {
      return new URL(asset.url, window.location.origin).href;
    }

    function formatFileSize(bytes) {
      const value = Number(bytes) || 0;
      if (value >= 1024 * 1024) return `${(value / 1024 / 1024).toFixed(2)} MB`;
      if (value >= 1024) return `${Math.round(value / 1024)} KB`;
      return `${value} B`;
    }

    function formatAssetType(asset) {
      return String(asset.contentType || "").replace(/^image\//, "").toUpperCase() || "FILE";
    }

    function filterAssets(assets) {
      const query = String(mediaFilterInput?.value || "").trim().toLocaleLowerCase();
      if (!query) return assets;
      return assets.filter((asset) => [
        asset.filename,
        asset.alt,
        asset.contentType,
        asset.id,
        asset.r2Key,
      ].join(" ").toLocaleLowerCase().includes(query));
    }

    function insertMarkdown(text) {
      if (!(markdownInput instanceof HTMLTextAreaElement)) return;
      const start = markdownInput.selectionStart ?? markdownInput.value.length;
      const end = markdownInput.selectionEnd ?? markdownInput.value.length;
      const prefix = markdownInput.value.slice(0, start);
      const suffix = markdownInput.value.slice(end);
      const separatorBefore = prefix && !prefix.endsWith("\n") ? "\n\n" : "";
      const separatorAfter = suffix && !suffix.startsWith("\n") ? "\n\n" : "";
      markdownInput.value = `${prefix}${separatorBefore}${text}${separatorAfter}${suffix}`;
      const cursor = (prefix + separatorBefore + text).length;
      markdownInput.focus();
      markdownInput.setSelectionRange(cursor, cursor);
      updatePreview();
    }

    function selectedMarkdownText() {
      if (!(markdownInput instanceof HTMLTextAreaElement)) return "";
      const start = markdownInput.selectionStart ?? markdownInput.value.length;
      const end = markdownInput.selectionEnd ?? markdownInput.value.length;
      return markdownInput.value.slice(start, end);
    }

    function replaceSelection(formatter) {
      if (!(markdownInput instanceof HTMLTextAreaElement)) return;
      const start = markdownInput.selectionStart ?? markdownInput.value.length;
      const end = markdownInput.selectionEnd ?? markdownInput.value.length;
      const selected = markdownInput.value.slice(start, end);
      const replacement = formatter(selected);
      markdownInput.setRangeText(replacement, start, end, "end");
      markdownInput.focus();
      updatePreview();
    }

    function closeToolbarMenus(except = null) {
      app?.querySelectorAll("[data-toolbar-menu]").forEach((menu) => {
        if (menu === except) return;
        const trigger = menu.querySelector("[data-menu-trigger]");
        const list = menu.querySelector("[data-menu-list]");
        if (trigger instanceof HTMLElement) trigger.setAttribute("aria-expanded", "false");
        if (list instanceof HTMLElement) list.hidden = true;
      });
    }

    function toggleToolbarMenu(menu) {
      if (!(menu instanceof HTMLElement)) return;
      const trigger = menu.querySelector("[data-menu-trigger]");
      const list = menu.querySelector("[data-menu-list]");
      if (!(trigger instanceof HTMLElement) || !(list instanceof HTMLElement)) return;
      const willOpen = list.hidden;
      closeToolbarMenus(menu);
      list.hidden = !willOpen;
      trigger.setAttribute("aria-expanded", String(willOpen));
    }

    function applyHeading(level) {
      const depth = Number(level);
      if (!depth) return;
      replaceSelection((selected) => `${"#".repeat(depth)} ${selected || "标题"}`);
    }

    function applyList(type) {
      if (!type) return;
      replaceSelection((selected) => {
        const lines = (selected || "列表项").split("\n").filter((line) => line.trim());
        return lines.map((line, index) => (
          type === "ordered" ? `${index + 1}. ${line.trim()}` : `- ${line.trim()}`
        )).join("\n");
      });
    }

    function applyCodeBlock(language) {
      if (!language) return;
      const lang = language === "text" ? "" : language;
      replaceSelection((selected) => `\`\`\`${lang}\n${selected || "代码内容"}\n\`\`\``);
    }

    function closeEditorDialog(dialog) {
      if (dialog instanceof HTMLDialogElement && dialog.open) dialog.close();
    }

    function openLinkDialog() {
      if (!(linkDialog instanceof HTMLDialogElement)) return;
      const selected = selectedMarkdownText();
      const textInput = linkDialog.querySelector("[data-link-text]");
      const urlInput = linkDialog.querySelector("[data-link-url]");
      if (textInput instanceof HTMLInputElement) textInput.value = selected || "";
      if (urlInput instanceof HTMLInputElement) urlInput.value = "";
      linkDialog.showModal();
      window.requestAnimationFrame(() => {
        if (urlInput instanceof HTMLInputElement) urlInput.focus();
      });
    }

    function insertLinkFromDialog() {
      if (!(linkDialog instanceof HTMLDialogElement)) return;
      const textInput = linkDialog.querySelector("[data-link-text]");
      const urlInput = linkDialog.querySelector("[data-link-url]");
      const text = textInput instanceof HTMLInputElement ? textInput.value.trim() : "";
      const url = urlInput instanceof HTMLInputElement ? urlInput.value.trim() : "";
      if (!url) {
        setStatus("请填写链接地址。", "error");
        return;
      }
      insertMarkdown(`[${text || "链接文本"}](${url})`);
      closeEditorDialog(linkDialog);
    }

    function openImageDialog() {
      if (!(imageDialog instanceof HTMLDialogElement)) return;
      imageDialog.showModal();
    }

    function validateInlineImageFile(file) {
      const allowedTypes = new Set(["image/jpeg", "image/png", "image/webp", "image/gif"]);
      const maxBytes = 5 * 1024 * 1024;
      if (!(file instanceof File) || !file.size) throw new Error("请选择图片文件。");
      if (!allowedTypes.has(file.type)) throw new Error("仅支持 JPG、JPEG、PNG、WEBP、GIF 图片。");
      if (file.size > maxBytes) throw new Error("单张图片最大支持 5MB。");
    }

    async function uploadInlineImage() {
      try {
        if (!(imageDialog instanceof HTMLElement)) return;
        const fileInput = imageDialog.querySelector("[data-inline-image-file]");
        const altInput = imageDialog.querySelector("[data-inline-image-alt]");
        const file = fileInput instanceof HTMLInputElement ? fileInput.files?.[0] : null;
        validateInlineImageFile(file);

        const data = new FormData();
        data.set("file", file);
        data.set("alt", altInput instanceof HTMLInputElement ? altInput.value : "");

        setStatus("正在上传图片...");
        const uploaded = await readJson(await fetch("/api/admin/assets", {
          method: "POST",
          headers: adminHeaders(),
          body: data,
        }));
        assetsCache = [uploaded, ...assetsCache.filter((asset) => asset.id !== uploaded.id)];
        renderAssets(assetsCache);
        insertMarkdown(markdownForAsset(uploaded));
        if (fileInput instanceof HTMLInputElement) fileInput.value = "";
        if (altInput instanceof HTMLInputElement) altInput.value = "";
        closeEditorDialog(imageDialog);
        setStatus(`已上传并插入：${uploaded.filename}`, "success");
      } catch (error) {
        setStatus(error.message, "error");
      }
    }

    function insertImageUrlFromDialog() {
      if (!(imageDialog instanceof HTMLDialogElement)) return;
      const urlInput = imageDialog.querySelector("[data-image-url]");
      const altInput = imageDialog.querySelector("[data-image-alt]");
      const url = urlInput instanceof HTMLInputElement ? urlInput.value.trim() : "";
      const alt = altInput instanceof HTMLInputElement ? altInput.value.trim() : "";
      if (!url) {
        setStatus("请填写图片地址。", "error");
        return;
      }
      insertMarkdown(`![${alt || "图片"}](${url})`);
      if (urlInput instanceof HTMLInputElement) urlInput.value = "";
      if (altInput instanceof HTMLInputElement) altInput.value = "";
      closeEditorDialog(imageDialog);
    }

    function runMarkdownAction(action) {
      const fallback = {
        bold: "加粗文本",
        italic: "斜体文本",
        strike: "删除线文本",
        quote: "引用内容",
      };

      const selectedOr = (selected, key) => selected || fallback[key];

      const actions = {
        bold: (selected) => `**${selectedOr(selected, "bold")}**`,
        italic: (selected) => `*${selectedOr(selected, "italic")}*`,
        strike: (selected) => `~~${selectedOr(selected, "strike")}~~`,
        quote: (selected) => selected
          ? selected.split("\n").map((line) => `> ${line}`).join("\n")
          : `> ${fallback.quote}`,
      };

      const formatter = actions[action];
      if (formatter) replaceSelection(formatter);
    }

    function renderAssets(assets) {
      if (!assetList) return;
      if (!assets.length) {
        assetList.innerHTML = `<div class="admin-empty">暂无资源。</div>`;
        updateCoverSummary();
        return;
      }

      const selectedCoverId = currentCoverAssetId();
      assetList.innerHTML = assets.map((asset) => `
        <article class="asset-item${asset.id === selectedCoverId ? " is-cover" : ""}">
          <img src="${escapeHtml(asset.url)}" alt="${escapeHtml(asset.alt || asset.filename)}" loading="lazy" />
          <div>
            <strong>${escapeHtml(asset.filename)}</strong>
            <small>${Math.round((asset.byteSize || 0) / 1024)} KB · ${escapeHtml(asset.id)}</small>
            <div class="asset-actions">
              <button class="mini-button" type="button" data-cover-id="${escapeHtml(asset.id)}">
                ${asset.id === selectedCoverId ? "当前封面" : "设封面"}
              </button>
              <button class="mini-button" type="button" data-insert-asset="${escapeHtml(asset.id)}">插入</button>
              <button class="mini-button" type="button" data-copy-url="${escapeHtml(browserUrlForAsset(asset))}">复制 URL</button>
            </div>
          </div>
        </article>
      `).join("");

      assetList.querySelectorAll("[data-cover-id]").forEach((button) => {
        button.addEventListener("click", () => {
          if (postForm) postForm.elements.coverAssetId.value = button.dataset.coverId || "";
          updateCoverSummary();
          renderAssets(assetsCache);
          setStatus("已设置封面资源。", "success");
        });
      });

      assetList.querySelectorAll("[data-insert-asset]").forEach((button) => {
        button.addEventListener("click", () => {
          const asset = assetsCache.find((item) => item.id === button.dataset.insertAsset);
          if (!asset) return;
          insertMarkdown(markdownForAsset(asset));
          setStatus("已插入图片 Markdown。", "success");
        });
      });

      assetList.querySelectorAll("[data-copy-url]").forEach((button) => {
        button.addEventListener("click", async () => {
          await navigator.clipboard?.writeText(button.dataset.copyUrl || "");
          setStatus("已复制资源 URL。", "success");
        });
      });
    }

    function renderMediaAssets(assets) {
      if (!mediaList) return;
      const visibleAssets = filterAssets(assets);

      if (!visibleAssets.length) {
        mediaList.innerHTML = `<div class="admin-empty">暂无匹配的媒体资源。</div>`;
        return;
      }

      mediaList.innerHTML = visibleAssets.map((asset) => `
        <article class="media-row">
          <a class="media-file" href="${escapeHtml(asset.url)}" target="_blank" rel="noreferrer">
            <img src="${escapeHtml(asset.url)}" alt="${escapeHtml(asset.alt || asset.filename)}" loading="lazy" />
            <span>
              <strong>${escapeHtml(asset.filename)}</strong>
              <small>${escapeHtml(asset.r2Key || asset.id)}</small>
            </span>
          </a>
          <span>${escapeHtml(formatFileSize(asset.byteSize))}</span>
          <span>${escapeHtml(formatAssetType(asset))}</span>
          <span>${escapeHtml(formatAdminDate(asset.createdAt))}</span>
          <span class="media-actions">
            <button class="mini-button" type="button" data-media-copy-url="${escapeHtml(browserUrlForAsset(asset))}">复制 URL</button>
            <button class="mini-button" type="button" data-media-insert="${escapeHtml(asset.id)}">插入</button>
            <button class="mini-button danger" type="button" data-delete-asset="${escapeHtml(asset.id)}">删除</button>
          </span>
        </article>
      `).join("");

      mediaList.querySelectorAll("[data-media-copy-url]").forEach((button) => {
        button.addEventListener("click", async () => {
          await navigator.clipboard?.writeText(button.dataset.mediaCopyUrl || "");
          setStatus("已复制资源 URL。", "success");
        });
      });

      mediaList.querySelectorAll("[data-media-insert]").forEach((button) => {
        button.addEventListener("click", () => {
          const asset = assetsCache.find((item) => item.id === button.dataset.mediaInsert);
          if (!asset) return;
          setWorkspaceView("editor");
          insertMarkdown(markdownForAsset(asset));
          setStatus("已插入图片 Markdown。", "success");
        });
      });

      mediaList.querySelectorAll("[data-delete-asset]").forEach((button) => {
        button.addEventListener("click", () => deleteAsset(button.dataset.deleteAsset));
      });
    }

    async function uploadAssetFromForm(formElement) {
      try {
        if (!(formElement instanceof HTMLElement)) throw new Error("Asset form is missing.");
        const fileInput = formElement.querySelector('input[name="file"]');
        const altInput = formElement.querySelector('input[name="alt"]');
        const file = fileInput instanceof HTMLInputElement ? fileInput.files?.[0] : null;
        if (!(file instanceof File) || !file.size) {
          throw new Error("请选择图片文件。");
        }

        const data = new FormData();
        data.set("file", file);
        data.set("alt", altInput instanceof HTMLInputElement ? altInput.value : "");

        setStatus("正在上传图片...");
        const uploaded = await readJson(await fetch("/api/admin/assets", {
          method: "POST",
          headers: adminHeaders(),
          body: data,
        }));
        setStatus(`已上传：${uploaded.filename}`, "success");
        if (fileInput instanceof HTMLInputElement) fileInput.value = "";
        if (altInput instanceof HTMLInputElement) altInput.value = "";
        await loadAssets();
      } catch (error) {
        setStatus(error.message, "error");
      }
    }

    function uploadAsset() {
      uploadAssetFromForm(assetForm);
    }

    function uploadMediaAsset() {
      uploadAssetFromForm(mediaAssetForm);
    }

    async function deleteAsset(id) {
      const asset = assetsCache.find((item) => item.id === id);
      if (!asset) return;
      if (!window.confirm(`确定删除媒体资源「${asset.filename}」吗？这会同时删除数据库记录和 R2 文件。`)) return;

      try {
        setStatus("正在删除媒体资源...");
        await readJson(await fetch(`/api/admin/assets/${encodeURIComponent(id)}`, {
          method: "DELETE",
          headers: adminHeaders(),
        }));
        if (postForm?.elements.coverAssetId?.value === id) {
          postForm.elements.coverAssetId.value = "";
        }
        assetsCache = assetsCache.filter((item) => item.id !== id);
        renderAssets(assetsCache);
        renderMediaAssets(assetsCache);
        updateCoverSummary();
        setStatus(`已删除媒体资源：${asset.filename}`, "success");
      } catch (error) {
        setStatus(error.message, "error");
      }
    }

    function insertCoverImage() {
      const id = postForm?.elements.coverAssetId.value;
      const asset = assetsCache.find((item) => item.id === id);
      if (!asset) {
        setStatus("请先从资源列表设置封面。", "error");
        return;
      }
      insertMarkdown(markdownForAsset(asset));
      setStatus("已插入封面图片 Markdown。", "success");
    }

    function publishPost() {
      setPostStatus("PUBLISHED");
      updateEditorMeta();
      savePost();
    }

    postForm?.addEventListener("input", updatePreview);
    postFilterInput?.addEventListener("input", () => renderPosts(postsCache));
    statusFilterInput?.addEventListener("change", () => renderPosts(postsCache));
    app?.querySelector("[data-save-post]")?.addEventListener("click", savePost);
    app?.querySelector("[data-publish-post]")?.addEventListener("click", publishPost);
    app?.querySelector("[data-delete-post]")?.addEventListener("click", () => deletePost());
    app?.querySelector("[data-new-post]")?.addEventListener("click", resetPostForm);
    app?.querySelector("[data-reset-post]")?.addEventListener("click", resetPostForm);
    app?.querySelector("[data-upload-asset]")?.addEventListener("click", uploadAsset);
    app?.querySelector("[data-upload-media-asset]")?.addEventListener("click", uploadMediaAsset);
    app?.querySelectorAll("[data-refresh-assets]").forEach((button) => {
      button.addEventListener("click", loadAssets);
    });
    app?.querySelector("[data-refresh-posts]")?.addEventListener("click", loadPosts);
    app?.querySelector("[data-open-link-dialog]")?.addEventListener("click", openLinkDialog);
    app?.querySelector("[data-insert-link]")?.addEventListener("click", insertLinkFromDialog);
    app?.querySelector("[data-open-image-dialog]")?.addEventListener("click", openImageDialog);
    app?.querySelector("[data-upload-inline-image]")?.addEventListener("click", uploadInlineImage);
    app?.querySelector("[data-insert-image-url]")?.addEventListener("click", insertImageUrlFromDialog);
    app?.querySelectorAll("[data-menu-trigger]").forEach((button) => {
      button.addEventListener("click", (event) => {
        event.stopPropagation();
        toggleToolbarMenu(button.closest("[data-toolbar-menu]"));
      });
    });
    app?.querySelectorAll("[data-heading-level]").forEach((button) => {
      button.addEventListener("click", () => {
        applyHeading(button.dataset.headingLevel);
        closeToolbarMenus();
      });
    });
    app?.querySelectorAll("[data-list-type]").forEach((button) => {
      button.addEventListener("click", () => {
        applyList(button.dataset.listType);
        closeToolbarMenus();
      });
    });
    app?.querySelectorAll("[data-code-language]").forEach((button) => {
      button.addEventListener("click", () => {
        applyCodeBlock(button.dataset.codeLanguage);
        closeToolbarMenus();
      });
    });
    document.addEventListener("click", (event) => {
      if (event.target instanceof Element && event.target.closest("[data-toolbar-menu]")) return;
      closeToolbarMenus();
    });
    app?.querySelectorAll("[data-close-dialog]").forEach((button) => {
      button.addEventListener("click", () => closeEditorDialog(button.closest("dialog")));
    });
    clearCoverButton?.addEventListener("click", () => {
      if (postForm?.elements.coverAssetId) postForm.elements.coverAssetId.value = "";
      updateCoverSummary();
      renderAssets(assetsCache);
      setStatus("已清除封面。", "success");
    });
    toggleLibraryButton?.addEventListener("click", toggleLibrary);
    openEditorButtons.forEach((button) => {
      button.addEventListener("click", () => setWorkspaceView("editor"));
    });
    openSettingsButtons.forEach((button) => {
      button.addEventListener("click", toggleSettingsView);
    });
    openMediaButtons.forEach((button) => {
      button.addEventListener("click", () => setWorkspaceView("media"));
    });
    openAnalyticsButtons.forEach((button) => {
      button.addEventListener("click", () => {
        setWorkspaceView("analytics");
        setAnalyticsDetail("");
        if (!analyticsCache) loadAnalytics();
      });
    });
    app?.querySelector("[data-refresh-analytics]")?.addEventListener("click", loadAnalytics);
    analyticsDetailButtons.forEach((button) => {
      button.addEventListener("click", () => setAnalyticsDetail(button.dataset.openAnalyticsDetail || ""));
    });
    app?.querySelector("[data-close-analytics-detail]")?.addEventListener("click", () => setAnalyticsDetail(""));
    openTocButtons.forEach((button) => {
      button.addEventListener("click", toggleTocPanel);
    });
    closeTocButton?.addEventListener("click", closeTocPanel);
    mediaFilterInput?.addEventListener("input", () => renderMediaAssets(assetsCache));
    editorModeButtons.forEach((button) => {
      button.addEventListener("click", () => setEditorMode(button.dataset.editorModeButton));
    });
    markdownInput?.addEventListener("scroll", () => withScrollSync(syncPreviewScroll));
    markdownPreview?.addEventListener("scroll", () => withScrollSync(syncMarkdownScroll));
    tocList?.addEventListener("click", (event) => {
      const button = event.target instanceof Element ? event.target.closest("[data-toc-heading]") : null;
      if (!(button instanceof HTMLElement)) return;
      goToTocHeading(button.dataset.tocLine, button.dataset.tocHeading || "");
    });
    app?.querySelectorAll("[data-md-action]").forEach((button) => {
      button.addEventListener("click", () => runMarkdownAction(button.dataset.mdAction));
    });
    loginButton?.addEventListener("click", authenticateAdmin);
    tokenInput?.addEventListener("keydown", (event) => {
      if (event.key === "Enter") {
        event.preventDefault();
        authenticateAdmin();
      }
    });
    adminThemeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const currentTheme = document.documentElement.dataset.theme === "dark" ? "dark" : "light";
        setAdminTheme(currentTheme === "dark" ? "light" : "dark");
      });
    });
    window.addEventListener("storage", (event) => {
      if (event.key !== "sinxy-theme") return;
      if (event.newValue !== "light" && event.newValue !== "dark") return;
      setAdminTheme(event.newValue);
    });

    syncAdminTheme();
    resetPostForm();
    setWorkspaceView("editor");
    setEditorMode(activeEditorMode);
    setTocVisible(true);
    setAuthenticated(false);
    tokenInput?.focus();
  </script>

