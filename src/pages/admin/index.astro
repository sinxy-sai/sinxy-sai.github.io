---
import {
  Eye,
  KeyRound,
  RefreshCw,
  RotateCcw,
  Save,
  Upload,
} from "lucide-astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Admin"
  description="Private blog publishing workspace."
  robots="noindex, nofollow"
>
  <section class="admin-shell" data-admin-app>
    <header class="admin-hero">
      <div>
        <p class="section-kicker">Admin Workspace</p>
        <h1>发布与资源管理</h1>
        <p>文章、图片和发布状态集中在一个工作台里处理。</p>
      </div>
      <div class="admin-token-panel">
        <label for="admin-token">
          <KeyRound size={16} aria-hidden="true" />
          <span>Admin Token</span>
        </label>
        <input
          id="admin-token"
          name="token"
          type="password"
          autocomplete="off"
          placeholder="Bearer token"
          data-admin-token
        />
      </div>
    </header>

    <div class="admin-status" data-admin-status role="status">等待连接后端。</div>

    <div class="admin-grid">
      <section class="admin-panel admin-editor">
        <div class="admin-panel-head">
          <div>
            <p class="section-kicker">Editor</p>
            <h2>文章编辑</h2>
          </div>
          <div class="admin-actions">
            <button class="admin-button ghost" type="button" data-reset-post>
              <RotateCcw size={16} aria-hidden="true" />
              <span>重置</span>
            </button>
            <button class="admin-button primary" type="button" data-save-post>
              <Save size={16} aria-hidden="true" />
              <span>保存文章</span>
            </button>
          </div>
        </div>

        <form class="admin-form" data-post-form>
          <input type="hidden" name="id" data-post-id />
          <div class="admin-form-row two">
            <label>
              <span>标题</span>
              <input name="title" type="text" maxlength="180" required />
            </label>
            <label>
              <span>Slug</span>
              <input name="slug" type="text" maxlength="120" placeholder="留空时由标题生成" />
            </label>
          </div>
          <label>
            <span>描述</span>
            <input name="description" type="text" maxlength="320" required />
          </label>
          <div class="admin-form-row three">
            <label>
              <span>状态</span>
              <select name="status">
                <option value="DRAFT">DRAFT</option>
                <option value="PUBLISHED">PUBLISHED</option>
              </select>
            </label>
            <label>
              <span>发布时间</span>
              <input name="pubDate" type="datetime-local" />
            </label>
            <label>
              <span>封面资源 ID</span>
              <input name="coverAssetId" type="text" placeholder="从资源列表选择" />
            </label>
          </div>
          <label class="admin-readonly-field">
            <span>最后编辑时间</span>
            <input name="updatedAt" type="text" placeholder="保存后自动记录" readonly />
          </label>
          <label>
            <span>标签</span>
            <input name="tags" type="text" placeholder="Backend, D1, Cloudflare" />
          </label>
          <label>
            <span>Markdown</span>
            <textarea name="contentMarkdown" rows="18" required></textarea>
          </label>
        </form>
      </section>

      <aside class="admin-panel admin-side">
        <div class="admin-panel-head compact">
          <div>
            <p class="section-kicker">Media</p>
            <h2>图片上传</h2>
          </div>
        </div>
        <form class="asset-upload" data-asset-form>
          <label>
            <span>图片文件</span>
            <input name="file" type="file" accept="image/jpeg,image/png,image/webp,image/gif" />
          </label>
          <label>
            <span>替代文本</span>
            <input name="alt" type="text" maxlength="240" />
          </label>
          <button class="admin-button primary" type="button" data-upload-asset>
            <Upload size={16} aria-hidden="true" />
            <span>上传图片</span>
          </button>
        </form>

        <div class="admin-panel-head compact with-gap">
          <div>
            <p class="section-kicker">Assets</p>
            <h2>资源列表</h2>
          </div>
          <button class="admin-icon-button" type="button" data-refresh-assets aria-label="刷新资源">
            <RefreshCw size={16} aria-hidden="true" />
          </button>
        </div>
        <div class="asset-list" data-asset-list></div>
      </aside>
    </div>

    <div class="admin-grid lower">
      <section class="admin-panel">
        <div class="admin-panel-head">
          <div>
            <p class="section-kicker">Posts</p>
            <h2>文章列表</h2>
          </div>
          <button class="admin-button ghost" type="button" data-refresh-posts>
            <RefreshCw size={16} aria-hidden="true" />
            <span>刷新</span>
          </button>
        </div>
        <div class="admin-list" data-post-list></div>
      </section>

      <section class="admin-panel">
        <div class="admin-panel-head">
          <div>
            <p class="section-kicker">Preview</p>
            <h2>正文预览</h2>
          </div>
          <span class="admin-preview-badge">
            <Eye size={16} aria-hidden="true" />
            Live
          </span>
        </div>
        <article class="admin-preview" data-markdown-preview></article>
      </section>
    </div>
  </section>

  <script is:inline>
    const app = document.querySelector("[data-admin-app]");
    const tokenInput = app?.querySelector("[data-admin-token]");
    const statusEl = app?.querySelector("[data-admin-status]");
    const postForm = app?.querySelector("[data-post-form]");
    const assetForm = app?.querySelector("[data-asset-form]");
    const postList = app?.querySelector("[data-post-list]");
    const assetList = app?.querySelector("[data-asset-list]");
    const markdownPreview = app?.querySelector("[data-markdown-preview]");

    const setStatus = (message, type = "neutral") => {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.dataset.type = type;
    };

    const getToken = () => tokenInput?.value.trim() || "";

    const adminHeaders = () => {
      const token = getToken();
      if (!token) throw new Error("请先填写 Admin Token。");
      return { Authorization: `Bearer ${token}` };
    };

    async function readJson(response) {
      const payload = await response.json().catch(() => null);
      if (!response.ok) {
        throw new Error(payload?.error?.message || `Request failed: ${response.status}`);
      }
      return payload?.data;
    }

    function escapeHtml(value) {
      return String(value).replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        '"': "&quot;",
        "'": "&#39;",
      })[char]);
    }

    function renderInlineMarkdown(value) {
      return escapeHtml(value)
        .replace(/`([^`]+)`/g, "<code>$1</code>")
        .replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>")
        .replace(/\*([^*]+)\*/g, "<em>$1</em>");
    }

    function renderMarkdown(markdown) {
      const html = [];
      let paragraph = [];
      let code = [];
      let inCode = false;

      const flushParagraph = () => {
        if (!paragraph.length) return;
        html.push(`<p>${renderInlineMarkdown(paragraph.join(" "))}</p>`);
        paragraph = [];
      };

      const flushCode = () => {
        html.push(`<pre><code>${escapeHtml(code.join("\n"))}</code></pre>`);
        code = [];
      };

      for (const line of String(markdown || "").replace(/\r\n/g, "\n").split("\n")) {
        if (/^```/.test(line)) {
          if (inCode) {
            flushCode();
            inCode = false;
          } else {
            flushParagraph();
            inCode = true;
          }
          continue;
        }

        if (inCode) {
          code.push(line);
          continue;
        }

        if (!line.trim()) {
          flushParagraph();
          continue;
        }

        const heading = line.match(/^(#{1,3})\s+(.+)$/);
        if (heading) {
          flushParagraph();
          const depth = heading[1].length;
          html.push(`<h${depth}>${renderInlineMarkdown(heading[2])}</h${depth}>`);
          continue;
        }

        paragraph.push(line.trim());
      }

      if (inCode) flushCode();
      flushParagraph();
      return html.join("");
    }

    function updatePreview() {
      if (!markdownPreview || !postForm) return;
      const data = new FormData(postForm);
      markdownPreview.innerHTML = renderMarkdown(data.get("contentMarkdown") || "");
    }

    function localDateTimeValue(date = new Date()) {
      const offset = date.getTimezoneOffset() * 60000;
      return new Date(date.valueOf() - offset).toISOString().slice(0, 16);
    }

    function postDateTimeInputValue(value) {
      if (!value) return "";
      return String(value).replace(" ", "T").slice(0, 16);
    }

    function resetPostForm() {
      postForm?.reset();
      const idInput = postForm?.querySelector("[data-post-id]");
      if (idInput) idInput.value = "";
      const pubDateInput = postForm?.querySelector("input[name='pubDate']");
      if (pubDateInput) pubDateInput.value = localDateTimeValue();
      if (postForm?.elements.updatedAt) postForm.elements.updatedAt.value = "";
      updatePreview();
    }

    function formatAdminDate(value) {
      if (!value) return "未记录";
      const date = new Date(value);
      if (Number.isNaN(date.valueOf())) return String(value);
      return new Intl.DateTimeFormat("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
      }).format(date);
    }

    function formatAdminPublishDate(value) {
      const inputValue = postDateTimeInputValue(value);
      return inputValue ? inputValue.replace("T", " ") : "未记录";
    }

    function fillPostForm(post) {
      if (!postForm) return;
      postForm.elements.id.value = post.id || "";
      postForm.elements.title.value = post.title || "";
      postForm.elements.slug.value = post.slug || "";
      postForm.elements.description.value = post.description || "";
      postForm.elements.status.value = post.status || "DRAFT";
      postForm.elements.pubDate.value = postDateTimeInputValue(post.pubDate);
      postForm.elements.updatedAt.value = formatAdminDate(post.updatedAt || post.updatedDate);
      postForm.elements.coverAssetId.value = post.coverAssetId || "";
      postForm.elements.tags.value = Array.isArray(post.tags) ? post.tags.join(", ") : "";
      postForm.elements.contentMarkdown.value = post.contentMarkdown || "";
      updatePreview();
      postForm.scrollIntoView({ block: "start", behavior: "smooth" });
    }

    function getPostPayload() {
      if (!postForm) throw new Error("Post form is missing.");
      const data = new FormData(postForm);
      const tags = String(data.get("tags") || "")
        .split(",")
        .map((tag) => tag.trim())
        .filter(Boolean);
      const pubDate = data.get("pubDate") ? String(data.get("pubDate")) : undefined;

      return {
        title: String(data.get("title") || "").trim(),
        slug: String(data.get("slug") || "").trim() || undefined,
        description: String(data.get("description") || "").trim(),
        contentMarkdown: String(data.get("contentMarkdown") || ""),
        status: String(data.get("status") || "DRAFT"),
        pubDate,
        coverAssetId: String(data.get("coverAssetId") || "").trim() || null,
        tags,
      };
    }

    async function loadPosts() {
      try {
        setStatus("正在读取文章列表...");
        const posts = await readJson(await fetch("/api/admin/posts", {
          headers: adminHeaders(),
        }));
        renderPosts(posts || []);
        setStatus(`已读取 ${posts?.length || 0} 篇文章。`, "success");
      } catch (error) {
        setStatus(error.message, "error");
      }
    }

    function renderPosts(posts) {
      if (!postList) return;
      if (!posts.length) {
        postList.innerHTML = `<div class="admin-empty">暂无文章。</div>`;
        return;
      }

      postList.innerHTML = posts.map((post) => `
        <article class="admin-post-item">
          <div>
            <span class="admin-pill">${escapeHtml(post.status)}</span>
            <h3>${escapeHtml(post.title)}</h3>
            <p>${escapeHtml(post.description || "")}</p>
            <small>
              ${escapeHtml(post.slug)}
              · 发布时间 ${escapeHtml(formatAdminPublishDate(post.pubDate))}
              · 最后编辑 ${escapeHtml(formatAdminDate(post.updatedAt || post.updatedDate))}
            </small>
          </div>
          <div class="admin-item-actions">
            <a class="admin-icon-link" href="${escapeHtml(post.url)}" target="_blank" rel="noreferrer" aria-label="打开文章">↗</a>
            <button class="admin-small-button" type="button" data-edit-post="${escapeHtml(post.id)}">编辑</button>
          </div>
        </article>
      `).join("");

      postList.querySelectorAll("[data-edit-post]").forEach((button) => {
        button.addEventListener("click", () => {
          const post = posts.find((item) => item.id === button.dataset.editPost);
          if (post) fillPostForm(post);
        });
      });
    }

    async function savePost() {
      try {
        setStatus("正在保存文章...");
        const id = postForm?.elements.id.value;
        const response = await fetch(id ? `/api/admin/posts/${encodeURIComponent(id)}` : "/api/admin/posts", {
          method: id ? "PATCH" : "POST",
          headers: {
            ...adminHeaders(),
            "Content-Type": "application/json",
          },
          body: JSON.stringify(getPostPayload()),
        });
        const saved = await readJson(response);
        setStatus(`已保存：${saved.title}`, "success");
        fillPostForm(saved);
        await loadPosts();
      } catch (error) {
        setStatus(error.message, "error");
      }
    }

    async function loadAssets() {
      try {
        const assets = await readJson(await fetch("/api/assets"));
        renderAssets(assets || []);
      } catch (error) {
        setStatus(error.message, "error");
      }
    }

    function renderAssets(assets) {
      if (!assetList) return;
      if (!assets.length) {
        assetList.innerHTML = `<div class="admin-empty">暂无资源。</div>`;
        return;
      }

      assetList.innerHTML = assets.map((asset) => `
        <article class="asset-item">
          <img src="${escapeHtml(asset.url)}" alt="${escapeHtml(asset.alt || asset.filename)}" loading="lazy" />
          <div>
            <strong>${escapeHtml(asset.filename)}</strong>
            <small>${Math.round((asset.byteSize || 0) / 1024)} KB</small>
            <code>${escapeHtml(asset.id)}</code>
            <div class="admin-item-actions">
              <button class="admin-small-button" type="button" data-cover-id="${escapeHtml(asset.id)}">封面</button>
              <button class="admin-small-button" type="button" data-copy-url="${escapeHtml(asset.url)}">复制 URL</button>
            </div>
          </div>
        </article>
      `).join("");

      assetList.querySelectorAll("[data-cover-id]").forEach((button) => {
        button.addEventListener("click", () => {
          if (postForm) postForm.elements.coverAssetId.value = button.dataset.coverId || "";
          setStatus("已填入封面资源 ID。", "success");
        });
      });

      assetList.querySelectorAll("[data-copy-url]").forEach((button) => {
        button.addEventListener("click", async () => {
          await navigator.clipboard?.writeText(button.dataset.copyUrl || "");
          setStatus("已复制资源 URL。", "success");
        });
      });
    }

    async function uploadAsset() {
      try {
        if (!assetForm) throw new Error("Asset form is missing.");
        const data = new FormData(assetForm);
        const file = data.get("file");
        if (!(file instanceof File) || !file.size) {
          throw new Error("请选择图片文件。");
        }

        setStatus("正在上传图片...");
        const uploaded = await readJson(await fetch("/api/admin/assets", {
          method: "POST",
          headers: adminHeaders(),
          body: data,
        }));
        setStatus(`已上传：${uploaded.filename}`, "success");
        assetForm.reset();
        await loadAssets();
      } catch (error) {
        setStatus(error.message, "error");
      }
    }

    postForm?.addEventListener("input", updatePreview);
    app?.querySelector("[data-save-post]")?.addEventListener("click", savePost);
    app?.querySelector("[data-reset-post]")?.addEventListener("click", resetPostForm);
    app?.querySelector("[data-upload-asset]")?.addEventListener("click", uploadAsset);
    app?.querySelector("[data-refresh-assets]")?.addEventListener("click", loadAssets);
    app?.querySelector("[data-refresh-posts]")?.addEventListener("click", loadPosts);
    tokenInput?.addEventListener("change", loadPosts);

    resetPostForm();
    loadAssets();
  </script>

  <style>
    .admin-shell {
      display: grid;
      gap: 22px;
      padding-top: 34px;
    }

    .admin-hero,
    .admin-panel {
      border: 1px solid var(--line);
      background: var(--surface);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
    }

    .admin-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(280px, 380px);
      gap: 22px;
      align-items: end;
      border-radius: 30px;
      padding: clamp(24px, 5vw, 42px);
    }

    .admin-hero h1 {
      margin: 0;
      font-size: clamp(2.1rem, 6vw, 4.6rem);
      line-height: 1.04;
      letter-spacing: 0;
    }

    .admin-hero p:not(.section-kicker) {
      max-width: 620px;
      margin: 14px 0 0;
      color: var(--muted);
      line-height: 1.75;
    }

    .admin-token-panel,
    .admin-form,
    .asset-upload {
      display: grid;
      gap: 14px;
    }

    .admin-token-panel label,
    .admin-form label,
    .asset-upload label {
      display: grid;
      gap: 8px;
      color: var(--muted);
      font-size: 0.88rem;
      font-weight: 760;
    }

    .admin-token-panel label {
      display: flex;
      align-items: center;
    }

    .admin-form input,
    .admin-form select,
    .admin-form textarea,
    .asset-upload input,
    .admin-token-panel input {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: var(--surface-control);
      color: var(--text);
      font: inherit;
      padding: 12px 14px;
    }

    .admin-form textarea {
      min-height: 430px;
      resize: vertical;
      font-family: "JetBrains Mono", "SFMono-Regular", Consolas, monospace;
      font-size: 0.92rem;
      line-height: 1.7;
    }

    .admin-readonly-field input {
      color: var(--muted);
      cursor: default;
      opacity: 0.86;
    }

    .admin-status {
      border: 1px solid var(--line);
      border-radius: 18px;
      background: var(--surface-control);
      color: var(--muted);
      padding: 12px 16px;
      font-size: 0.92rem;
      font-weight: 720;
    }

    .admin-status[data-type="success"] {
      border-color: rgba(47, 143, 112, 0.42);
      color: var(--accent-strong);
    }

    .admin-status[data-type="error"] {
      border-color: rgba(208, 96, 96, 0.42);
      color: #c85050;
    }

    .admin-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 360px;
      gap: 22px;
      align-items: start;
    }

    .admin-grid.lower {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    }

    .admin-panel {
      border-radius: 28px;
      padding: 22px;
    }

    .admin-panel-head {
      display: flex;
      gap: 16px;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 18px;
    }

    .admin-panel-head.compact {
      margin-bottom: 14px;
    }

    .admin-panel-head.with-gap {
      margin-top: 24px;
    }

    .admin-panel h2 {
      margin: 0;
      font-size: 1.2rem;
    }

    .admin-actions,
    .admin-item-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .admin-button,
    .admin-icon-button,
    .admin-small-button,
    .admin-icon-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--line);
      background: var(--surface-control);
      color: var(--text);
      cursor: pointer;
      font: inherit;
      font-weight: 780;
      transition:
        transform 180ms ease,
        border-color 180ms ease,
        background 180ms ease;
    }

    .admin-button {
      min-height: 42px;
      gap: 8px;
      border-radius: 999px;
      padding: 9px 14px;
    }

    .admin-button.primary {
      border-color: rgba(47, 143, 112, 0.35);
      background: var(--accent-strong);
      color: var(--bg);
    }

    .admin-icon-button,
    .admin-icon-link {
      width: 38px;
      height: 38px;
      border-radius: 999px;
    }

    .admin-small-button {
      min-height: 32px;
      border-radius: 999px;
      padding: 6px 10px;
      font-size: 0.82rem;
    }

    .admin-button:hover,
    .admin-icon-button:hover,
    .admin-small-button:hover,
    .admin-icon-link:hover {
      transform: translateY(-1px);
      border-color: rgba(117, 201, 165, 0.62);
      background: var(--accent-soft);
    }

    .admin-form-row {
      display: grid;
      gap: 14px;
    }

    .admin-form-row.two {
      grid-template-columns: 1fr 0.7fr;
    }

    .admin-form-row.three {
      grid-template-columns: 0.55fr 0.8fr 1fr;
    }

    .asset-list,
    .admin-list {
      display: grid;
      gap: 10px;
    }

    .asset-item,
    .admin-post-item {
      display: grid;
      gap: 12px;
      border: 1px solid var(--line);
      border-radius: 20px;
      background: var(--surface-control);
      padding: 12px;
    }

    .asset-item {
      grid-template-columns: 82px minmax(0, 1fr);
    }

    .asset-item img {
      width: 82px;
      height: 82px;
      border-radius: 16px;
      object-fit: cover;
      background: var(--bg-soft);
    }

    .asset-item strong,
    .admin-post-item h3 {
      display: block;
      margin: 0;
      line-height: 1.32;
    }

    .asset-item small,
    .admin-post-item small,
    .admin-post-item p {
      color: var(--muted);
    }

    .asset-item code {
      display: block;
      overflow: hidden;
      margin: 6px 0;
      color: var(--muted);
      font-size: 0.72rem;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .admin-post-item {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: center;
    }

    .admin-post-item p {
      margin: 6px 0;
      line-height: 1.55;
    }

    .admin-pill,
    .admin-preview-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border: 1px solid rgba(117, 201, 165, 0.3);
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-strong);
      font-size: 0.74rem;
      font-weight: 820;
      padding: 4px 9px;
    }

    .admin-preview {
      min-height: 360px;
      border: 1px solid var(--line);
      border-radius: 22px;
      background: var(--surface-control);
      padding: 20px;
      line-height: 1.85;
    }

