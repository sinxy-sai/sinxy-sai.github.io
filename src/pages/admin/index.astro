---
import {
  Activity,
  ArrowLeft,
  BarChart3,
  Bold,
  ChevronDown,
  ChevronRight,
  Clock3,
  Code2,
  Columns2,
  Eye,
  FilePlus,
  Globe2,
  PanelLeftClose,
  PanelLeftOpen,
  Images,
  ImagePlus,
  Italic,
  KeyRound,
  Link,
  List,
  ListOrdered,
  Moon,
  PencilLine,
  Quote,
  RefreshCw,
  RotateCcw,
  Save,
  Search,
  Send,
  SlidersHorizontal,
  Strikethrough,
  Sun,
  Trash2,
  TriangleAlert,
  Upload,
  X,
} from "lucide-astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Admin"
  description="Private blog publishing workspace."
  robots="noindex, nofollow"
>
  <section class="admin-shell" data-admin-app>
    <div class="admin-login-gate" data-admin-gate>
      <div class="admin-login-card">
        <div class="admin-login-head">
          <p class="section-kicker">Admin Access</p>
          <button class="admin-theme-toggle" type="button" data-admin-theme-toggle aria-label="切换主题">
            <Sun class="admin-theme-sun" size={16} aria-hidden="true" />
            <Moon class="admin-theme-moon" size={16} aria-hidden="true" />
            <span data-admin-theme-text>夜间</span>
          </button>
        </div>
        <h1>进入后台管理</h1>
        <p>请输入 Admin Token，验证通过后才能加载文章和媒体资源。</p>
        <label class="token-field login-token-field" for="admin-token">
          <KeyRound size={17} aria-hidden="true" />
          <span>Token</span>
          <input id="admin-token" type="password" autocomplete="current-password" data-admin-token />
        </label>
        <button class="admin-button primary" type="button" data-admin-login>
          进入管理系统
        </button>
        <div class="admin-login-status" data-admin-login-status role="status"></div>
      </div>
    </div>

    <header class="admin-editor-bar">
      <a class="back-link" href="/" aria-label="返回网站首页">‹ 返回</a>
      <div class="editor-title">
        <span class="section-kicker">Admin Workspace</span>
        <strong>发布文章</strong>
        <small data-word-count>0 字</small>
      </div>
      <button class="admin-theme-toggle" type="button" data-admin-theme-toggle aria-label="切换主题">
        <Sun class="admin-theme-sun" size={16} aria-hidden="true" />
        <Moon class="admin-theme-moon" size={16} aria-hidden="true" />
        <span data-admin-theme-text>夜间</span>
      </button>
    </header>

    <div class="admin-status" data-admin-status role="status">等待 Admin Token。</div>

    <div class="admin-workbench">
      <aside class="admin-panel post-library" aria-label="后台文章列表">
        <div class="panel-head">
          <div>
            <p class="section-kicker">Posts</p>
            <h2>文章库</h2>
          </div>
          <div class="icon-actions">
            <button class="icon-button" type="button" data-toggle-library aria-label="收起文章库">
              <PanelLeftClose class="library-icon-collapse" size={16} aria-hidden="true" />
              <PanelLeftOpen class="library-icon-expand" size={16} aria-hidden="true" />
            </button>
            <button class="icon-button" type="button" data-new-post aria-label="新建文章">
              <FilePlus size={16} aria-hidden="true" />
            </button>
            <button class="icon-button" type="button" data-refresh-posts aria-label="刷新文章">
              <RefreshCw size={16} aria-hidden="true" />
            </button>
          </div>
        </div>

        <div class="library-tools">
          <label class="search-field">
            <Search size={16} aria-hidden="true" />
            <input type="search" placeholder="搜索标题、slug、标签" data-post-filter />
          </label>
          <select data-status-filter aria-label="按状态筛选">
            <option value="ALL">全部状态</option>
            <option value="PUBLISHED">已发布</option>
            <option value="DRAFT">草稿</option>
          </select>
        </div>

        <div class="post-list" data-post-list></div>

        <nav class="library-rail" aria-label="后台功能区">
          <button class="rail-button is-active" type="button" data-open-editor aria-label="打开编辑区" aria-pressed="true">
            <PencilLine size={17} aria-hidden="true" />
            <span>编辑</span>
          </button>
          <button class="rail-button" type="button" data-open-settings aria-label="打开发布设置" aria-pressed="false">
            <SlidersHorizontal size={17} aria-hidden="true" />
            <span>设置</span>
          </button>
          <button class="rail-button" type="button" data-open-media aria-label="打开媒体资源管理" aria-pressed="false">
            <Images size={17} aria-hidden="true" />
            <span>媒体</span>
          </button>
          <button class="rail-button" type="button" data-open-analytics aria-label="打开统计面板" aria-pressed="false">
            <BarChart3 size={17} aria-hidden="true" />
            <span>统计</span>
          </button>
          <button class="rail-button" type="button" data-open-toc aria-label="打开文章目录" aria-pressed="false">
            <List size={17} aria-hidden="true" />
            <span>目录</span>
          </button>
        </nav>
      </aside>

      <main class="admin-panel editor-panel">
        <form class="post-form" data-post-form>
          <input type="hidden" name="id" data-post-id />
          <input type="hidden" name="coverAssetId" data-cover-asset-id />

          <section class="settings-view" data-settings-view hidden>
            <div class="settings-head">
              <div>
                <p class="section-kicker">Publish Settings</p>
                <h2>发布设置</h2>
              </div>
              <button class="admin-button" type="button" data-open-editor>
                <PencilLine size={16} aria-hidden="true" />
                返回编辑区
              </button>
            </div>

            <div class="title-row">
              <label>
                <span>文章标题</span>
                <input name="title" type="text" maxlength="180" required placeholder="请输入文章标题" />
              </label>
              <label>
                <span>Slug</span>
                <input name="slug" type="text" maxlength="120" placeholder="留空时由标题生成" />
              </label>
            </div>

            <label class="description-field">
              <span>摘要描述</span>
              <input name="description" type="text" maxlength="320" required placeholder="用于首页、RSS 和搜索结果展示" />
            </label>

            <div class="publish-strip">
              <fieldset class="status-toggle">
                <legend>发布状态</legend>
                <label>
                  <input name="status" type="radio" value="DRAFT" checked />
                  <Clock3 size={15} aria-hidden="true" />
                  草稿
                </label>
                <label>
                  <input name="status" type="radio" value="PUBLISHED" />
                  <Send size={15} aria-hidden="true" />
                  发布
                </label>
              </fieldset>
              <label>
                <span>发布时间</span>
                <input name="pubDate" type="datetime-local" />
              </label>
              <label>
                <span>最后编辑</span>
                <input name="updatedAt" type="text" placeholder="保存后自动记录" readonly />
              </label>
            </div>

            <div class="publishing-meta-grid">
              <fieldset class="settings-choice-group">
                <legend>文章类型</legend>
                <label>
                  <input name="contentOrigin" type="radio" value="ORIGINAL" checked />
                  原创
                </label>
                <label>
                  <input name="contentOrigin" type="radio" value="REPOST" />
                  转载
                </label>
                <label>
                  <input name="contentOrigin" type="radio" value="TRANSLATION" />
                  翻译
                </label>
              </fieldset>

              <label class="statement-field">
                <span>创作声明</span>
                <select name="creationStatement">
                  <option value="NONE">无声明</option>
                  <option value="AI_ASSISTED">部分内容由 AI 辅助生成</option>
                  <option value="AGGREGATED">内容来源网络，进行整合/再创作</option>
                  <option value="PERSONAL_VIEW">个人观点，仅供参考</option>
                </select>
              </label>

              <fieldset class="settings-choice-group">
                <legend>可见范围</legend>
                <label>
                  <input name="visibility" type="radio" value="PUBLIC" checked />
                  全部可见
                </label>
                <label>
                  <input name="visibility" type="radio" value="PRIVATE" />
                  仅我可见
                </label>
              </fieldset>
            </div>

            <div class="publish-strip secondary">
              <label>
                <span>标签</span>
                <input name="tags" type="text" placeholder="Backend, D1, Cloudflare" />
              </label>
            </div>

            <section class="settings-media-card" aria-label="封面与图片资源">
              <div class="settings-card-head">
                <div>
                  <p class="section-kicker">Cover Media</p>
                  <h3>封面与图片资源</h3>
                </div>
                <button class="icon-button" type="button" data-refresh-assets aria-label="刷新资源">
                  <RefreshCw size={16} aria-hidden="true" />
                </button>
              </div>

              <div class="cover-current" data-cover-summary>
                <span>当前封面</span>
                <strong>未选择封面</strong>
                <button class="mini-button" type="button" data-clear-cover hidden>清除封面</button>
              </div>

              <div class="asset-upload" data-asset-form>
                <label>
                  <span>图片文件</span>
                  <input name="file" type="file" accept="image/jpeg,image/png,image/webp,image/gif" />
                </label>
                <label>
                  <span>替代文本（alt）</span>
                  <input name="alt" type="text" maxlength="240" placeholder="图片无法显示时的说明文字" />
                </label>
                <button class="admin-button primary full" type="button" data-upload-asset>
                  <Upload size={16} aria-hidden="true" />
                  上传图片
                </button>
              </div>

              <div class="asset-list" data-asset-list></div>
            </section>
          </section>

          <section class="media-view" data-media-view hidden>
            <div class="settings-head">
              <div>
                <p class="section-kicker">Media Library</p>
                <h2>媒体资源管理</h2>
              </div>
              <div class="button-row">
                <button class="admin-button" type="button" data-refresh-assets>
                  <RefreshCw size={16} aria-hidden="true" />
                  刷新
                </button>
                <button class="admin-button" type="button" data-open-editor>
                  <PencilLine size={16} aria-hidden="true" />
                  返回编辑区
                </button>
              </div>
            </div>

            <div class="media-toolbar">
              <div class="media-upload-card" data-media-asset-form>
                <label>
                  <span>上传文件</span>
                  <input name="file" type="file" accept="image/jpeg,image/png,image/webp,image/gif" />
                </label>
                <label>
                  <span>替代文本（alt）</span>
                  <input name="alt" type="text" maxlength="240" placeholder="图片无法显示时的说明文字" />
                </label>
                <button class="admin-button primary" type="button" data-upload-media-asset>
                  <Upload size={16} aria-hidden="true" />
                  上传文件
                </button>
              </div>

              <label class="search-field media-search">
                <Search size={16} aria-hidden="true" />
                <input type="search" placeholder="搜索文件名、类型、alt" data-media-filter />
              </label>
            </div>

            <div class="media-file-manager">
              <div class="media-table-head" aria-hidden="true">
                <span>文件名</span>
                <span>大小</span>
                <span>文件类型</span>
                <span>上传时间</span>
                <span>操作</span>
              </div>
              <div class="media-list" data-media-list></div>
            </div>
          </section>

          <section class="analytics-view" data-analytics-view hidden>
            <div class="settings-head">
              <div>
                <p class="section-kicker">Analytics</p>
                <h2>站点统计</h2>
              </div>
              <div class="button-row">
                <button class="admin-button" type="button" data-refresh-analytics>
                  <RefreshCw size={16} aria-hidden="true" />
                  刷新
                </button>
                <button class="admin-button" type="button" data-open-editor>
                  <PencilLine size={16} aria-hidden="true" />
                  返回编辑区
                </button>
              </div>
            </div>

            <div class="analytics-summary" data-analytics-summary>
              <article>
                <span>今日 PV</span>
                <strong>--</strong>
              </article>
              <article>
                <span>今日 UV</span>
                <strong>--</strong>
              </article>
              <article>
                <span>平均 API 延迟</span>
                <strong>--</strong>
              </article>
              <article>
                <span>最近错误</span>
                <strong>--</strong>
              </article>
            </div>

            <div class="analytics-overview" data-analytics-overview>
              <button class="analytics-entry" type="button" data-open-analytics-detail="traffic" disabled>
                <span class="analytics-entry-icon"><BarChart3 size={20} aria-hidden="true" /></span>
                <span>
                  <small>Traffic</small>
                  <strong>最近 7 天访问</strong>
                  <b data-analytics-entry-metric="traffic">--</b>
                </span>
                <ChevronRight size={18} aria-hidden="true" />
              </button>
              <button class="analytics-entry" type="button" data-open-analytics-detail="pages" disabled>
                <span class="analytics-entry-icon"><Globe2 size={20} aria-hidden="true" /></span>
                <span>
                  <small>Pages</small>
                  <strong>热门页面</strong>
                  <b data-analytics-entry-metric="pages">--</b>
                </span>
                <ChevronRight size={18} aria-hidden="true" />
              </button>
              <button class="analytics-entry" type="button" data-open-analytics-detail="api" disabled>
                <span class="analytics-entry-icon"><Clock3 size={20} aria-hidden="true" /></span>
                <span>
                  <small>Performance</small>
                  <strong>API 延迟</strong>
                  <b data-analytics-entry-metric="api">--</b>
                </span>
                <ChevronRight size={18} aria-hidden="true" />
              </button>
              <button class="analytics-entry" type="button" data-open-analytics-detail="vitals" disabled>
                <span class="analytics-entry-icon"><Activity size={20} aria-hidden="true" /></span>
                <span>
                  <small>Web Vitals</small>
                  <strong>前端性能</strong>
                  <b data-analytics-entry-metric="vitals">--</b>
                </span>
                <ChevronRight size={18} aria-hidden="true" />
              </button>
              <button class="analytics-entry" type="button" data-open-analytics-detail="errors" disabled>
                <span class="analytics-entry-icon"><TriangleAlert size={20} aria-hidden="true" /></span>
                <span>
                  <small>Errors</small>
                  <strong>最近错误</strong>
                  <b data-analytics-entry-metric="errors">--</b>
                </span>
                <ChevronRight size={18} aria-hidden="true" />
              </button>
            </div>

            <section class="analytics-detail" data-analytics-detail hidden>
              <div class="analytics-detail-head">
                <button class="admin-button ghost" type="button" data-close-analytics-detail>
                  <ArrowLeft size={16} aria-hidden="true" />
                  返回统计总览
                </button>
                <div>
                  <p class="section-kicker" data-analytics-detail-kicker>Traffic</p>
                  <h3 data-analytics-detail-title>最近 7 天访问</h3>
                </div>
              </div>

              <div class="analytics-detail-panels">
              <section class="analytics-card" data-analytics-panel="traffic">
                <div class="analytics-bars" data-analytics-daily></div>
              </section>

              <section class="analytics-card" data-analytics-panel="pages" hidden>
                <div class="analytics-list" data-analytics-pages></div>
              </section>

              <section class="analytics-card" data-analytics-panel="api" hidden>
                <div class="analytics-list" data-analytics-api></div>
              </section>

              <section class="analytics-card" data-analytics-panel="vitals" hidden>
                <div class="analytics-list" data-analytics-vitals></div>
              </section>

              <section class="analytics-card" data-analytics-panel="errors" hidden>
                <div class="analytics-list" data-analytics-errors></div>
              </section>
              </div>
            </section>
          </section>

          <section class="editor-view" data-editor-view>
            <div class="markdown-toolbar" aria-label="Markdown 快捷工具栏">
              <button class="tool-button" type="button" data-md-action="bold" title="加粗">
                <Bold size={16} aria-hidden="true" />
              </button>
              <button class="tool-button" type="button" data-md-action="italic" title="斜体">
                <Italic size={16} aria-hidden="true" />
              </button>
              <button class="tool-button" type="button" data-md-action="strike" title="删除线">
                <Strikethrough size={16} aria-hidden="true" />
              </button>
              <div class="toolbar-menu" data-toolbar-menu>
                <button class="toolbar-menu-trigger" type="button" data-menu-trigger aria-haspopup="true" aria-expanded="false">
                  <span class="heading-trigger-label" aria-hidden="true">H</span>
                  <ChevronDown size={13} aria-hidden="true" />
                </button>
                <div class="toolbar-menu-list" data-menu-list hidden>
                  <button class="heading-option" type="button" data-heading-level="1">一级标题</button>
                  <button class="heading-option" type="button" data-heading-level="2">二级标题</button>
                  <button class="heading-option" type="button" data-heading-level="3">三级标题</button>
                  <button class="heading-option" type="button" data-heading-level="4">四级标题</button>
                </div>
              </div>
              <button class="tool-button" type="button" data-md-action="quote" title="引用">
                <Quote size={16} aria-hidden="true" />
              </button>
              <div class="toolbar-menu" data-toolbar-menu>
                <button class="toolbar-menu-trigger" type="button" data-menu-trigger aria-haspopup="true" aria-expanded="false">
                  <List size={16} aria-hidden="true" />
                  <ChevronDown size={13} aria-hidden="true" />
                </button>
                <div class="toolbar-menu-list" data-menu-list hidden>
                  <button type="button" data-list-type="unordered">
                    <List size={16} aria-hidden="true" />
                    无序列表
                  </button>
                  <button type="button" data-list-type="ordered">
                    <ListOrdered size={16} aria-hidden="true" />
                    有序列表
                  </button>
                </div>
              </div>
              <div class="toolbar-menu" data-toolbar-menu>
                <button class="toolbar-menu-trigger" type="button" data-menu-trigger aria-haspopup="true" aria-expanded="false">
                  <Code2 size={16} aria-hidden="true" />
                  <ChevronDown size={13} aria-hidden="true" />
                </button>
                <div class="toolbar-menu-list wide code-languages" data-menu-list hidden>
                  <button type="button" data-code-language="text">纯文本</button>
                  <button type="button" data-code-language="javascript">JavaScript</button>
                  <button type="button" data-code-language="typescript">TypeScript</button>
                  <button type="button" data-code-language="html">HTML</button>
                  <button type="button" data-code-language="css">CSS</button>
                  <button type="button" data-code-language="bash">Bash</button>
                  <button type="button" data-code-language="python">Python</button>
                  <button type="button" data-code-language="c">C</button>
                  <button type="button" data-code-language="cpp">C++</button>
                  <button type="button" data-code-language="java">Java</button>
                  <button type="button" data-code-language="csharp">C#</button>
                  <button type="button" data-code-language="go">Go</button>
                  <button type="button" data-code-language="rust">Rust</button>
                  <button type="button" data-code-language="php">PHP</button>
                  <button type="button" data-code-language="kotlin">Kotlin</button>
                  <button type="button" data-code-language="swift">Swift</button>
                  <button type="button" data-code-language="sql">SQL</button>
                  <button type="button" data-code-language="json">JSON</button>
                  <button type="button" data-code-language="yaml">YAML</button>
                  <button type="button" data-code-language="markdown">Markdown</button>
                </div>
              </div>
              <button class="tool-button" type="button" data-open-link-dialog title="链接">
                <Link size={16} aria-hidden="true" />
              </button>
              <button class="tool-button" type="button" data-open-image-dialog title="插入图片">
                <ImagePlus size={16} aria-hidden="true" />
              </button>
              <span class="toolbar-spacer"></span>
              <div class="toolbar-view-mode" role="group" aria-label="编辑预览模式">
                <button class="view-mode-button" type="button" data-editor-mode-button="markdown" aria-pressed="false">
                  <Code2 size={16} aria-hidden="true" />
                  Markdown
                </button>
                <button class="view-mode-button is-active" type="button" data-editor-mode-button="compare" aria-pressed="true">
                  <Columns2 size={16} aria-hidden="true" />
                  比对
                </button>
                <button class="view-mode-button" type="button" data-editor-mode-button="preview" aria-pressed="false">
                  <Eye size={16} aria-hidden="true" />
                  预览
                </button>
              </div>
              <button class="tool-button text-tool" type="button" data-open-settings title="发布设置">
                <SlidersHorizontal size={16} aria-hidden="true" />
                设置
              </button>
            </div>

            <dialog class="editor-dialog" data-link-dialog aria-label="插入链接">
              <div class="dialog-head">
                <div>
                  <p class="section-kicker">Link</p>
                  <h3>插入链接</h3>
                </div>
                <button class="icon-button" type="button" data-close-dialog aria-label="关闭链接弹窗">×</button>
              </div>
              <div class="dialog-grid">
                <label>
                  <span>链接文字</span>
                  <input name="linkText" type="text" data-link-text placeholder="链接文本" />
                </label>
                <label>
                  <span>链接地址</span>
                  <input name="linkUrl" type="url" data-link-url placeholder="https://example.com" />
                </label>
              </div>
              <div class="dialog-actions">
                <button class="admin-button ghost" type="button" data-close-dialog>取消</button>
                <button class="admin-button primary" type="button" data-insert-link>插入链接</button>
              </div>
            </dialog>

            <dialog class="editor-dialog image-dialog" data-image-dialog aria-label="插入图片">
              <div class="dialog-head">
                <div>
                  <p class="section-kicker">Image</p>
                  <h3>插入图片</h3>
                </div>
                <button class="icon-button" type="button" data-close-dialog aria-label="关闭图片弹窗">×</button>
              </div>
              <div class="image-insert-grid">
                <section class="image-insert-card">
                  <h4>本地上传</h4>
                  <label>
                    <span>图片文件</span>
                    <input data-inline-image-file type="file" accept="image/jpeg,image/png,image/webp,image/gif" />
                  </label>
                  <label>
                    <span>替代文本（alt）</span>
                    <input data-inline-image-alt type="text" maxlength="240" placeholder="图片无法显示时的说明文字" />
                  </label>
                  <small>支持 JPG、JPEG、PNG、WEBP、GIF，单张最大 5MB。</small>
