  <script>
    import katex from "katex";

    const app = document.querySelector("[data-admin-app]");
    const authGate = app?.querySelector("[data-admin-gate]");
    const tokenInput = app?.querySelector("[data-admin-token]");
    const loginButton = app?.querySelector("[data-admin-login]");
    const loginStatusEl = app?.querySelector("[data-admin-login-status]");
    const statusEl = app?.querySelector("[data-admin-status]");
    const postForm = app?.querySelector("[data-post-form]");
    const assetForm = app?.querySelector("[data-asset-form]");
    const mediaAssetForm = app?.querySelector("[data-media-asset-form]");
    const postList = app?.querySelector("[data-post-list]");
    const assetList = app?.querySelector("[data-asset-list]");
    const mediaList = app?.querySelector("[data-media-list]");
    const mediaFilterInput = app?.querySelector("[data-media-filter]");
    const markdownPreview = app?.querySelector("[data-markdown-preview]");
    const markdownInput = app?.querySelector("[data-markdown-input]");
    const editorSplit = app?.querySelector("[data-editor-split]");
    const editorModeButtons = app?.querySelectorAll("[data-editor-mode-button]") || [];
