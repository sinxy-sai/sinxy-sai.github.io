---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { render } from "astro:content";
import { estimateReadingMinutes, formatDate, getPublishedPosts } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const allPosts = await getPublishedPosts();
const currentIndex = allPosts.findIndex((item) => item.id === post.id);
const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : undefined;
const olderPost = currentIndex >= 0 ? allPosts[currentIndex + 1] : undefined;
const { Content, headings } = await render(post);
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const minutes = estimateReadingMinutes(post.body ?? "");
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={post.data.pubDate.toISOString()}
  tags={post.data.tags}
>
  <div class:list={["article-layout", toc.length > 0 ? "has-toc" : "no-toc"]}>
    {
      toc.length > 0 && (
        <aside class="article-toc" aria-label="文章目录">
          <h2>目录</h2>
          <ol>
            {toc.map((heading) => (
              <li class={`toc-depth-${heading.depth}`}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ol>
        </aside>
      )
    }

    <article class="article" data-pagefind-body>
      <header class="article-header">
        <p class="section-kicker">Article</p>
        <h1 class="article-title">{post.data.title}</h1>
        <div class="meta">
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          <span>{minutes} 分钟阅读</span>
          {
            post.data.updatedDate && (
              <span>更新于 {formatDate(post.data.updatedDate)}</span>
            )
          }
        </div>
        <div class="tag-list">
          {
            post.data.tags.map((tag) => (
              <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>
                {tag}
              </a>
            ))
          }
        </div>
      </header>
      <div class="prose">
        <Content />
      </div>

      <nav class="post-nav" aria-label="文章导航">
        {
          newerPost ? (
            <a href={`/blog/${newerPost.id}/`}>
              <small>上一篇</small>
              <strong>{newerPost.data.title}</strong>
            </a>
          ) : (
            <span>已经是最新文章</span>
          )
        }
        {
          olderPost ? (
            <a href={`/blog/${olderPost.id}/`}>
              <small>下一篇</small>
              <strong>{olderPost.data.title}</strong>
            </a>
          ) : (
            <span>已经是最后一篇</span>
          )
        }
      </nav>
    </article>
  </div>
</BaseLayout>
