---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, getPublishedPosts } from "../../lib/posts";

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
---

<BaseLayout title="标签" description="Browse posts by tag.">
  <section>
    <p class="section-kicker">Tags</p>
    <h1 class="page-title">标签</h1>
    <p class="page-description">把文章按主题归类，方便之后回看。</p>
  </section>

  <section class="tag-list" style="margin-top: 36px">
    {
      tags.map(([tag, count]) => (
        <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>
          {tag} · {count}
        </a>
      ))
    }
  </section>
</BaseLayout>
